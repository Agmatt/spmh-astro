---
import Layout from '../../Layout/Layout.astro';

const ADMIN_EMAIL = 'st.paulsmissionhospital2025@gmail.com'; 
const SUBJECT = encodeURIComponent(
  "Partnership Enquiry — St. Paul's Mission Hospital",
);
const MAILTO = `mailto:${ADMIN_EMAIL}?subject=${SUBJECT}`;

const partnerTypes = [
  {
    category: 'Infrastructure',
    title: 'Capital Development',
    desc: 'Support the construction and modernisation of our new Maternity & Surgical Wing, solar energy integration, and expanding ward capacity as we grow toward Level 5.',
    examples: [
      'Construction & civil works',
      'Solar & energy systems',
      'Medical equipment supply',
      'Renovation & fit-out',
    ],
    icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-2 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4',
  },
  {
    category: 'Clinical Technology',
    title: 'Diagnostic Systems',
    desc: 'Partner with us to bring CT & MRI imaging, electronic medical records, telemedicine infrastructure, and point-of-care diagnostics to Homa Bay County.',
    examples: [
      'Imaging (CT, MRI, X-Ray)',
      'EMR & health IT systems',
      'Telemedicine platforms',
      'Laboratory automation',
    ],
    icon: 'M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18',
  },
  {
    category: 'Public Health',
    title: 'Community Programmes',
    desc: 'Co-develop and fund outreach programmes aligned with Ministry of Health priorities — maternal and child health, nutrition, disease prevention, and community health education.',
    examples: [
      'MNCH outreach',
      'Nutrition & food security',
      'Infectious disease control',
      'Community health education',
    ],
    icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z',
  },
  {
    category: 'Academia & Research',
    title: 'Knowledge Exchange',
    desc: "We welcome academic institutions and research bodies for internship placements, clinical rotations, nursing attachments, and joint research initiatives at St. Paul's.",
    examples: [
      'Medical & nursing internships',
      'Clinical rotation placements',
      'Health research partnerships',
      'CME & training programmes',
    ],
    icon: 'M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253',
  },
  {
    category: 'Faith & NGOs',
    title: 'Mission Alignment',
    desc: 'We partner with faith-based organisations, charities, and NGOs whose values align with our founding charism — dignified care for the poor, the sick, and the marginalised.',
    examples: [
      'Faith-based organisations',
      'International NGOs & charities',
      'Local CBOs & community groups',
      'Diocesan health networks',
    ],
    icon: 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z',
  },
  {
    category: 'Corporate',
    title: 'Corporate Social Responsibility',
    desc: 'Companies seeking meaningful CSR alignment can sponsor equipment, fund specific programmes, or support the care of underprivileged patients across Homa Bay County.',
    examples: [
      'Equipment sponsorship',
      'Patient care funds',
      'Staff welfare programmes',
      'Health camps & outreach',
    ],
    icon: 'M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z',
  },
];

const logos = [
  { src: '/logos/kccb.png', alt: 'KCCB' },
  { src: '/logos/aar.png', alt: 'AAR Health' },
  { src: '/logos/jubilee.png', alt: 'Jubilee Insurance' },
  { src: '/logos/apa.png', alt: 'APA Insurance' },
  { src: '/logos/britam.png', alt: 'Britam' },
  { src: '/logos/aon.png', alt: 'AON Kenya' },
  { src: '/logos/sha.png', alt: 'SHA' },
  { src: '/logos/moh.png', alt: 'Ministry of Health' },
  { src: '/logos/nps.png', alt: 'NPS' },
  { src: '/logos/cic.png', alt: 'CIC Group' },
  { src: '/logos/madison.png', alt: 'Madison Insurance' },
];
// Duplicate for seamless CSS loop
const marqueeLogos = [...logos, ...logos];
---

<Layout title="Partner With Us — St. Paul's Mission Hospital">
  <!-- HERO -->
  <header class='relative bg-secondary overflow-hidden'>
    <div class='relative z-10 max-w-7xl mx-auto px-6 lg:px-16 pt-24 pb-20'>
      <div class='grid lg:grid-cols-12 gap-10 items-end'>
        <div class='lg:col-span-7'>
          <p
            class='text-primary-light text-xs tracking-[0.22em] uppercase font-semibold mb-5 flex items-center gap-3'>
            <span class='w-8 h-px bg-primary-light inline-block'></span>
            Partner With Us
          </p>
          <h1
            class='font-display text-white text-5xl sm:text-6xl lg:text-7xl font-normal leading-[1.0]'>
            Build something<br />
            <span class='font-semibold text-primary-light'>that lasts.</span>
          </h1>
        </div>

        <div class='lg:col-span-5 pb-1 border-l border-white/15 pl-8'>
          <p
            class='font-display text-white/70 text-lg italic font-normal leading-relaxed mb-7'>
            St. Paul's Mission Hospital has served Homa Bay County since 1983.
            Our Strategic Plan 2026–2030 charts an ambitious path to Level 5 —
            and we cannot do it alone.
          </p>
          <div class='flex flex-wrap gap-2'>
            {
              [
                'SHA Accredited',
                'MoH Compliant',
                'KEC–CHC Affiliated',
                'Level 4 Facility',
              ].map((chip) => (
                <span class='text-[0.6rem] font-bold tracking-[0.14em] uppercase border border-white/20 text-white/60 px-3 py-1'>
                  {chip}
                </span>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </header>

  <!--STATS BAND -->
  <div class='bg-white border-b border-border/60'>
    <div class='max-w-7xl mx-auto px-6 lg:px-16 py-8'>
      <div class='grid grid-cols-2 sm:grid-cols-4 divide-x divide-border/60'>
        {
          [
            { stat: '1983', label: 'Year founded' },
            { stat: 'L4→5', label: 'Facility target 2030' },
            { stat: '25+', label: 'Insurance partners' },
            { stat: '6', label: 'Partnership pathways' },
          ].map((s) => (
            <div class='px-6 first:pl-0 last:pr-0'>
              <div class='font-display text-secondary text-3xl font-bold leading-none mb-1'>
                {s.stat}
              </div>
              <div class='text-muted text-[0.65rem] tracking-wide uppercase'>
                {s.label}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>

  <!-- SIX PARTNERSHIP PATHWAYS -->
  <section class='bg-surface py-20 lg:py-28'>
    <div class='max-w-7xl mx-auto px-2 md:px-4 lg:px-10'>
      <div class='mx-auto text-center mb-14'>
        <h2 class='font-semibold text-primary text-4xl'>
          Partnership Pathways
        </h2>
      </div>

      <div class='grid sm:grid-cols-2 lg:grid-cols-3 gap-5'>
        {
          partnerTypes.map((p) => (
            <div
              class='group bg-white border border-border/60
                       hover:border-primary/30 hover:shadow-xl hover:shadow-primary/5
                       hover:-translate-y-1 transition-all duration-300 flex flex-col p-7'>
              <div class='flex items-start justify-between mb-6'>
                <div class='size-12 bg-surface group-hover:bg-secondary flex items-center justify-center transition-colors duration-300'>
                  <svg
                    class='size-5 text-primary group-hover:text-white transition-colors duration-300'
                    fill='none'
                    stroke='currentColor'
                    stroke-width='1.5'
                    viewBox='0 0 24 24'>
                    <path
                      stroke-linecap='round'
                      stroke-linejoin='round'
                      d={p.icon}
                    />
                  </svg>
                </div>
                <span class='text-[0.58rem] font-bold tracking-[0.16em] uppercase text-muted/60 bg-surface border border-border/60 px-2 py-1'>
                  {p.category}
                </span>
              </div>

              <div class='flex-1'>
                <h3 class='font-display text-xl font-semibold text-secondary group-hover:text-primary transition-colors duration-200 mb-3'>
                  {p.title}
                </h3>
                <p class='text-muted text-sm leading-relaxed mb-5'>{p.desc}</p>
              </div>

              <ul class='space-y-2 pt-5 border-t border-border/50'>
                {p.examples.map((ex) => (
                  <li class='flex items-center gap-2.5'>
                    <span class='w-3 h-px bg-primary/30 shrink-0' />
                    <span class='text-muted text-xs'>{ex}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!--  PARTNER LOGOS — CSS marquee -->
  <section class='bg-white border-y border-border/60 py-14 overflow-hidden'>
    <div class='max-w-7xl mx-auto px-6 lg:px-16 mb-8'>
      <p
        class='text-primary text-xs tracking-[0.22em] uppercase font-semibold flex items-center gap-3'>
        <span class='w-8 h-px bg-primary inline-block'></span>
        Our partners & accredited underwriters
      </p>
    </div>

    <div class='relative flex overflow-hidden'>
      <div
        class='absolute left-0 top-0 bottom-0 w-24 bg-gradient-to-r from-white to-transparent z-10 pointer-events-none'>
      </div>
      <div
        class='absolute right-0 top-0 bottom-0 w-24 bg-gradient-to-l from-white to-transparent z-10 pointer-events-none'>
      </div>

      <div class='flex items-center partner-marquee'>
        {
          marqueeLogos.map((logo) => (
            <div class='mx-10 flex items-center justify-center shrink-0'>
              <img
                src={logo.src}
                alt={logo.alt}
                class='h-12 w-auto object-contain grayscale hover:grayscale-0 opacity-50 hover:opacity-100 transition-all duration-300'
                loading='lazy'
              />
            </div>
          ))
        }
      </div>
    </div>

    <p
      class='text-slate-700 text-[0.62rem] tracking-widest uppercase text-center mt-8'>
      Supporting 25+ private and corporate medical schemes
    </p>
  </section>

  <!--  GOVERNANCE  -->
  <section class='bg-surface border-b border-border/60 py-16'>
    <div class='max-w-7xl mx-auto px-4 lg:px-16'>
      <div class='grid lg:grid-cols-12 gap-10 items-start'>
        <div class='lg:col-span-4'>
          <p
            class='text-primary text-xs tracking-[0.22em] uppercase font-semibold mb-4 flex items-center gap-3'>
            Governance & Transparency
          </p>
          <h2
            class='font-display text-secondary text-2xl sm:text-3xl font-normal leading-snug mb-4'>
            A trustworthy<br />
            <span class='font-semibold text-primary'
              >institutional partner.</span
            >
          </h2>
          <p class='text-muted text-sm leading-relaxed'>
            All partnerships are governed by our Board of Management and the
            Catholic Diocese of Homa Bay, in full compliance with Kenyan
            regulatory requirements.
          </p>
        </div>

        <div
          class='lg:col-span-8 grid grid-cols-2 sm:grid-cols-3 gap-4 lg:pl-10 lg:border-l border-border/60'>
          {
            [
              { label: 'Accreditation', value: 'SHA Accredited\nFacility' },
              { label: 'Governance', value: 'Board of Management\n& Diocese' },
              { label: 'Authority', value: 'KMPDC\nCertified' },
              {
                label: 'Affiliation',
                value: 'KEC–Catholic\nHealth Commission',
              },
              {
                label: 'Data Privacy',
                value: 'Kenya Data Protection\nAct Aligned',
              },
              { label: 'Financial', value: 'Annual External\nAudit Cycle' },
            ].map((c) => (
              <div class='p-5 bg-white border border-border/60'>
                <p class='text-[0.58rem] font-bold uppercase tracking-widest text-muted/50 mb-2'>
                  {c.label}
                </p>
                <p class='text-secondary text-xs font-bold leading-snug whitespace-pre-line'>
                  {c.value}
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

 

  <!-- CONTACT CTA -->
  <section class='bg-gray-300 py-20 relative overflow-hidden'>
    <!-- Dot grid -->
    <div class='relative max-w-7xl mx-auto px-4 lg:px-16 text-center'>
      <p
        class='text-primary/70 text-xs tracking-[0.22em] uppercase font-semibold mb-4'>
        Partner With Us
      </p>

      <h2
        class='font-display text-slate-800 text-3xl sm:text-4xl font-normal leading-snug mb-4'>
        Interested in working<br />
        <span class='font-semibold text-primary'
          >with St. Paul's?</span
        >
      </h2>

      <p class='text-slate-700 text-sm leading-relaxed mb-10 max-w-sm mx-auto'>
        We welcome proposals from organisations, institutions, and community
        partners. Reach out — we respond within 3 working days.
      </p>

      <a
        href={MAILTO}
        class='group inline-flex items-center gap-3 bg-primary hover:bg-primary-dark
             text-white font-semibold text-sm tracking-wide px-8 py-4
             transition-all duration-200 hover:-translate-y-0.5
             hover:shadow-lg hover:shadow-primary/30'>
        Send us a message
        <svg
          class='size-4 transition-transform group-hover:translate-x-1'
          fill='none'
          stroke='currentColor'
          stroke-width='2'
          viewBox='0 0 24 24'>
          <path
            stroke-linecap='round'
            stroke-linejoin='round'
            d='M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z'
          ></path>
        </svg>
      </a>
    </div>
  </section>
</Layout>

<style>
  .partner-marquee {
    animation: marquee-scroll 35s linear infinite;
    will-change: transform;
  }
  .partner-marquee:hover {
    animation-play-state: paused;
  }
  @keyframes marquee-scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }
</style>
