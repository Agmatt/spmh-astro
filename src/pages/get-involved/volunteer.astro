---
import Layout from '../../Layout/Layout.astro';


const REGISTER_FORM  = "https://docs.google.com/forms/d/e/YOUR_FORM_ID/viewform"
const GUIDELINES_PDF = "/docs/Volunteer Operation Manual.pdf"
const CONTACT_EMAIL  = "volunteer@stpauls.go.ke"

const serviceSectors = [
  {
    id:     "01",
    sector: "Clinical & Patient Flow",
    roles:  ["Triage Support", "Ward Companionship", "Patient Wayfinding"],
    intent: "Assist nursing staff with non-clinical patient navigation and comfort — helping patients feel seen and supported from the moment they arrive.",
    icon:   "M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z",
    iconFill: true,
  },
  {
    id:     "02",
    sector: "Data & Health Informatics",
    roles:  ["ICT Support", "Records Digitisation", "EMR Assistance"],
    intent: "Support the integrity and digital flow of patient health records — helping our clinical teams access the information they need, when they need it.",
    icon:   "M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z",
    iconFill: false,
  },
  {
    id:     "03",
    sector: "Institutional Administration",
    roles:  ["Claims Processing", "Finance Support", "Front Office"],
    intent: "Strengthen the administrative backbone of the hospital — freeing clinical staff to focus on care by supporting the systems that keep St. Paul's running.",
    icon:   "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4",
    iconFill: false,
  },
  {
    id:     "04",
    sector: "Social & Community",
    roles:  ["Medical Social Work", "Community Health Outreach", "Liaison"],
    intent: "Extend care beyond hospital walls into Homa Bay County — reaching families and communities who need support, information, and connection to services.",
    icon:   "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z",
    iconFill: false,
  },
  {
    id:     "05",
    sector: "Technical & Logistics",
    roles:  ["Radiology Aide", "Inventory Support", "Lab Logistics"],
    intent: "Facilitate the movement of supplies and patients across specialised units — the behind-the-scenes work that makes clinical care possible.",
    icon:   "M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z",
    iconFill: false,
  },
]

const steps = [
  {
    num:  "01",
    title: "Register your interest",
    desc:  "Fill in our short online form — tell us who you are, your availability, and the areas you'd like to contribute to.",
  },
  {
    num:  "02",
    title: "Orientation & vetting",
    desc:  "All volunteers undergo a mandatory background check and a clinical safety orientation before placement. This protects both you and our patients.",
  },
  {
    num:  "03",
    title: "Placement & support",
    desc:  "We match you to a role that fits your skills and availability. A designated coordinator supports you throughout your placement.",
  },
]
---

<Layout title="Volunteer — St. Paul's Mission Hospital">

  <!-- HERO -->
 <header class="relative min-h-[65vh] flex items-end overflow-hidden">

  <div class="absolute inset-0 z-0">
    <img
      src="/img/57.jpg"
      alt="Volunteer at St. Paul's Mission Hospital"
      class="absolute inset-0 w-full h-full object-cover object-center brightness-[0.55]"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-secondary-dark via-secondary/15 to-transparent"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-16 pb-16 pt-32 w-full">
    <div class="grid lg:grid-cols-12 gap-8 items-end">

      <div class="lg:col-span-7">
        <p class="text-primary-light text-xs tracking-[0.22em] uppercase font-semibold mb-5 flex items-center gap-3">
          <span class="w-8 h-px bg-primary-light inline-block"></span>
          Volunteer With Us
        </p>
        <h1 class="font-display text-white text-5xl sm:text-6xl lg:text-7xl font-normal leading-[1.0]">
          Give your time.<br/>
          <span class="font-semibold italic text-primary-light">Change a life.</span>
        </h1>
      </div>

      <div class="lg:col-span-5 pb-1">
        <div class="border-l-2 border-white/20 pl-6">
          <p class="text-white/70 text-base lg:text-lg font-display italic font-normal leading-relaxed">
            "Whoever serves me must follow me; and where I am, my servant also will be."
          </p>
          <p class="text-white/35 text-[0.62rem] tracking-[0.18em] uppercase font-semibold mt-3">
            John 12:26 · The spirit of service at St. Paul's since 1983
          </p>
        </div>
      </div>

    </div>
  </div>
</header>


  <!-- INTRO BAND -->
  <div class="bg-secondary border-b border-white/10">
    <div class="max-w-7xl mx-auto px-4 lg:px-16 py-7
                flex flex-col sm:flex-row sm:items-center justify-between gap-4">
      <p class="text-white/60 text-sm leading-relaxed max-w-2xl">
        Whether you are a healthcare professional, a student, a retiree, or simply someone with time and a willing heart — there is a role for you at St. Paul's. Volunteering here is not just about filling gaps. It is about extending the mission of compassionate, dignified care to every person who walks through our doors.
      </p>
      <div class="flex items-center gap-2 shrink-0">
        <span class="relative flex size-2">
          <span class="absolute inline-flex size-full rounded-full bg-[#25D366]/70"></span>
          <span class="relative inline-flex size-2 rounded-full bg-[#25D366]"></span>
        </span>
        <span class="text-white/50 text-xs tracking-[0.16em] uppercase font-semibold">
          Open to individuals & groups
        </span>
      </div>
    </div>
  </div>


  <!--  SERVICE SECTORS -->
  <section class="bg-surface py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 lg:px-16">

      <!-- Header -->
      <div class="mx-auto px-4 text-center mb-14">
        <div>
          <p class="text-primary text-xs tracking-[0.22em] uppercase font-semibold mb-4">
            Where you can serve
          </p>
          <h2 class="font-display text-secondary text-3xl sm:text-4xl font-normal leading-snug">
            Areas of contribution.
          </h2>
        </div>
      </div>

      <!-- Sectors grid -->
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {serviceSectors.map((s) => (
          <div class="group bg-white border border-border/60
                      hover:border-primary/30 hover:shadow-lg hover:shadow-primary/5
                      transition-all duration-300 hover:-translate-y-0.5
                      flex flex-col p-7">

            <!-- Icon + number -->
            <div class="flex items-start justify-between mb-6">
              <div class="size-11 bg-surface-2 flex items-center justify-center
                          group-hover:bg-primary transition-all duration-300">
                <svg class="size-5 text-primary group-hover:text-white transition-colors duration-300"
                     fill={s.iconFill ? "currentColor" : "none"}
                     stroke={s.iconFill ? "none" : "currentColor"}
                     stroke-width="1.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d={s.icon}/>
                </svg>
              </div>
              
            </div>

            <!-- Sector title -->
            <h3 class="font-display text-xl font-semibold text-secondary
                       group-hover:text-primary transition-colors duration-200 mb-3 leading-snug">
              {s.sector}
            </h3>

            <!-- Intent -->
            <p class="text-muted text-sm leading-relaxed flex-1 mb-6">
              {s.intent}
            </p>

            <!-- Role tags -->
            <div class="flex flex-wrap gap-2 pt-5 border-t border-border/50">
              {s.roles.map(role => (
                <span class="text-[0.6rem] font-bold tracking-[0.12em] uppercase
                             bg-surface border border-border/60 text-muted px-2.5 py-1
                             group-hover:border-primary/20 group-hover:text-primary
                             transition-colors duration-200">
                  {role}
                </span>
              ))}
            </div>

          </div>
        ))}

        <!-- Register CTA card — fills the 6th grid slot -->
        <div class="bg-primary border border-primary flex flex-col justify-between p-7">
          <div>
            <p class="text-white/60 text-xs tracking-[0.18em] uppercase font-semibold mb-4">
              Ready to serve?
            </p>
            <h3 class="font-display text-white text-2xl font-semibold leading-snug mb-3">
              Register your interest today.
            </h3>
            <p class="text-white/60 text-sm leading-relaxed">
              Fill in our short form and we'll be in touch to discuss placement options.
            </p>
          </div>
          <a
            href={REGISTER_FORM}
            target="_blank"
            rel="noopener noreferrer"
            class="group/btn mt-8 inline-flex items-center gap-2.5 bg-white
                   text-primary font-bold text-xs tracking-[0.12em] uppercase
                   px-6 py-3.5 hover:bg-primary-light hover:text-white
                   transition-all duration-200 self-start"
          >
            Register interest
            <svg class="size-3.5 group-hover/btn:translate-x-1 transition-transform duration-200"
                 fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
        </div>

      </div>
    </div>
  </section>


  <!-- HOW IT WORKS -->
<!-- <section class="bg-white border-t border-border/60 py-20">
    <div class="max-w-7xl mx-auto px-6 lg:px-16">

      <div class="grid lg:grid-cols-12 gap-12 items-start">

        <div class="lg:col-span-4">
          <p class="text-primary text-xs tracking-[0.22em] uppercase font-semibold mb-4 flex items-center gap-3">
            <span class="w-8 h-px bg-primary inline-block"></span>
            The process
          </p>
          <h2 class="font-display text-secondary text-3xl font-normal leading-snug mb-5">
            Simple to join.<br/>
            <span class="font-semibold italic text-primary">Safe for everyone.</span>
          </h2>
          <p class="text-muted text-sm leading-relaxed">
            All volunteers are vetted and supported. We take the safety of our patients — and our volunteers — seriously.
          </p>
        </div>

        <div class="lg:col-span-8 flex flex-col gap-6">
          {steps.map((step, i) => (
            <div class="flex gap-6 items-start">

              <div class="size-12 bg-surface border border-border/60 flex items-center
                          justify-center shrink-0">
                <span class="font-display text-primary font-bold text-sm">{step.num}</span>
              </div>

              <div class="flex-1 pt-2">
                <h3 class="text-secondary font-semibold text-base mb-1.5">{step.title}</h3>
                <p class="text-muted text-sm leading-relaxed">{step.desc}</p>
              </div>

              {i < steps.length - 1 && (
                <div class="absolute mt-12 ml-6 w-px h-6 bg-border/60 hidden lg:block"></div>
              )}

            </div>
          ))}
        </div>

      </div>
    </div>
  </section> -->



  <!-- HOW IT WORKS — reworked with image as proper background layer -->
<section class="relative py-24 lg:py-32 overflow-hidden">

  <!-- Background image — isolated so filter/overlay don't bleed onto content -->
  <div class="absolute inset-0 z-0">
    <img
      src="/img/40.jpg"
      alt=""
      aria-hidden="true"
      class="absolute inset-0 w-full h-full object-cover object-center"
      loading="lazy"
    />
    <!-- Warm sepia-toned overlay — replaces the section-level filter -->
    <div class="absolute inset-0 bg-secondary/80 mix-blend-multiply"></div>
    <div class="absolute inset-0 bg-gradient-to-br from-secondary-dark/60 via-transparent to-secondary/40"></div>
  </div>

  <!-- Content — sits cleanly above the image -->
  <div class="relative z-10 max-w-7xl mx-auto px-4 lg:px-16">
    <div class="grid lg:grid-cols-12 gap-12 items-start">

      <!-- LEFT: heading -->
      <div class="lg:col-span-4">
        <h2 class="font-display text-white text-3xl sm:text-4xl font-normal leading-snug mb-5">
          <span class="font-semibold text-primary-light">How to join.</span>
        </h2>
        <p class="text-white text-sm leading-relaxed">
          All volunteers are vetted and supported. We take the safety of our patients — and our volunteers — seriously.
        </p>
      </div>

      <!-- RIGHT: steps -->
      <div class="lg:col-span-8 flex flex-col gap-5">
        {steps.map((step, i) => (
          <div class="flex gap-5 items-start group">

            <!-- Step number box -->
            <div class="size-12 bg-white/10 border border-white/20 flex items-center
                        justify-center shrink-0
                        group-hover:bg-primary group-hover:border-primary
                        transition-all duration-300">
              <span class="font-display text-white font-bold text-sm">{step.num}</span>
            </div>

            <!-- Content -->
            <div class="flex-1 bg-white/8 border border-white/10 px-6 py-5
                        group-hover:bg-white/12 group-hover:border-white/20
                        transition-all duration-300">
              <h3 class="text-white font-semibold text-base mb-1.5">{step.title}</h3>
              <p class="text-white text-sm leading-relaxed">{step.desc}</p>
            </div>

          </div>
        ))}
      </div>

    </div>
  </div>

</section>


  <!-- FOOTER STRIP -->
  <section class="bg-surface border-t border-border/60 py-12">
    <div class="max-w-7xl mx-auto px-4 lg:px-16
                flex flex-col sm:flex-row items-start sm:items-center
                justify-between gap-6">

      <!-- Vetting note — from original, preserved -->
      <div class="flex items-start gap-5">
        <div class="size-10 bg-white border border-border/60 flex items-center justify-center shrink-0">
          <svg class="size-5 text-primary" fill="none" stroke="currentColor"
               stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round"
              d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
          </svg>
        </div>
        <div>
          <p class="text-secondary font-semibold text-sm mb-0.5">100% vetted placements</p>
          <p class="text-muted text-xs leading-relaxed max-w-sm">
            All volunteers undergo mandatory background checks and clinical safety orientation prior to placement.
          </p>
        </div>
      </div>

      <!-- PDF download — from original, preserved -->
      <a
        href={GUIDELINES_PDF}
        target="_blank"
        rel="noopener noreferrer"
        class="group inline-flex items-center gap-2.5 btn-secondary
               text-xs font-bold tracking-[0.12em] uppercase px-5 py-3
               transition-all duration-200"
      >
        <svg class="size-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round"
            d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
        </svg>
        Download Service Guidelines
        <svg class="size-3.5 group-hover:translate-x-1 transition-transform duration-200"
             fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>

    </div>
  </section>

</Layout>