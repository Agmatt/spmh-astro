---
import Layout from '../../Layout/Layout.astro';
import CareersPortal from '../../react-islands/CareersPortal';
---

<Layout title='Apply Now | SPMH Careers'>
  <!-- Hero Section -->
  <section class='hero-section bg-gradient-to-b from-primary/5 to-surface'>
    <div class='section-spacing'>
      <div class='max-w-2xl'>
        <h1 class='text-5xl md:text-6xl font-bold text-primary mb-4'>
          Join our team
        </h1>
        <p class='text-xl text-muted'>
          Find the right opportunity and submit your application below.
        </p>
      </div>
    </div>
  </section>

  <!-- Portal -->
  <section class='section-spacing'>
    <CareersPortal client:load />
  </section>

  <!-- Contact info -->
  <section class='section-spacing bg-surface-2'>
    <div class='text-center max-w-2xl mx-auto'>
      <h2 class='text-2xl font-bold text-primary mb-4'>Questions?</h2>
      <p class='text-muted mb-4'>
        If you have any questions about our open positions, feel free to contact
        us.
      </p>
      <p class='text-lg font-medium text-primary'>
        <a href='mailto:careers@spmh.co.ke' class='hover:underline'
          >careers@spmh.co.ke</a
        >
      </p>
    </div>
  </section>
</Layout>



