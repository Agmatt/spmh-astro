---
import '../styles/global.css'
---

<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>SPMH Outreach — Transforming Communities Together</title>
  </head>
  <body class='font-sans antialiased text-gray-900 overflow-x-hidden'>
    <!-- ══════════════════════════════════════════
       HERO
  ══════════════════════════════════════════ -->
    <section
      class='relative min-h-[500px] flex items-center justify-center text-center px-4 md:px-6 py-28'
      style="background: linear-gradient(rgba(10,25,55,0.60), rgba(10,25,55,0.65)), url('https://images.unsplash.com/photo-1582213782179-e0d53f98f2ca?w=1400&q=80') center/cover no-repeat;">
      <div class='max-w-2xl mx-auto'>
        <h1
          class='text-4xl md:text-5xl font-extrabold text-white leading-tight mb-4'>
          Transforming Communities Together
        </h1>
        <p class='text-lg text-white/85 mb-8'>
          Building relationships through outreach and care
        </p>
        <div class='flex flex-wrap gap-4 justify-center'>
          <a
            href='#volunteer'
            class='inline-flex items-center gap-2 bg-orange-500 hover:bg-orange-600 text-white font-bold px-7 py-3 rounded-lg transition-colors duration-200'>
            <!-- Heroicon: hand-raised -->
            <svg
              xmlns='http://www.w3.org/2000/svg'
              viewBox='0 0 24 24'
              fill='currentColor'
              class='w-5 h-5'>
              <path
                d='M10.5 1.5a.75.75 0 0 1 .75.75V4.5a.75.75 0 0 1-1.5 0V2.25a.75.75 0 0 1 .75-.75ZM5.628 5.165a.75.75 0 0 1 0 1.061l-1.5 1.5a.75.75 0 1 1-1.06-1.061l1.5-1.5a.75.75 0 0 1 1.06 0ZM2.25 10.5a.75.75 0 0 1 .75-.75h1.5a.75.75 0 0 1 0 1.5H3a.75.75 0 0 1-.75-.75Zm12.47-5.335a.75.75 0 0 1 1.06 0l1.5 1.5a.75.75 0 1 1-1.06 1.06l-1.5-1.5a.75.75 0 0 1 0-1.06ZM21 10.5a.75.75 0 0 1-.75.75h-1.5a.75.75 0 0 1 0-1.5h1.5a.75.75 0 0 1 .75.75ZM8.25 13.5a3 3 0 1 1 5.25 1.96v5.79a.75.75 0 0 1-1.5 0V15.46a3 3 0 0 1-3.75-1.96ZM6.3 14.573a.75.75 0 0 1 .427.973A6.04 6.04 0 0 0 6 17.25a6 6 0 0 0 12 0 6.04 6.04 0 0 0-.727-2.704.75.75 0 1 1 1.354-.646A7.54 7.54 0 0 1 19.5 17.25a7.5 7.5 0 1 1-14.373-2.95.75.75 0 0 1 .973-.427Z'
              ></path>
            </svg>
            Volunteer Now
          </a>
          <a
            href='#about'
            class='inline-flex items-center gap-2 border-2 border-white text-white hover:bg-white hover:text-blue-900 font-bold px-7 py-3 rounded-lg transition-colors duration-200'>
            <!-- Heroicon: information-circle -->
            <svg
              xmlns='http://www.w3.org/2000/svg'
              viewBox='0 0 24 24'
              fill='currentColor'
              class='w-5 h-5'>
              <path
                fill-rule='evenodd'
                d='M2.25 12c0-5.385 4.365-9.75 9.75-9.75s9.75 4.365 9.75 9.75-4.365 9.75-9.75 9.75S2.25 17.385 2.25 12Zm8.706-1.442c1.146-.573 2.437.463 2.126 1.706l-.709 2.836.042-.02a.75.75 0 0 1 .67 1.34l-.04.022c-1.147.573-2.438-.463-2.127-1.706l.71-2.836-.042.02a.75.75 0 1 1-.671-1.34l.041-.022ZM12 9a.75.75 0 1 0 0-1.5A.75.75 0 0 0 12 9Z'
                clip-rule='evenodd'></path>
            </svg>
            Learn More
          </a>
        </div>
      </div>

      <!-- wave bottom -->
      <div
        class='absolute bottom-0 left-0 right-0 overflow-hidden leading-none'>
        <svg
          viewBox='0 0 1440 60'
          xmlns='http://www.w3.org/2000/svg'
          preserveAspectRatio='none'
          class='w-full h-12 block'>
          <path d='M0,30 C480,60 960,0 1440,30 L1440,60 L0,60 Z' fill='#fdf6ee'
          ></path>
        </svg>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
       ABOUT
  ══════════════════════════════════════════ -->
    <section id='about' class='bg-[#fdf6ee] px-4 md:px-6 pt-16 pb-0'>
      <div class='max-w-5xl mx-auto grid md:grid-cols-2 gap-12 items-center'>
        <div>
          <h2 class='text-2xl font-bold text-gray-900 mb-3'>
            About SPMH Outreach
          </h2>
          <div class='w-12 h-1 bg-orange-500 rounded mb-5'></div>
          <p class='text-gray-500 leading-relaxed text-[0.97rem]'>
            Our mission is to provide compassionate care and support to
            underserved communities. We aim to foster trust, health, and hope in
            every life we touch — bringing essential services directly to those
            who need them most across the Diocese of Homa Bay.
          </p>
        </div>
        <div>
          <img
            src='https://images.unsplash.com/photo-1576091160550-2173dba999ef?w=700&q=80'
            alt='SPMH outreach team with community members'
            class='w-full h-64 object-cover rounded-2xl shadow-lg'
          />
        </div>
      </div>

      <!-- wave into programs -->
      <div class='overflow-hidden leading-none mt-12'>
        <svg
          viewBox='0 0 1440 60'
          xmlns='http://www.w3.org/2000/svg'
          preserveAspectRatio='none'
          class='w-full h-12 block'>
          <path d='M0,0 C480,60 960,0 1440,40 L1440,60 L0,60 Z' fill='#ffffff'
          ></path>
        </svg>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
       PROGRAMS
  ══════════════════════════════════════════ -->
    <section id='programs' class='bg-white px-4 md:px-6 py-16'>
      <h2 class='text-center text-2xl font-bold text-blue-900 mb-2'>
        Our Programs
      </h2>
      <div class='flex justify-center mb-10'>
        <div class='w-14 h-1 bg-orange-500 rounded'></div>
      </div>

      <div class='max-w-4xl mx-auto grid sm:grid-cols-3 gap-6'>
        <!-- Health Clinics -->
        <div
          class='bg-[#fdf6ee] rounded-2xl p-8 text-center shadow-md hover:-translate-y-1 hover:shadow-lg transition-all duration-200'>
          <div
            class='inline-flex items-center justify-center w-14 h-14 rounded-full bg-orange-100 mb-5'>
            <!-- Heroicon: heart (solid) -->
            <svg
              xmlns='http://www.w3.org/2000/svg'
              viewBox='0 0 24 24'
              fill='currentColor'
              class='w-7 h-7 text-orange-500'>
              <path
                d='m11.645 20.91-.007-.003-.022-.012a15.247 15.247 0 0 1-.383-.218 25.18 25.18 0 0 1-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0 1 12 5.052 5.5 5.5 0 0 1 16.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 0 1-4.244 3.17 15.247 15.247 0 0 1-.383.219l-.022.012-.007.004-.003.001a.752.752 0 0 1-.704 0l-.003-.001Z'
              ></path>
            </svg>
          </div>
          <h3 class='font-bold text-gray-900 mb-2'>Health Clinics</h3>
          <p class='text-sm text-gray-500 leading-relaxed'>
            Medical services for those in need, delivered with dignity and
            compassion.
          </p>
        </div>

        <!-- Food Assistance -->
        <div
          class='bg-[#fdf6ee] rounded-2xl p-8 text-center shadow-md hover:-translate-y-1 hover:shadow-lg transition-all duration-200'>
          <div
            class='inline-flex items-center justify-center w-14 h-14 rounded-full bg-orange-100 mb-5'>
            <!-- Heroicon: shopping-bag (solid) -->
            <svg
              xmlns='http://www.w3.org/2000/svg'
              viewBox='0 0 24 24'
              fill='currentColor'
              class='w-7 h-7 text-orange-500'>
              <path
                fill-rule='evenodd'
                d='M7.5 6v.75H5.513c-.96 0-1.764.724-1.865 1.679l-1.263 12A1.875 1.875 0 0 0 4.25 22.5h15.5a1.875 1.875 0 0 0 1.865-2.071l-1.263-12a1.875 1.875 0 0 0-1.865-1.679H16.5V6a4.5 4.5 0 1 0-9 0ZM12 3a3 3 0 0 0-3 3v.75h6V6a3 3 0 0 0-3-3Zm-3 8.25a3 3 0 1 0 6 0v-.75a.75.75 0 0 1 1.5 0v.75a4.5 4.5 0 1 1-9 0v-.75a.75.75 0 0 1 1.5 0v.75Z'
                clip-rule='evenodd'></path>
            </svg>
          </div>
          <h3 class='font-bold text-gray-900 mb-2'>Food Assistance</h3>
          <p class='text-sm text-gray-500 leading-relaxed'>
            Providing nutritious meals to hungry families and individuals in our
            area.
          </p>
        </div>

        <!-- Outreach Support -->
        <div
          class='bg-[#fdf6ee] rounded-2xl p-8 text-center shadow-md hover:-translate-y-1 hover:shadow-lg transition-all duration-200'>
          <div
            class='inline-flex items-center justify-center w-14 h-14 rounded-full bg-orange-100 mb-5'>
            <!-- Heroicon: user-group (solid) -->
            <svg
              xmlns='http://www.w3.org/2000/svg'
              viewBox='0 0 24 24'
              fill='currentColor'
              class='w-7 h-7 text-orange-500'>
              <path
                fill-rule='evenodd'
                d='M8.25 6.75a3.75 3.75 0 1 1 7.5 0 3.75 3.75 0 0 1-7.5 0ZM15.75 9.75a3 3 0 1 1 6 0 3 3 0 0 1-6 0ZM2.25 9.75a3 3 0 1 1 6 0 3 3 0 0 1-6 0ZM6.31 15.117A6.745 6.745 0 0 1 12 12a6.745 6.745 0 0 1 6.709 7.498.75.75 0 0 1-.372.568A12.696 12.696 0 0 1 12 21.75c-2.305 0-4.47-.612-6.337-1.684a.75.75 0 0 1-.372-.568 6.787 6.787 0 0 1 1.019-4.38Z'
                clip-rule='evenodd'></path>
              <path
                d='M5.082 14.254a8.287 8.287 0 0 0-1.308 5.135 9.687 9.687 0 0 1-1.764-.44l-.115-.04a.563.563 0 0 1-.373-.487l-.01-.121a3.75 3.75 0 0 1 3.57-4.047ZM20.226 19.389a8.287 8.287 0 0 0-1.308-5.135 3.75 3.75 0 0 1 3.57 4.047l-.01.121a.563.563 0 0 1-.373.486l-.115.04c-.567.2-1.156.349-1.764.441Z'
              ></path>
            </svg>
          </div>
          <h3 class='font-bold text-gray-900 mb-2'>Outreach Support</h3>
          <p class='text-sm text-gray-500 leading-relaxed'>
            Connecting communities with social, health, and welfare resources.
          </p>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
       IMPACT
  ══════════════════════════════════════════ -->
    <section id='impact' class='relative bg-blue-900 px-4 md:px-6 py-20 text-white'>
      <!-- wave top -->
      <div
        class='absolute top-0 left-0 right-0 overflow-hidden leading-none rotate-180'>
        <svg
          viewBox='0 0 1440 50'
          xmlns='http://www.w3.org/2000/svg'
          preserveAspectRatio='none'
          class='w-full h-10 block'>
          <path d='M0,25 C480,50 960,0 1440,25 L1440,50 L0,50 Z' fill='#1e3a8a'
          ></path>
        </svg>
      </div>

      <h2 class='text-center text-2xl font-bold text-white mb-2'>Our Impact</h2>
      <div class='flex justify-center mb-12'>
        <div class='w-14 h-1 bg-orange-400 rounded'></div>
      </div>

      <div
        class='max-w-4xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-8 text-center'>
        <div>
          <div
            class='text-4xl md:text-5xl font-extrabold text-white leading-none'>
            3,000+
          </div>
          <div class='text-sm text-blue-200 mt-2'>Lives Reached</div>
        </div>
        <div>
          <div
            class='text-4xl md:text-5xl font-extrabold text-white leading-none'>
            1,200+
          </div>
          <div class='text-sm text-blue-200 mt-2'>Meals Served</div>
        </div>
        <div>
          <div
            class='text-4xl md:text-5xl font-extrabold text-white leading-none'>
            850+
          </div>
          <div class='text-sm text-blue-200 mt-2'>Volunteers Engaged</div>
        </div>
        <div>
          <div
            class='text-4xl md:text-5xl font-extrabold text-white leading-none'>
            100+
          </div>
          <div class='text-sm text-blue-200 mt-2'>Events Hosted</div>
        </div>
      </div>

      <!-- wave bottom -->
      <div
        class='absolute bottom-0 left-0 right-0 overflow-hidden leading-none'>
        <svg
          viewBox='0 0 1440 50'
          xmlns='http://www.w3.org/2000/svg'
          preserveAspectRatio='none'
          class='w-full h-10 block'>
          <path d='M0,25 C480,50 960,0 1440,25 L1440,50 L0,50 Z' fill='#fdf6ee'
          ></path>
        </svg>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
       GET INVOLVED
  ══════════════════════════════════════════ -->
    <section id='volunteer' class='bg-[#fdf6ee] px-4 md:px-6 py-20'>
      <h2 class='text-center text-2xl font-bold text-orange-500 mb-2'>
        Get Involved
      </h2>
      <div class='flex justify-center mb-10'>
        <div class='w-14 h-1 bg-blue-900 rounded'></div>
      </div>

      <div class='max-w-4xl mx-auto grid sm:grid-cols-2 lg:grid-cols-4 gap-5'>
        <!-- Volunteer -->
        <div
          class='bg-white rounded-2xl p-7 text-center shadow-md flex flex-col items-center'>
          <div
            class='inline-flex items-center justify-center w-12 h-12 rounded-full bg-red-100 mb-4'>
            <!-- Heroicon: heart (solid) -->
            <svg
              xmlns='http://www.w3.org/2000/svg'
              viewBox='0 0 24 24'
              fill='currentColor'
              class='w-6 h-6 text-red-500'>
              <path
                d='m11.645 20.91-.007-.003-.022-.012a15.247 15.247 0 0 1-.383-.218 25.18 25.18 0 0 1-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0 1 12 5.052 5.5 5.5 0 0 1 16.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 0 1-4.244 3.17 15.247 15.247 0 0 1-.383.219l-.022.012-.007.004-.003.001a.752.752 0 0 1-.704 0l-.003-.001Z'
              ></path>
            </svg>
          </div>
          <h3 class='font-bold text-orange-500 mb-2'>Volunteer</h3>
          <p class='text-xs text-gray-400 leading-relaxed mb-5'>
            Join our team and make a difference in someone's life today.
          </p>
          <a
            href='/volunteer'
            class='mt-auto inline-block border-2 border-orange-500 text-orange-500 hover:bg-orange-500 hover:text-white font-bold text-sm px-5 py-2 rounded-lg transition-colors duration-200'
            >Sign Up</a
          >
        </div>

        <!-- Donate -->
        <div
          class='bg-white rounded-2xl p-7 text-center shadow-md flex flex-col items-center'>
          <div
            class='inline-flex items-center justify-center w-12 h-12 rounded-full bg-blue-100 mb-4'>
            <!-- Heroicon: banknotes (solid) -->
            <svg
              xmlns='http://www.w3.org/2000/svg'
              viewBox='0 0 24 24'
              fill='currentColor'
              class='w-6 h-6 text-blue-700'>
              <path d='M12 7.5a2.25 2.25 0 1 0 0 4.5 2.25 2.25 0 0 0 0-4.5Z'
              ></path>
              <path
                fill-rule='evenodd'
                d='M1.5 4.875C1.5 3.839 2.34 3 3.375 3h17.25c1.035 0 1.875.84 1.875 1.875v9.75c0 1.036-.84 1.875-1.875 1.875H3.375A1.875 1.875 0 0 1 1.5 14.625v-9.75ZM8.25 9.75a3.75 3.75 0 1 1 7.5 0 3.75 3.75 0 0 1-7.5 0ZM18.75 9a.75.75 0 0 0-.75.75v.008c0 .414.336.75.75.75h.008a.75.75 0 0 0 .75-.75V9.75a.75.75 0 0 0-.75-.75h-.008ZM4.5 9.75A.75.75 0 0 1 5.25 9h.008a.75.75 0 0 1 .75.75v.008a.75.75 0 0 1-.75.75H5.25a.75.75 0 0 1-.75-.75V9.75Z'
                clip-rule='evenodd'></path>
              <path
                d='M2.25 18a.75.75 0 0 0 0 1.5c5.4 0 10.63.722 15.6 2.075 1.19.324 2.4-.558 2.4-1.82V18.75a.75.75 0 0 0-.75-.75H2.25Z'
              ></path>
            </svg>
          </div>
          <h3 class='font-bold text-blue-800 mb-2'>Donate</h3>
          <p class='text-xs text-gray-400 leading-relaxed mb-5'>
            Support our mission with a donation of any size.
          </p>
          <a
            href='/donate'
            class='mt-auto inline-block bg-blue-900 hover:bg-blue-800 text-white font-bold text-sm px-5 py-2 rounded-lg transition-colors duration-200'
            >Donate Now</a
          >
        </div>

        <!-- Become a Partner -->
        <div
          class='bg-white rounded-2xl p-7 text-center shadow-md flex flex-col items-center'>
          <div
            class='inline-flex items-center justify-center w-12 h-12 rounded-full bg-orange-100 mb-4'>
            <!-- Heroicon: building-office-2 (solid) -->
            <svg
              xmlns='http://www.w3.org/2000/svg'
              viewBox='0 0 24 24'
              fill='currentColor'
              class='w-6 h-6 text-orange-500'>
              <path
                fill-rule='evenodd'
                d='M3 2.25a.75.75 0 0 0 0 1.5v16.5h-.75a.75.75 0 0 0 0 1.5H15v-18a.75.75 0 0 0 0-1.5H3ZM6.75 19.5v-2.25a.75.75 0 0 1 .75-.75h3a.75.75 0 0 1 .75.75v2.25a.75.75 0 0 1-.75.75h-3a.75.75 0 0 1-.75-.75ZM6 6.75A.75.75 0 0 1 6.75 6h.75a.75.75 0 0 1 0 1.5h-.75A.75.75 0 0 1 6 6.75ZM6.75 9a.75.75 0 0 0 0 1.5h.75a.75.75 0 0 0 0-1.5h-.75ZM6 12.75a.75.75 0 0 1 .75-.75h.75a.75.75 0 0 1 0 1.5h-.75a.75.75 0 0 1-.75-.75ZM10.5 6a.75.75 0 0 0 0 1.5h.75a.75.75 0 0 0 0-1.5h-.75Zm-.75 3.75A.75.75 0 0 1 10.5 9h.75a.75.75 0 0 1 0 1.5h-.75a.75.75 0 0 1-.75-.75ZM10.5 12a.75.75 0 0 0 0 1.5h.75a.75.75 0 0 0 0-1.5h-.75ZM16.5 6.75v15h3.75a.75.75 0 0 0 0-1.5H19.5v-13.5h.75a.75.75 0 0 0 0-1.5H16.5Z'
                clip-rule='evenodd'></path>
            </svg>
          </div>
          <h3 class='font-bold text-orange-500 mb-2'>Become a Partner</h3>
          <p class='text-xs text-gray-400 leading-relaxed mb-5'>
            Partner with us for greater community impact.
          </p>
          <a
            href='/partner'
            class='mt-auto inline-block bg-orange-500 hover:bg-orange-600 text-white font-bold text-sm px-5 py-2 rounded-lg transition-colors duration-200'
            >Join Now</a
          >
        </div>

        <!-- Join Us (highlighted) -->
        <div
          class='bg-orange-500 rounded-2xl p-7 text-center shadow-md flex flex-col items-center'>
          <div
            class='inline-flex items-center justify-center w-12 h-12 rounded-full bg-white/20 mb-4'>
            <!-- Heroicon: user-plus (solid) -->
            <svg
              xmlns='http://www.w3.org/2000/svg'
              viewBox='0 0 24 24'
              fill='currentColor'
              class='w-6 h-6 text-white'>
              <path
                d='M6.25 6.375a4.125 4.125 0 1 1 8.25 0 4.125 4.125 0 0 1-8.25 0ZM3.25 19.125a7.125 7.125 0 0 1 14.25 0v.003l-.001.119a.75.75 0 0 1-.363.63 13.067 13.067 0 0 1-6.761 1.873c-2.472 0-4.786-.684-6.76-1.873a.75.75 0 0 1-.364-.63l-.001-.122ZM19.75 7.5a.75.75 0 0 0-1.5 0v2.25H16a.75.75 0 0 0 0 1.5h2.25v2.25a.75.75 0 0 0 1.5 0v-2.25H22a.75.75 0 0 0 0-1.5h-2.25V7.5Z'
              ></path>
            </svg>
          </div>
          <h3 class='font-bold text-white mb-2'>Join Us</h3>
          <p class='text-xs text-white/80 leading-relaxed'>
            Be part of a movement that puts people at the heart of everything we
            do.
          </p>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
       TESTIMONIAL + CTA
  ══════════════════════════════════════════ -->
    <section
      class='relative px-6 py-20'
      style="background: linear-gradient(rgba(20,35,70,0.72), rgba(20,35,70,0.78)), url('https://images.unsplash.com/photo-1529156069898-49953e39b3ac?w=1200&q=80') center/cover no-repeat;">
      <div class='max-w-4xl mx-auto'>
        <h2 class='text-center text-2xl font-bold text-white mb-2'>
          What Our Volunteers Say
        </h2>
        <div class='flex justify-center mb-10'>
          <div class='w-14 h-1 bg-orange-400 rounded'></div>
        </div>

        <div class='flex flex-col md:flex-row items-center gap-8 mb-10'>
          <img
            src='https://images.unsplash.com/photo-1607746882042-944635dfe10e?w=300&q=80'
            alt='Volunteer'
            class='w-36 h-44 object-cover rounded-xl shadow-lg flex-shrink-0'
          />
          <div>
            <!-- Heroicon: chat-bubble-left-ellipsis (outline) as quote mark -->
            <svg
              xmlns='http://www.w3.org/2000/svg'
              viewBox='0 0 24 24'
              fill='currentColor'
              class='w-8 h-8 text-orange-400 mb-3'>
              <path
                fill-rule='evenodd'
