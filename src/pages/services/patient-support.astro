---
import Layout from '../../Layout/Layout.astro';

/**
 * Patient & Visitor Satisfaction Survey
 * Matches SPMH_Patient_Feedback_Form.docx exactly:
 *   A. Respondent Details (optional)
 *   B. Service Quality Rating — 18 items, Excellent/Good/Fair/Poor/N-A
 *   C. Your Comments — 3 open fields
 *   D. Follow-Up (optional)
 *
 * ── Update this value ─────────────────────────────────────────────
 */
const FORMSPREE = "https://formspree.io/f/movnbakk"   // ← replace with real endpoint

const serviceCategories = [
  {
    title: "Admission & Reception",
    items: [
      { name: "q1",  label: "Ease of registration and admission process" },
      { name: "q2",  label: "Courtesy and helpfulness of reception staff" },
      { name: "q3",  label: "Waiting time before being attended to" },
      { name: "q4",  label: "Clarity of information provided at reception" },
    ],
  },
  {
    title: "Medical & Nursing Care",
    items: [
      { name: "q5",  label: "Professionalism and competence of doctors" },
      { name: "q6",  label: "Professionalism and kindness of nursing staff" },
      { name: "q7",  label: "Explanation of your diagnosis and treatment" },
      { name: "q8",  label: "Attention given to your pain and discomfort" },
      { name: "q9",  label: "Respect for your privacy and dignity" },
    ],
  },
  {
    title: "Pharmacy & Laboratory",
    items: [
      { name: "q10", label: "Availability and dispensing of prescribed medicines" },
      { name: "q11", label: "Speed and accuracy of laboratory / diagnostic services" },
      { name: "q12", label: "Explanation of medication instructions by pharmacy staff" },
    ],
  },
  {
    title: "Facilities & Environment",
    items: [
      { name: "q13", label: "Cleanliness of wards, corridors, and toilets" },
      { name: "q14", label: "Comfort and adequacy of ward facilities and bedding" },
      { name: "q15", label: "Quality and suitability of meals provided (in-patients only)" },
      { name: "q16", label: "Safety and security within the hospital premises" },
    ],
  },
  {
    title: "Overall Experience",
    items: [
      { name: "q17", label: "Overall satisfaction with the care and treatment received" },
      { name: "q18", label: "Likelihood of recommending SPMH to family or friends" },
    ],
  },
]

const ratings = ["Excellent", "Good", "Fair", "Poor", "N/A"]
---

<Layout title="Patient Satisfaction Survey — St. Paul's Mission Hospital">

  <!-- ════════════════════════════════════════
       HEADER
  ════════════════════════════════════════ -->
  <header class="bg-secondary border-b border-white/10">
    <div class="max-w-4xl mx-auto px-6 lg:px-16 py-10 pt-16">
      <p class="text-primary-light text-xs tracking-[0.22em] uppercase font-semibold mb-4 flex items-center gap-3">
        <span class="w-8 h-px bg-primary-light inline-block"></span>
        Patient Affairs
      </p>
      <h1 class="font-display text-white text-4xl sm:text-5xl font-normal leading-tight mb-4">
        Patient & Visitor<br/>
        <span class="font-semibold italic text-primary-light">Satisfaction Survey</span>
      </h1>
      <p class="text-white/50 text-sm italic">We Value Your Feedback · Tunashukuru Maoni Yako</p>
    </div>
  </header>


  <!-- ════════════════════════════════════════
       INTRO BAND
  ════════════════════════════════════════ -->
  <div class="bg-surface border-b border-border/60">
    <div class="max-w-4xl mx-auto px-6 lg:px-16 py-6">
      <p class="text-muted text-sm leading-relaxed">
        At St. Paul's Mission Hospital, we are committed to delivering compassionate, safe, and high-quality care to every person who walks through our doors. Your experience matters deeply to us. Please take a few minutes to complete this form.
        <span class="text-secondary font-semibold"> All responses are strictly confidential</span> and will be used only to improve our services. You do not need to include your name if you prefer not to.
      </p>
    </div>
  </div>


  <!-- ════════════════════════════════════════
       FORM
  ════════════════════════════════════════ -->
  <section class="bg-white py-12">
    <div class="max-w-4xl mx-auto px-4 lg:px-16">

      <form method="POST" action={FORMSPREE} class="space-y-10">

        <!-- ── A. RESPONDENT DETAILS ── -->
        <div class="border border-border/60 bg-surface">

          <div class="px-6 py-4 border-b border-border/60 flex items-center gap-3">
            <span class="size-7 bg-secondary text-white text-xs font-bold flex items-center justify-center shrink-0">A</span>
            <h2 class="text-secondary font-semibold text-base">Respondent Details
              <span class="text-muted font-normal text-xs ml-2">(Optional)</span>
            </h2>
          </div>

          <div class="p-6 space-y-6">

            <!-- Visitor type -->
            <div>
              <p class="text-secondary text-sm font-semibold mb-3">I am visiting as a:</p>
              <div class="flex flex-wrap gap-3">
                {["Patient (In-patient)", "Patient (Out-patient)", "Relative / Guardian", "Visitor", "Other"].map(v => (
                  <label class="flex items-center gap-2 cursor-pointer group">
                    <input type="radio" name="visitor_type" value={v}
                      class="size-4 text-primary border-border/60 focus:ring-primary"/>
                    <span class="text-sm text-muted group-hover:text-secondary transition-colors">{v}</span>
                  </label>
                ))}
              </div>
            </div>

            <!-- Name / Age / Sex -->
            <div class="grid sm:grid-cols-3 gap-4">
              <div class="sm:col-span-1">
                <label class="block text-xs font-semibold text-secondary uppercase tracking-wider mb-1.5">Name</label>
                <input type="text" name="name" placeholder="Your name (optional)"
                  class="w-full border border-border/60 bg-white px-3 py-2.5 text-sm text-secondary
                         focus:outline-none focus:border-primary transition-colors duration-200"/>
              </div>
              <div>
                <label class="block text-xs font-semibold text-secondary uppercase tracking-wider mb-1.5">Age</label>
                <input type="number" name="age" min="0" max="120" placeholder="—"
                  class="w-full border border-border/60 bg-white px-3 py-2.5 text-sm text-secondary
                         focus:outline-none focus:border-primary transition-colors duration-200"/>
              </div>
              <div>
                <label class="block text-xs font-semibold text-secondary uppercase tracking-wider mb-1.5">Sex</label>
                <div class="flex gap-4 pt-2.5">
                  {["Male", "Female"].map(s => (
                    <label class="flex items-center gap-2 cursor-pointer">
                      <input type="radio" name="sex" value={s}
                        class="size-4 text-primary border-border/60 focus:ring-primary"/>
                      <span class="text-sm text-muted">{s}</span>
                    </label>
                  ))}
                </div>
              </div>
            </div>

            <!-- Ward / Room / Date -->
            <div class="grid sm:grid-cols-3 gap-4">
              <div>
                <label class="block text-xs font-semibold text-secondary uppercase tracking-wider mb-1.5">Ward / Department</label>
                <input type="text" name="ward_dept" placeholder="e.g. OPD, Maternity"
                  class="w-full border border-border/60 bg-white px-3 py-2.5 text-sm text-secondary
                         focus:outline-none focus:border-primary transition-colors duration-200"/>
              </div>
              <div>
                <label class="block text-xs font-semibold text-secondary uppercase tracking-wider mb-1.5">Room / Bed No.</label>
                <input type="text" name="room_bed"
                  class="w-full border border-border/60 bg-white px-3 py-2.5 text-sm text-secondary
                         focus:outline-none focus:border-primary transition-colors duration-200"/>
              </div>
              <div>
                <label class="block text-xs font-semibold text-secondary uppercase tracking-wider mb-1.5">Date of Visit</label>
                <input type="date" name="visit_date"
                  class="w-full border border-border/60 bg-white px-3 py-2.5 text-sm text-secondary
                         focus:outline-none focus:border-primary transition-colors duration-200"/>
              </div>
            </div>

            <!-- Phone / Email -->
            <div class="grid sm:grid-cols-2 gap-4">
              <div>
                <label class="block text-xs font-semibold text-secondary uppercase tracking-wider mb-1.5">Phone</label>
                <input type="tel" name="phone" placeholder="+254 ..."
                  class="w-full border border-border/60 bg-white px-3 py-2.5 text-sm text-secondary
                         focus:outline-none focus:border-primary transition-colors duration-200"/>
              </div>
              <div>
                <label class="block text-xs font-semibold text-secondary uppercase tracking-wider mb-1.5">Email</label>
                <input type="email" name="email"
                  class="w-full border border-border/60 bg-white px-3 py-2.5 text-sm text-secondary
                         focus:outline-none focus:border-primary transition-colors duration-200"/>
              </div>
            </div>

          </div>
        </div>


        <!-- ── B. SERVICE QUALITY RATING ── -->
        <div class="border border-border/60">

          <div class="px-6 py-4 border-b border-border/60 flex items-center gap-3">
            <span class="size-7 bg-secondary text-white text-xs font-bold flex items-center justify-center shrink-0">B</span>
            <div>
              <h2 class="text-secondary font-semibold text-base">Service Quality Rating</h2>
              <p class="text-muted text-xs mt-0.5">Please rate each area by ticking the box that best reflects your experience.</p>
            </div>
          </div>

          <!-- Rating header — desktop -->
          <div class="hidden sm:grid grid-cols-12 gap-0 px-6 py-3 bg-surface border-b border-border/60">
            <div class="col-span-7 text-xs font-bold text-secondary uppercase tracking-wider">Service Area</div>
            {ratings.map(r => (
              <div class="col-span-1 text-center text-xs font-bold uppercase tracking-wider
                           text-muted">{r}</div>
            ))}
          </div>

          <div class="divide-y divide-border/40">
            {serviceCategories.map(cat => (
              <div>
                <!-- Category header -->
                <div class="px-6 py-2.5 bg-primary/5 border-b border-border/40">
                  <p class="text-primary text-xs font-bold tracking-[0.14em] uppercase">{cat.title}</p>
                </div>

                <!-- Items -->
                {cat.items.map((item, idx) => (
                  <div class="grid grid-cols-1 sm:grid-cols-12 gap-3 sm:gap-0
                               px-6 py-3.5 hover:bg-surface/60 transition-colors duration-150
                               border-b border-border/30 last:border-0">

                    <!-- Label -->
                    <div class="sm:col-span-7 flex items-start gap-2.5 pr-4">
                      <span class="text-muted/40 text-[0.65rem] font-bold shrink-0 mt-0.5 w-5">
                        {(cat.items.indexOf(item) + (serviceCategories.slice(0, serviceCategories.indexOf(cat)).reduce((a, c) => a + c.items.length, 0) + 1)).toString().padStart(2, '0')}.
                      </span>
                      <p class="text-secondary text-sm leading-snug">{item.label}</p>
                    </div>

                    <!-- Rating options -->
                    <div class="sm:col-span-5 grid grid-cols-5 gap-0">
                      {ratings.map(r => (
                        <label class="flex flex-col items-center justify-center gap-1.5
                                       py-2 cursor-pointer group hover:bg-primary/5
                                       transition-colors duration-150">
                          <!-- Mobile label -->
                          <span class="sm:hidden text-[0.58rem] text-muted font-semibold uppercase">{r}</span>
                          <input
                            type="radio"
                            name={item.name}
                            value={r}
                            class="size-4 text-primary border-border/60
                                   focus:ring-primary cursor-pointer
                                   group-hover:border-primary transition-colors duration-150"
                          />
                        </label>
                      ))}
                    </div>

                  </div>
                ))}
              </div>
            ))}
          </div>
        </div>


        <!-- ── C. YOUR COMMENTS ── -->
        <div class="border border-border/60">

          <div class="px-6 py-4 border-b border-border/60 flex items-center gap-3">
            <span class="size-7 bg-secondary text-white text-xs font-bold flex items-center justify-center shrink-0">C</span>
            <h2 class="text-secondary font-semibold text-base">Your Comments</h2>
          </div>

          <div class="p-6 space-y-6">

            <div>
              <label class="block text-sm font-semibold text-secondary mb-2">
                What did we do well?
                <span class="text-muted font-normal text-xs ml-1">Please tell us what you appreciated most about your experience.</span>
              </label>
              <textarea name="comment_positive" rows="3"
                placeholder="Share what went well..."
                class="w-full border border-border/60 bg-surface px-4 py-3 text-sm text-secondary
                       focus:outline-none focus:border-primary transition-colors duration-200
                       resize-none placeholder:text-muted/40"></textarea>
            </div>

            <div>
              <label class="block text-sm font-semibold text-secondary mb-2">
                Where can we improve?
                <span class="text-muted font-normal text-xs ml-1">Please describe any area of concern or suggestion for improvement.</span>
              </label>
              <textarea name="comment_improvement" rows="3"
                placeholder="Describe any concerns or suggestions..."
                class="w-full border border-border/60 bg-surface px-4 py-3 text-sm text-secondary
                       focus:outline-none focus:border-primary transition-colors duration-200
                       resize-none placeholder:text-muted/40"></textarea>
            </div>

            <div>
              <label class="block text-sm font-semibold text-secondary mb-2">
                Any other comments, compliments, or concerns?
              </label>
              <textarea name="comment_other" rows="3"
                placeholder="Any other thoughts..."
                class="w-full border border-border/60 bg-surface px-4 py-3 text-sm text-secondary
                       focus:outline-none focus:border-primary transition-colors duration-200
                       resize-none placeholder:text-muted/40"></textarea>
            </div>

          </div>
        </div>


        <!-- ── D. FOLLOW-UP ── -->
        <div class="border border-border/60">

          <div class="px-6 py-4 border-b border-border/60 flex items-center gap-3">
            <span class="size-7 bg-secondary text-white text-xs font-bold flex items-center justify-center shrink-0">D</span>
            <h2 class="text-secondary font-semibold text-base">Follow-Up
              <span class="text-muted font-normal text-xs ml-2">(Optional)</span>
            </h2>
          </div>

          <div class="p-6 space-y-5">

            <div>
              <p class="text-sm font-semibold text-secondary mb-3">
                Would you like a member of our team to contact you regarding your feedback?
              </p>
              <div class="flex gap-6">
                {["Yes", "No"].map(v => (
                  <label class="flex items-center gap-2 cursor-pointer group" id={`followup-${v.toLowerCase()}-label`}>
                    <input type="radio" name="wants_followup" value={v}
                      id={`followup-${v.toLowerCase()}`}
                      class="size-4 text-primary border-border/60 focus:ring-primary"/>
                    <span class="text-sm text-muted group-hover:text-secondary transition-colors">{v}</span>
                  </label>
                ))}
              </div>
            </div>

            <!-- Contact details — shown only if Yes -->
            <div id="followup-contact" class="hidden space-y-4 pt-2">
              <div class="grid sm:grid-cols-2 gap-4">
                <div>
                  <label class="block text-xs font-semibold text-secondary uppercase tracking-wider mb-1.5">
                    Preferred Phone
                  </label>
                  <input type="tel" name="followup_phone"
                    class="w-full border border-border/60 bg-surface px-3 py-2.5 text-sm text-secondary
                           focus:outline-none focus:border-primary transition-colors duration-200"/>
                </div>
                <div>
                  <label class="block text-xs font-semibold text-secondary uppercase tracking-wider mb-1.5">
                    Preferred Email
                  </label>
                  <input type="email" name="followup_email"
                    class="w-full border border-border/60 bg-surface px-3 py-2.5 text-sm text-secondary
                           focus:outline-none focus:border-primary transition-colors duration-200"/>
                </div>
              </div>
              <div>
                <p class="text-xs font-semibold text-secondary uppercase tracking-wider mb-2">
                  Preferred time to be contacted
                </p>
                <div class="flex gap-5">
                  {["Morning", "Afternoon", "Evening"].map(t => (
                    <label class="flex items-center gap-2 cursor-pointer">
                      <input type="radio" name="followup_time" value={t}
                        class="size-4 text-primary border-border/60 focus:ring-primary"/>
                      <span class="text-sm text-muted">{t}</span>
                    </label>
                  ))}
                </div>
              </div>
            </div>

          </div>
        </div>


        <!-- ── SUBMIT ── -->
        <div class="flex flex-col sm:flex-row items-start sm:items-center
                    justify-between gap-4 pt-2 border-t border-border/60">
          <p class="text-muted text-xs leading-relaxed max-w-sm">
            Thank you sincerely for your time and trust.
          </p>
          <button
            type="submit"
            class="group inline-flex items-center gap-3 bg-primary hover:bg-primary-dark
                   text-white font-bold text-sm tracking-wide px-8 py-4 shrink-0
                   transition-all duration-200 hover:-translate-y-0.5
                   hover:shadow-lg hover:shadow-primary/30">
            Submit Feedback
            <svg class="size-4 group-hover:translate-x-1 transition-transform duration-200"
                 fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </button>
        </div>

      </form>
    </div>
  </section>

</Layout>

<script>
  // Show/hide follow-up contact fields based on Yes/No selection
  const yesBtn = document.getElementById('followup-yes');
  const noBtn  = document.getElementById('followup-no');
  const panel  = document.getElementById('followup-contact');

  if (yesBtn && noBtn && panel) {
    yesBtn.addEventListener('change', () => {
      panel.classList.remove('hidden');
    });
    noBtn.addEventListener('change', () => {
      panel.classList.add('hidden');
    });
  }
</script>