---
import Layout from '../../Layout/Layout.astro';

/**
 * Appointments — St. Paul's Mission Hospital
 *
 * ── Update these values when Google Form is ready ────────────────────
 */
const GOOGLE_FORM   = "https://docs.google.com/forms/d/e/YOUR_FORM_ID/viewform"
const PHONE         = "+254 111 817 447"
const WHATSAPP      = "254111817447"
const WA_LINK       = `https://wa.me/${WHATSAPP}?text=${encodeURIComponent("Hello, I would like to book an appointment at St. Paul's Mission Hospital.")}`

/**
 * Department schedule
 * days: array of day strings — shown as availability badges
 * note: shown below the card — use for special instructions
 * surgery: true = shows "request" treatment instead of book button
 */
const departments = [
  {
    id:     "opd",
    title:  "OPD & General Consultation",
    meta:   "General",
    icon:   "M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z",
    iconFill: false,
    days:   ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat"],
    time:   "8:00 AM – 5:00 PM",
    desc:   "Walk in any day or book ahead to reduce your waiting time. Our clinical officers and doctors handle general consultations, chronic disease follow-ups, and referrals.",
    note:   null,
    surgery: false,
  },
  {
    id:     "maternal",
    title:  "Maternal & Antenatal",
    meta:   "Maternity",
    icon:   "M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z",
    iconFill: true,
    days:   ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat"],
    time:   "8:00 AM – 5:00 PM",
    desc:   "Antenatal care, postnatal follow-up, family planning, and maternal health services available every day. Our midwives and obstetricians are here to support you at every stage.",
    note:   "Emergency maternity care is available 24 hours, 7 days a week.",
    surgery: false,
  },
  {
    id:     "physio",
    title:  "Physiotherapy & Rehabilitation",
    meta:   "Rehab",
    icon:   "M13 10V3L4 14h7v7l9-11h-7z",
    iconFill: false,
    days:   ["Mon", "Tue", "Wed", "Thu", "Fri"],
    time:   "8:00 AM – 4:00 PM",
    desc:   "Rehabilitation sessions for orthopaedic recovery, stroke management, pain relief, and occupational therapy. Appointments are recommended to secure your slot.",
    note:   "Closed on weekends. Please book at least one day in advance.",
    surgery: false,
  },
  {
    id:     "lab",
    title:  "Laboratory & Diagnostics",
    meta:   "Diagnostics",
    icon:   "M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2",
    iconFill: false,
    days:   ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat"],
    time:   "7:30 AM – 5:00 PM",
    desc:   "Blood tests, urinalysis, imaging (X-Ray & Ultrasound), and pathology services. Most routine results are available same day. No prior appointment needed for standard tests.",
    note:   "Fasting tests (blood sugar, lipid profile) — please arrive before 9:00 AM.",
    surgery: false,
  },
  {
    id:     "surgery",
    title:  "Surgical Services",
    meta:   "Surgery",
    icon:   "M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z",
    iconFill: false,
    days:   ["Mon", "Tue", "Wed", "Thu", "Fri"],
    time:   "By arrangement",
    desc:   "Elective and planned surgical procedures including general surgery and specialised theatre cases. All surgical bookings require a prior consultation and clinical assessment.",
    note:   "Surgical appointments are confirmed by our team after review. Please allow 1–2 working days for confirmation.",
    surgery: true,
  },
]

const allDays = ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat"]
---

<Layout title="Book an Appointment — St. Paul's Mission Hospital">

  <!-- ════════════════════════════════════════
       HERO
  ════════════════════════════════════════ -->
  <header class="bg-secondary border-b border-white/10">
    <div class="max-w-7xl mx-auto px-6 lg:px-16 py-10 pt-16">
      <div class="grid lg:grid-cols-2 gap-8 items-end">
        <div>
          <p class="text-primary-light text-xs tracking-[0.22em] uppercase font-semibold mb-4 flex items-center gap-3">
            <span class="w-8 h-px bg-primary-light inline-block"></span>
            Appointments
          </p>
          <h1 class="font-display text-white text-4xl sm:text-5xl font-normal leading-tight">
            Book your visit<br/>
            <span class="font-semibold italic text-primary-light">at St. Paul's.</span>
          </h1>
        </div>
        <div class="pb-1">
          <p class="text-white/50 text-sm leading-relaxed max-w-md">
            Select your department below, check availability, and submit your request. Our team will confirm your appointment within 24 hours via the contact details you provide.
          </p>
          <!-- Quick contact strip -->
          <div class="flex flex-wrap items-center gap-4 mt-5">
            <a href={`tel:${PHONE}`}
               class="flex items-center gap-2 text-white/60 hover:text-white text-xs
                      font-semibold transition-colors duration-200">
              <svg class="size-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round"
                  d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
              {PHONE}
            </a>
            <span class="text-white/20 text-xs">or</span>
            <a href={WA_LINK} target="_blank" rel="noopener noreferrer"
               class="flex items-center gap-2 text-[#25D366] hover:text-white text-xs
                      font-semibold transition-colors duration-200">
              <svg class="size-3.5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M11.99 2C6.477 2 2 6.477 2 12c0 1.99.578 3.844 1.576 5.403L2 22l4.757-1.547A9.958 9.958 0 0012 22c5.523 0 10-4.477 10-10S17.523 2 11.99 2z"/>
              </svg>
              WhatsApp us
            </a>
          </div>
        </div>
      </div>
    </div>
  </header>


  <!-- ════════════════════════════════════════
       HOW IT WORKS — 3 steps
  ════════════════════════════════════════ -->
  <div class="bg-surface border-b border-border/60">
    <div class="max-w-7xl mx-auto px-6 lg:px-16 py-8">
      <div class="grid sm:grid-cols-3 gap-6 lg:gap-10">
        {[
          { num: "01", title: "Choose your department", desc: "Find your department below and check which days it runs." },
          { num: "02", title: "Submit your request",    desc: "Fill in the booking form with your details and preferred date." },
          { num: "03", title: "We confirm within 24hrs", desc: "Our team reviews your request and contacts you to confirm." },
        ].map(step => (
          <div class="flex items-start gap-4">
            <span class="font-display text-primary/20 text-4xl font-bold leading-none shrink-0 select-none">
              {step.num}
            </span>
            <div class="pt-1">
              <p class="text-secondary font-semibold text-sm mb-1">{step.title}</p>
              <p class="text-muted text-xs leading-relaxed">{step.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>


  <!-- ════════════════════════════════════════
       DEPARTMENT CARDS
  ════════════════════════════════════════ -->
  <section class="bg-white py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-6 lg:px-16">

      <div class="flex items-end justify-between mb-12">
        <div>
          <p class="text-primary text-xs tracking-[0.22em] uppercase font-semibold mb-3 flex items-center gap-3">
            <span class="w-8 h-px bg-primary inline-block"></span>
            Available departments
          </p>
          <h2 class="font-display text-secondary text-3xl font-normal leading-snug">
            Choose your<br/>
            <span class="font-semibold italic text-primary">department.</span>
          </h2>
        </div>
        <p class="text-muted text-xs leading-relaxed max-w-xs text-right hidden sm:block">
          Emergency? Call us directly or use the WhatsApp button — do not use this form.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {departments.map(dept => (
          <div class="group flex flex-col bg-surface border border-border/60
                      hover:border-primary/30 hover:shadow-lg hover:shadow-primary/5
                      transition-all duration-300">

            <!-- Card header -->
            <div class="p-6 flex items-start justify-between gap-4">
              <div class="flex items-start gap-4">
                <div class="size-11 bg-white border border-border/60 flex items-center justify-center shrink-0
                            group-hover:bg-primary group-hover:border-primary transition-all duration-300">
                  <svg class="size-5 text-primary group-hover:text-white transition-colors duration-300"
                       fill={dept.iconFill ? "currentColor" : "none"}
                       stroke={dept.iconFill ? "none" : "currentColor"}
                       stroke-width="1.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d={dept.icon}/>
                  </svg>
                </div>
                <div>
                  <span class="text-[0.58rem] font-bold tracking-[0.16em] uppercase
                               text-accent bg-accent/8 border border-accent/15 px-2 py-0.5 inline-block mb-2">
                    {dept.meta}
                  </span>
                  <h3 class="text-secondary font-semibold text-base leading-snug
                             group-hover:text-primary transition-colors duration-200">
                    {dept.title}
                  </h3>
                </div>
              </div>
            </div>

            <!-- Description -->
            <div class="px-6 pb-4 flex-1">
              <p class="text-muted text-xs leading-relaxed">{dept.desc}</p>
            </div>

            <!-- Availability -->
            <div class="px-6 py-4 border-t border-border/50">
              <p class="text-[0.58rem] font-bold tracking-widest uppercase text-muted/50 mb-2">
                Availability
              </p>
              <div class="flex items-center gap-1.5 flex-wrap mb-2">
                {allDays.map(day => {
                  const active = dept.days.includes(day)
                  return (
                    <span class={`text-[0.58rem] font-bold px-2 py-0.5 uppercase tracking-wider
                      ${active
                        ? 'bg-primary/10 text-primary border border-primary/20'
                        : 'bg-border/30 text-muted/30 border border-border/30'
                      }`}>
                      {day}
                    </span>
                  )
                })}
              </div>
              <p class="text-muted/60 text-[0.62rem]">{dept.time}</p>
            </div>

            <!-- Note -->
            {dept.note && (
              <div class="px-6 py-3 bg-primary/5 border-t border-primary/10">
                <p class="text-primary/70 text-[0.62rem] leading-relaxed">
                  <span class="font-bold">Note:</span> {dept.note}
                </p>
              </div>
            )}

            <!-- CTA -->
            <div class="p-5 border-t border-border/60">
              {dept.surgery ? (
                <a href={GOOGLE_FORM} target="_blank" rel="noopener noreferrer"
                   class="group/btn w-full inline-flex items-center justify-center gap-2
                          bg-secondary hover:bg-primary text-white
                          font-bold text-xs tracking-[0.12em] uppercase
                          px-5 py-3 transition-all duration-200">
                  <svg class="size-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round"
                      d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                  </svg>
                  Request Surgical Appointment
                  <svg class="size-3.5 group-hover/btn:translate-x-1 transition-transform duration-200"
                       fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                  </svg>
                </a>
              ) : (
                <a href={GOOGLE_FORM} target="_blank" rel="noopener noreferrer"
                   class="group/btn w-full inline-flex items-center justify-center gap-2
                          bg-primary hover:bg-primary-dark text-white
                          font-bold text-xs tracking-[0.12em] uppercase
                          px-5 py-3 transition-all duration-200">
                  <svg class="size-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round"
                      d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                  </svg>
                  Book Appointment
                  <svg class="size-3.5 group-hover/btn:translate-x-1 transition-transform duration-200"
                       fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                  </svg>
                </a>
              )}
            </div>

          </div>
        ))}
      </div>

    </div>
  </section>


  <!-- ════════════════════════════════════════
       EMERGENCY STRIP
  ════════════════════════════════════════ -->
  <section class="bg-accent py-10">
    <div class="max-w-7xl mx-auto px-6 lg:px-16">
      <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6">
        <div class="flex items-start gap-4">
          <div class="size-10 bg-white/10 border border-white/20 flex items-center justify-center shrink-0">
            <span class="relative flex size-2">
              <span class="absolute inline-flex size-full rounded-full bg-white animate-ping opacity-75"></span>
              <span class="relative inline-flex size-2 rounded-full bg-white"></span>
            </span>
          </div>
          <div>
            <p class="text-white font-bold text-base">This booking form is not for emergencies.</p>
            <p class="text-white/70 text-xs leading-relaxed mt-0.5">
              If you or someone you know needs urgent care — call us immediately or come directly to the hospital. Our emergency team is available 24 hours, 7 days a week.
            </p>
          </div>
        </div>
        <a href={`tel:${PHONE}`}
           class="inline-flex items-center gap-3 bg-white text-accent font-bold
                  text-xs tracking-[0.14em] uppercase px-6 py-3.5 shrink-0
                  hover:bg-accent-light hover:text-white transition-all duration-200">
          <svg class="size-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round"
              d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          Call Emergency Line
        </a>
      </div>
    </div>
  </section>

</Layout>