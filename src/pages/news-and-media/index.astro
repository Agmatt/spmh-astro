---
// src/pages/news-and-media.astro
// Redesigned with visual hierarchy, featured hero, better typography
// Adjust layout import path to match your project

import Layout from '../../Layout/Layout.astro';

// ── PLACEHOLDER DATA ─────────────────────────────────────────────
// Shaped to match Supabase schema. Replace with live Supabase queries
// when editorial dashboard is ready.

const articles = [
  {
    slug: 'baby-adrian-blessings-kmc',
    title: "Baby Adrian's First Days: A Newborn Unit Success Story",
    excerpt: "How Kangaroo Mother Care helped a premature newborn thrive in SPMH's Newborn Unit.",
    cover_image: '/images/news/newborn-unit-kmc.jpg',
    category: 'Patient Stories',
    published_at: '2026-05-12',
  },
  {
    slug: 'staff-family-day-2026',
    title: 'Staff Family Day 2026: Building Community Beyond the Wards',
    excerpt: 'Staff and their families gathered for a day of connection, games, and gratitude.',
    cover_image: '/images/news/family-day-2026.jpg',
    category: 'Community',
    published_at: '2026-04-02',
  },
  {
    slug: 'hdu-impact-one-year',
    title: 'One Year of the HDU: Lives Stabilized, Referrals Reduced',
    excerpt: "A look back at the High Dependency Unit's first year of operation.",
    cover_image: '/images/news/hdu-impact.jpg',
    category: 'Facility Updates',
    published_at: '2026-02-20',
  },
];

const pressReleases = [
  {
    slug: 'sha-level-4-accreditation',
    title: "St. Paul's Mission Hospital Attains SHA Level 4 Accreditation",
    excerpt: "Official statement on the hospital's accreditation upgrade and what it means for patients.",
    pdf_url: '/documents/press/sha-level-4-accreditation.pdf',
    published_at: '2026-06-01',
  },
  {
    slug: 'maternity-surgical-wing-groundbreaking',
    title: 'Groundbreaking Ceremony Held for New Maternity and Surgical Wing',
    excerpt: 'The Diocese of Homa Bay and hospital leadership mark the start of construction.',
    pdf_url: '/documents/press/maternity-surgical-wing-groundbreaking.pdf',
    published_at: '2026-03-18',
  },
];

const events = [
  {
    slug: 'cme-cqi-principles',
    title: 'CME Session: Continuous Quality Improvement Principles',
    description: 'A continuing medical education session for clinical staff on CQI methodology.',
    event_date: '2026-08-14',
    location: 'SPMH Conference Hall',
  },
  {
    slug: 'community-health-camp',
    title: 'Free Community Health Camp',
    description: 'Free screening, consultation, and referral services for the surrounding community.',
    event_date: '2026-09-05',
    location: 'SPMH Grounds',
  },
  {
    slug: 'maternity-surgical-wing-groundbreaking-event',
    title: 'Maternity and Surgical Wing Groundbreaking',
    description: 'Official groundbreaking ceremony for the new wing.',
    event_date: '2026-03-18',
    location: 'SPMH Main Grounds',
  },
];

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('en-KE', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}

function isEventPast(eventDateStr: string) {
  return new Date(eventDateStr) < new Date();
}

// Get the latest article for hero section
const latestArticle = articles[0];
const restArticles = articles.slice(1);
---

<Layout title="News & Media | St. Paul's Mission Hospital">
  <!-- PAGE INTRO -->
  <section class="bg-gradient-to-b from-slate-50 to-white px-6 py-16 md:py-20">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-sm font-sans uppercase tracking-widest text-[#125276] font-semibold mb-3">
        News &amp; Media
      </p>
      <h1 class="font-serif text-4xl md:text-5xl text-slate-900 mb-4 leading-tight">
        Stories from the heart of our mission
      </h1>
      <p class="font-sans text-lg text-slate-600">
        Updates on our patients, our work, and our community. Discover how we're making a difference at SPMH.
      </p>
    </div>
  </section>

  <!-- HERO: LATEST ARTICLE -->
  {latestArticle && (
    <section class="px-6 py-12 md:py-16 bg-white">
      <div class="max-w-5xl mx-auto">
        <a href={`/news/${latestArticle.slug}`} class="group block">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12 items-center">
            <!-- IMAGE -->
            <div class="overflow-hidden rounded-lg h-64 md:h-96">
              <img
                src={latestArticle.cover_image}
                alt={latestArticle.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
              />
            </div>

            <!-- CONTENT -->
            <div class="flex flex-col justify-center">
              <span class="inline-block text-xs font-sans font-semibold uppercase tracking-widest text-[#125276] bg-blue-50 px-3 py-1 rounded-full w-fit mb-4">
                Latest • {latestArticle.category}
              </span>
              <h2 class="font-serif text-3xl md:text-4xl text-slate-900 mb-4 leading-tight group-hover:text-[#125276] transition-colors">
                {latestArticle.title}
              </h2>
              <p class="font-sans text-lg text-slate-600 mb-6 leading-relaxed">
                {latestArticle.excerpt}
              </p>
              <div class="flex items-center gap-6">
                <time datetime={latestArticle.published_at} class="text-sm font-sans text-slate-500">
                  {formatDate(latestArticle.published_at)}
                </time>
                <span class="font-sans font-semibold text-[#125276] group-hover:gap-2 flex items-center gap-1 transition-all">
                  Read story →
                </span>
              </div>
            </div>
          </div>
        </a>
      </div>
    </section>
  )}

  <!-- CONTENT TABS SECTION -->
  <section class="px-4 md:px-6 py-16 md:py-20 bg-gradient-to-b from-slate-50 to-white">
    <div class="max-w-5xl mx-auto" x-data="{ activeTab: 'articles' }">
      <!-- TAB NAVIGATION -->
      <div class="flex gap-3 mb-12 overflow-x-auto">
        <button
          role="tab"
          :aria-selected="activeTab === 'articles'"
          @click="activeTab = 'articles'"
          class="px-4 py-3 font-sans font-semibold text-sm whitespace-nowrap rounded-lg transition-all duration-200"
          :class="activeTab === 'articles' ? 'bg-[#125276] text-white shadow-md hover:bg-[#0d3a5c]' : 'bg-slate-100 text-slate-700 hover:bg-slate-200'"
        >
          Articles
        </button>
        <button
          role="tab"
          :aria-selected="activeTab === 'press'"
          @click="activeTab = 'press'"
          class="px-4 py-3 font-sans font-semibold text-sm whitespace-nowrap rounded-lg transition-all duration-200"
          :class="activeTab === 'press' ? 'bg-[#860f0f] text-white shadow-md hover:bg-[#6b0a0a]' : 'bg-slate-100 text-slate-700 hover:bg-slate-200'"
        >
          Press Releases
        </button>
        <button
          role="tab"
          :aria-selected="activeTab === 'events'"
          @click="activeTab = 'events'"
          class="px-4 py-3 font-sans font-semibold text-sm whitespace-nowrap rounded-lg transition-all duration-200"
          :class="activeTab === 'events' ? 'bg-green-600 text-white shadow-md hover:bg-green-700' : 'bg-slate-100 text-slate-700 hover:bg-slate-200'"
        >
          Events
        </button>
      </div>

      <!-- ARTICLES TAB -->
      <div x-show="activeTab === 'articles'" x-cloak class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {restArticles.length === 0 ? (
          <p class="col-span-full text-center py-12 text-slate-500 font-sans">No more articles at this time.</p>
        ) : (
          restArticles.map((article) => (
            <a
              href={`/news/${article.slug}`}
              class="group flex flex-col bg-white rounded-lg overflow-hidden border border-slate-200 hover:border-[#125276] hover:shadow-xl transition-all duration-300 hover:-translate-y-1"
            >
              <!-- IMAGE -->
              <div class="relative overflow-hidden h-56 bg-slate-200">
                <img
                  src={article.cover_image}
                  alt={article.title}
                  loading="lazy"
                  class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                />
                <div class="absolute top-0 right-0 bg-[#125276] text-white px-4 py-2 text-xs font-semibold uppercase tracking-widest rounded-bl-lg">
                  {article.category}
                </div>
              </div>

              <!-- CONTENT -->
              <div class="p-6 flex flex-col flex-1">
                <h3 class="font-serif text-xl text-slate-900 mb-3 group-hover:text-[#125276] transition-colors line-clamp-2">
                  {article.title}
                </h3>
                <p class="font-sans text-sm text-slate-600 mb-4 leading-relaxed flex-1 line-clamp-2">
                  {article.excerpt}
                </p>
                <div class="flex items-center justify-between pt-4 border-t border-slate-100">
                  <time datetime={article.published_at} class="text-xs font-sans text-slate-500">
                    {formatDate(article.published_at)}
                  </time>
                  <span class="font-sans font-semibold text-[#125276] text-sm group-hover:gap-2 flex items-center gap-1 transition-all">
                    →
                  </span>
                </div>
              </div>
            </a>
          ))
        )}
      </div>

      <!-- PRESS RELEASES TAB -->
      <div x-show="activeTab === 'press'" x-cloak class="space-y-5">
        {pressReleases.length === 0 ? (
          <p class="text-center py-12 text-slate-500 font-sans">No press releases at this time.</p>
        ) : (
          pressReleases.map((release) => (
            <a
              href={`/news/${release.slug}`}
              class="group block bg-white rounded-lg border border-slate-200 hover:border-[#860f0f] hover:shadow-lg transition-all duration-300 overflow-hidden hover:-translate-y-0.5"
            >
              <div class="flex flex-col md:flex-row">
                <!-- ACCENT BAR -->
                <div class="w-1 md:w-2 bg-gradient-to-b from-[#860f0f] to-[#6b0a0a]"></div>

                <!-- CONTENT -->
                <div class="flex-1 p-6 md:p-7">
                  <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4 mb-3">
                    <div>
                      <span class="inline-block text-xs font-sans font-semibold uppercase tracking-widest text-[#860f0f] bg-red-50 px-3 py-1 rounded-full mb-3">
                        Press Release
                      </span>
                      <h3 class="font-serif text-2xl text-slate-900 group-hover:text-[#860f0f] transition-colors mb-2 leading-tight">
                        {release.title}
                      </h3>
                    </div>
                    <time datetime={release.published_at} class="text-sm font-sans text-slate-500 whitespace-nowrap md:text-right">
                      {formatDate(release.published_at)}
                    </time>
                  </div>
                  <p class="font-sans text-base text-slate-600 mb-4 leading-relaxed line-clamp-2">
                    {release.excerpt}
                  </p>
                  <div class="flex gap-6 flex-wrap">
                    <span class="font-sans font-semibold text-[#860f0f] text-sm group-hover:gap-2 flex items-center gap-1 transition-all">
                      Read full statement →
                    </span>
                    {release.pdf_url && (
                      <button
                        class="font-sans font-semibold text-[#125276] text-sm hover:text-[#0d3a5c] flex items-center gap-2 transition-colors"
                        onClick={(e) => {
                          e.preventDefault();
                          window.open(release.pdf_url, '_blank');
                        }}
                      >
                        📄 PDF
                      </button>
                    )}
                  </div>
                </div>
              </div>
            </a>
          ))
        )}
      </div>

      <!-- EVENTS TAB -->
      <div x-show="activeTab === 'events'" x-cloak class="space-y-6">
        {events.length === 0 ? (
          <p class="text-center py-12 text-slate-500 font-sans">No upcoming events at this time.</p>
        ) : (
          events
            .sort((a, b) => {
              const aIsPast = isEventPast(a.event_date);
              const bIsPast = isEventPast(b.event_date);
              if (aIsPast && !bIsPast) return 1;
              if (!aIsPast && bIsPast) return -1;
              if (aIsPast && bIsPast) return new Date(b.event_date).getTime() - new Date(a.event_date).getTime();
              return new Date(a.event_date).getTime() - new Date(b.event_date).getTime();
            })
            .map((event) => {
              const isPast = isEventPast(event.event_date);
              const eventDate = new Date(event.event_date);
              return (
                <div
                  class:list={[
                    'group p-6 md:p-8 bg-white rounded-lg border border-slate-200 hover:border-[#125276] hover:shadow-lg transition-all duration-300',
                    isPast ? 'opacity-60' : '',
                  ]}
                >
                  <div class="grid grid-cols-1 md:grid-cols-[120px_1fr] gap-6 md:gap-8">
                    <!-- DATE BOX -->
                    <div class="flex flex-col items-center justify-center bg-gradient-to-br from-[#125276] to-[#0d3a5c] text-white rounded-lg py-6 md:py-8">
                      <span class="font-serif text-4xl font-bold leading-none">
                        {eventDate.getDate()}
                      </span>
                      <span class="font-sans text-xs uppercase tracking-widest mt-2">
                        {eventDate.toLocaleDateString('en-KE', { month: 'short', year: 'numeric' })}
                      </span>
                    </div>

                    <!-- EVENT INFO -->
                    <div>
                      <div class="flex items-center gap-3 mb-3">
                        <span class="inline-block text-xs font-sans font-semibold uppercase tracking-widest text-slate-600 bg-slate-100 px-3 py-1 rounded-full">
                          {isPast ? 'Past Event' : 'Upcoming'}
                        </span>
                      </div>
                      <h3 class="font-serif text-2xl md:text-3xl text-slate-900 mb-2 group-hover:text-[#125276] transition-colors">
                        {event.title}
                      </h3>
                      <p class="font-sans text-base text-slate-600 mb-4 leading-relaxed">
                        {event.description}
                      </p>
                      <p class="font-sans font-semibold text-slate-700 flex items-center gap-2">
                        📍 {event.location}
                      </p>
                    </div>
                  </div>
                </div>
              );
            })
        )}
      </div>
    </div>
  </section>

  <!-- CALL TO ACTION / FOOTER -->
  <section class="px-6 py-16 md:py-20 bg-[#125276] text-white">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="font-serif text-3xl md:text-4xl mb-4">Stay updated with SPMH</h2>
      <p class="font-sans text-lg text-blue-100 mb-8">
        Get the latest news and announcements from St. Paul's Mission Hospital.
      </p>
      <button class="px-6 py-3 bg-white text-[#125276] font-sans font-semibold rounded-lg hover:bg-blue-50 transition-colors">
        Subscribe to our newsletter
      </button>
    </div>
  </section>
</Layout>