---
import '../../styles/global.css';
import { getCollection } from 'astro:content';
const allPosts = await getCollection('media');
const category = Astro.url.searchParams.get('category');

const filteredPosts = category
  ? allPosts.filter((p) => p.data.category === category)
  : allPosts;
---

<!-- src/pages/media/index.astro -->
<nav class='flex gap-6 mb-10 border-b pb-4'>
  <a href='/media' class='font-semibold text-gray-800 hover:text-blue-600'
    >All</a
  >
  <a href='/media?category=blog' class='text-gray-600 hover:text-blue-600'
    >Blogs</a
  >
  <a
    href='/media?category=press-release'
    class='text-gray-600 hover:text-blue-600'>Press Releases</a
  >
</nav>



<div class='grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8'>
  {
    filteredPosts.map((post) => (
      <div class='bg-white rounded-xl shadow-md overflow-hidden hover:shadow-xl transition-shadow duration-300 border border-gray-100'>
        <div class='p-6'>
          <span class='text-xs font-bold uppercase tracking-wider text-blue-600 bg-blue-50 px-2 py-1 rounded'>
            {post.data.category}
          </span>
          <h2 class='mt-4 text-xl font-bold text-gray-900'>
            {post.data.title}
          </h2>
          <p class='mt-2 text-gray-600 text-sm'>
            {post.data.date.toLocaleDateString()}
          </p>
          <a
            href={`/media/${post.id}`}
            class='mt-4 inline-block text-blue-600 font-medium hover:underline'>
            Read more &rarr;
          </a>
        </div>
      </div>
    ))
  }
</div>
