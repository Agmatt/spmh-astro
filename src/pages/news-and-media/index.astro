---
import Layout from '../../Layout/Layout.astro';



const articles = [
  {
    slug:     "groundbreaking-maternity-surgical-wing",
    featured: true,
    category: "Capital Development",
    date:     "March 2026",
    title:    "St. Paul's breaks ground on new Maternity & Surgical Wing",
    excerpt:  "A landmark moment for Homa Bay County — St. Paul's Mission Hospital has officially broken ground on a new Maternity and Surgical Wing, a cornerstone of our Strategic Plan 2026–2030. The development will add dedicated maternity beds, a modern surgical theatre, and expanded postnatal care capacity.",
    image:    "/img/18.jpg",
    href:     "/news-and-media/articles/groundbreaking-maternity-surgical-wing",
    readTime: "4 min read",
  },
  {
    slug:     "newborn-unit-launch",
    featured: false,
    category: "Clinical Services",
    date:     "February 2026",
    title:    "Our Newborn Unit is now open and fully operational",
    excerpt:  "St. Paul's Mission Hospital is proud to announce that our dedicated Newborn Unit is now fully operational, bringing specialised newborn care to Homa Bay County for the first time.",
    image:    "/img/56.jpg",
    href:     "/news-and-media/articles/newborn-unit-launch",
    readTime: "3 min read",
  },
  {
    slug:     "hdu-development",
    featured: false,
    category: "Developments",
    date:     "January 2026",
    title:    "High Dependency Unit — what it means for our patients",
    excerpt:  "Our HDU is currently being established as a critical step toward Level 5 status, bridging the gap between general ward care and full intensive care for high-risk patients.",
    image:    "/img/55.jpg",
    href:     "/news-and-media/articles/hdu-development",
    readTime: "3 min read",
  },
  {
    slug:     "sha-accreditation",
    featured: false,
    category: "Governance",
    date:     "December 2025",
    title:    "St. Paul's receives full SHA accreditation for inpatient and outpatient services",
    excerpt:  "Following a rigorous review process, St. Paul's Mission Hospital has been fully accredited by the Social Health Authority (SHA) for both inpatient and outpatient services.",
    image:    "/img/54.jpg",
    href:     "/news-and-media/articles/sha-accreditation-renewed",
    readTime: "2 min read",
  },
]

const events = [
  {
    day:      "15",
    month:    "Mar",
    year:     "2026",
    title:    "Free Community Health Screening",
    location: "St. Paul's Mission Hospital — Outpatient Forecourt",
    time:     "9:00 AM – 12:00 PM",
    desc:     "Free blood pressure, blood sugar, and BMI checks open to all Homa Bay residents. No appointment needed.",
    href:     "/news-and-media/events/community-health-screening-march-2026",
  },
  {
    day:      "04",
    month:    "Apr",
    year:     "2026",
    title:    "Maternal Health Awareness Day",
    location: "St. Paul's Mission Hospital — Maternity Ward",
    time:     "10:00 AM – 2:00 PM",
    desc:     "A dedicated awareness event for expectant and new mothers — covering antenatal care, safe delivery, and postnatal support.",
    href:     "/news-and-media/events/maternal-health-awareness-april-2026",
  },
  {
    day:      "20",
    month:    "Apr",
    year:     "2026",
    title:    "Volunteer Orientation Day",
    location: "St. Paul's Mission Hospital — Conference Room",
    time:     "8:30 AM – 1:00 PM",
    desc:     "Mandatory orientation session for all new volunteers. Background checks must be completed before attending.",
    href:     "/get-involved/volunteer",
  },
]

const gallery = [
  { src: "/gallery/1.jpg", },
  { src: "/gallery/2.jpg", },
  { src: "/gallery/3.jpg", },
  { src: "/gallery/4.jpg", },
  { src: "/gallery/5.jpg", },
  { src: "/gallery/6.jpg", },
]

const featuredArticle  = articles.find(a => a.featured)
const remainingArticles = articles.filter(a => !a.featured)
---

<Layout title="News & Media — St. Paul's Mission Hospital">

  <!-- PAGE HEADER -->
  <div class="bg-secondary border-b border-white/10">
    <div class="max-w-7xl mx-auto px-6 lg:px-16 py-10 pt-16">
      <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4">
        <div>
          <p class="text-primary-light text-xs tracking-[0.22em] uppercase font-semibold mb-3 flex items-center gap-3">
            <span class="w-8 h-px bg-primary-light inline-block"></span>
            News & Media
          </p>
          <h1 class="font-display text-white text-4xl sm:text-5xl font-normal leading-tight">
            Stories from<br/>
            <span class="font-semibold italic text-primary-light">St. Paul's.</span>
          </h1>
        </div>
        <p class="text-white/40 text-sm leading-relaxed max-w-xs pb-1">
          Updates, announcements, and stories from our hospital and the Homa Bay community we serve.
        </p>
      </div>
    </div>
  </div>


  <!-- FEATURED + ARTICLE GRID -->
  <section class="bg-surface py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 lg:px-16">

      <!-- Section label -->
      <div class="flex items-center justify-between mb-10">
        <div class="flex items-center gap-3">
          <p class="text-primary text-xs tracking-[0.22em] uppercase font-semibold">
            Latest News
          </p>
          <div class="h-px w-10 bg-primary/30"></div>
        </div>
        <a href="/news-and-media/articles"
           class="group flex items-center gap-2 text-muted hover:text-primary
                  text-xs font-semibold tracking-[0.12em] uppercase transition-colors duration-200">
          All articles
          <svg class="size-3.5 group-hover:translate-x-1 transition-transform duration-200"
               fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>

      <!-- Asymmetric editorial grid -->
      <div class="grid lg:grid-cols-12 gap-6">

        <!-- FEATURED article — 7 cols -->
        {featuredArticle && (
          <a href={featuredArticle.href}
             class="lg:col-span-7 group flex flex-col bg-white border border-border/60
                    hover:border-primary/30 hover:shadow-xl hover:shadow-primary/5
                    transition-all duration-300">

            <!-- Image -->
            <div class="relative overflow-hidden aspect-[16/9] lg:aspect-[16/10]">
              <img
                src={featuredArticle.image}
                alt={featuredArticle.title}
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                loading="eager"
              />
              <!-- Featured label -->
              <div class="absolute top-4 left-4">
                <span class="bg-primary text-white text-[0.58rem] font-bold tracking-[0.16em] uppercase px-3 py-1.5">
                  Featured
                </span>
              </div>
            </div>

            <!-- Content -->
            <div class="flex flex-col flex-1 p-7 lg:p-8">
              <div class="flex items-center gap-3 mb-4">
                <span class="text-accent text-[0.6rem] font-bold tracking-[0.18em] uppercase">
                  {featuredArticle.category}
                </span>
                <span class="text-border text-xs">·</span>
                <span class="text-muted text-xs">{featuredArticle.date}</span>
                <span class="text-border text-xs">·</span>
                <span class="text-muted text-xs">{featuredArticle.readTime}</span>
              </div>

              <h2 class="font-display text-secondary text-2xl lg:text-3xl font-semibold
                         leading-snug mb-4 group-hover:text-primary transition-colors duration-200">
                {featuredArticle.title}
              </h2>

              <p class="text-muted text-sm leading-relaxed flex-1 mb-6">
                {featuredArticle.excerpt}
              </p>

              <div class="flex items-center gap-2 text-primary text-xs font-bold
                          tracking-[0.12em] uppercase group-hover:gap-3 transition-all duration-200">
                Read article
                <svg class="size-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                </svg>
              </div>
            </div>

          </a>
        )}

        <!-- REMAINING articles — 5 cols, stacked -->
        <div class="lg:col-span-5 flex flex-col gap-5">
          {remainingArticles.slice(0, 3).map(article => (
            <a href={article.href}
               class="group flex gap-5 bg-white border border-border/60
                      hover:border-primary/30 hover:shadow-md hover:shadow-primary/5
                      transition-all duration-300 p-5">

              <!-- Thumbnail -->
              <div class="relative overflow-hidden size-20 sm:size-24 shrink-0">
                <img
                  src={article.image}
                  alt={article.title}
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                  loading="lazy"
                />
              </div>

              <!-- Text -->
              <div class="flex flex-col justify-between min-w-0 flex-1">
                <div>
                  <div class="flex items-center gap-2 mb-2">
                    <span class="text-accent text-[0.58rem] font-bold tracking-[0.16em] uppercase">
                      {article.category}
                    </span>
                    <span class="text-border text-xs">·</span>
                    <span class="text-muted text-[0.62rem]">{article.date}</span>
                  </div>
                  <h3 class="text-secondary font-semibold text-sm leading-snug
                             group-hover:text-primary transition-colors duration-200 line-clamp-2">
                    {article.title}
                  </h3>
                </div>
                <span class="text-muted text-[0.62rem] mt-2">{article.readTime}</span>
              </div>

            </a>
          ))}
        </div>

      </div>
    </div>
  </section>


  <!--  EVENTS -->
<section class="bg-white border-t border-border/60 py-16 lg:py-20">
  <div class="max-w-7xl mx-auto px-4 lg:px-16">

    <div class="flex items-center justify-between mb-10">
      <div class="flex items-center gap-3">
        <p class="text-primary text-xs tracking-[0.22em] uppercase font-semibold">
          Upcoming Events
        </p>
      </div>
      <a href="/news-and-media/events"
         class="group flex items-center gap-2 text-muted hover:text-primary
                text-xs font-semibold tracking-[0.12em] uppercase transition-colors duration-200">
        All events
        <svg class="size-3.5 group-hover:translate-x-1 transition-transform duration-200"
             fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {events.map(event => (
        <a href={event.href}
           class="group flex flex-col bg-surface border border-border/60
                  hover:border-primary/30 hover:shadow-md hover:shadow-primary/5
                  transition-all duration-300 hover:-translate-y-0.5">

          <!-- Date bar — stacks gracefully on all screen sizes -->
          <div class="flex items-stretch bg-secondary
                      group-hover:bg-primary transition-colors duration-300">

            <!-- Day block -->
            <div class="flex flex-col items-center justify-center px-5 py-4 shrink-0">
              <p class="font-display text-white text-4xl font-bold leading-none">
                {event.day}
              </p>
              <p class="text-white/60 text-[0.58rem] tracking-widest uppercase mt-1">
                {event.month} {event.year}
              </p>
            </div>

            <!-- Divider -->
            <div class="w-px bg-white/15 my-3"></div>

            <!-- Time block — no truncate, wraps cleanly -->
            <div class="flex flex-col justify-center px-5 py-4 min-w-0">
              <p class="text-white/50 text-[0.58rem] tracking-widest uppercase mb-1">
                Time
              </p>
              <p class="text-white/90 text-xs font-semibold leading-snug">
                {event.time}
              </p>
            </div>

          </div>

          <!-- Content -->
          <div class="p-6 flex flex-col flex-1 gap-3">
            <h3 class="text-secondary font-semibold text-base leading-snug
                       group-hover:text-primary transition-colors duration-200">
              {event.title}
            </h3>
            <p class="text-muted text-xs leading-relaxed flex-1">{event.desc}</p>
            <div class="flex items-start gap-2 pt-3 border-t border-border/50">
              <svg class="size-3.5 text-muted/50 shrink-0 mt-0.5" fill="none" stroke="currentColor"
                   stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round"
                  d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              <!-- items-start + mt-0.5 on icon so location text wraps without misaligning -->
              <p class="text-muted text-xs leading-relaxed">{event.location}</p>
            </div>
          </div>

        </a>
      ))}
    </div>

  </div>
</section>


<!-- ════════════════════════════════════════
     §3  PHOTO GALLERY — Compact carousel
     aspect-[16/10] works for any photo type
     Simple vanilla JS, no framework
════════════════════════════════════════ -->
<section class="bg-secondary py-10 relative overflow-hidden">

  <div class="relative max-w-7xl mx-auto px-2 md:px-4 lg:px-16">

    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
      <div class="flex items-center gap-3">
        <p class="text-primary-light text-xs tracking-[0.22em] uppercase font-semibold">
          Photo Gallery
        </p>
      </div>
      <div class="flex items-center gap-2">
        <button id="gallery-prev" aria-label="Previous"
          class="size-8 border border-white/20 text-white flex items-center justify-center
                 hover:bg-primary hover:border-primary transition-all duration-200">
          <svg class="size-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
          </svg>
        </button>
        <button id="gallery-next" aria-label="Next"
          class="size-8 border border-white/20 text-white flex items-center justify-center
                 hover:bg-primary hover:border-primary transition-all duration-200">
          <svg class="size-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
          </svg>
        </button>
        <div class="w-px h-5 bg-white/15 mx-1"></div>
        <a href="/news-and-media/gallery"
           class="text-white/40 hover:text-white text-xs font-semibold
                  tracking-[0.12em] uppercase transition-colors duration-200">
          View all →
        </a>
      </div>
    </div>

    <!-- Track -->
    <div
      id="gallery-track"
      class="flex gap-3 overflow-x-auto [scrollbar-width:none] [&::-webkit-scrollbar]:hidden"
      style="scroll-snap-type:x mandatory; scroll-behavior:smooth;"
    >
      <!-- All cards: aspect-[16/10] — works for landscape, portrait, square -->
      <div class="shrink-0 w-[85vw] sm:w-[55vw] lg:w-[calc(25%-9px)]" style="scroll-snap-align:start;">
        <div class="relative aspect-[16/10] overflow-hidden bg-white/5">
          <img src="/gallery/1.jpg" alt=""
               class="absolute inset-0 w-full h-full object-cover"
               loading="eager" fetchpriority="high" decoding="async"/>
        </div>
      </div>

      <div class="shrink-0 w-[85vw] sm:w-[55vw] lg:w-[calc(25%-9px)]" style="scroll-snap-align:start;">
        <div class="relative aspect-[16/10] overflow-hidden bg-white/5">
          <img src="/gallery/2.jpg" alt=""
               class="absolute inset-0 w-full h-full object-cover"
               loading="lazy" decoding="async"/>
        </div>
      </div>

      <div class="shrink-0 w-[85vw] sm:w-[55vw] lg:w-[calc(25%-9px)]" style="scroll-snap-align:start;">
        <div class="relative aspect-[16/10] overflow-hidden bg-white/5">
          <img src="/gallery/3.jpg" alt=""
               class="absolute inset-0 w-full h-full object-cover"
               loading="lazy" decoding="async"/>
        </div>
      </div>

      <div class="shrink-0 w-[85vw] sm:w-[55vw] lg:w-[calc(25%-9px)]" style="scroll-snap-align:start;">
        <div class="relative aspect-[16/10] overflow-hidden bg-white/5">
          <img src="/gallery/4.jpg" alt=""
               class="absolute inset-0 w-full h-full object-cover"
               loading="lazy" decoding="async"/>
        </div>
      </div>
    </div>

    <!-- Dots -->
    <div class="flex items-center gap-1.5 mt-4">
      <button data-i="0" class="g-dot h-1 w-5 rounded-full bg-primary-light transition-all duration-200" aria-label="1"></button>
      <button data-i="1" class="g-dot h-1 w-2 rounded-full bg-white/20 transition-all duration-200" aria-label="2"></button>
      <button data-i="2" class="g-dot h-1 w-2 rounded-full bg-white/20 transition-all duration-200" aria-label="3"></button>
      <button data-i="3" class="g-dot h-1 w-2 rounded-full bg-white/20 transition-all duration-200" aria-label="4"></button>
    </div>

  </div>
</section>

<script>
  (function(){
    const track = document.getElementById('gallery-track');
    const cards = Array.from(track.children);
    const dots  = Array.from(document.querySelectorAll('.g-dot'));
    const prev  = document.getElementById('gallery-prev');
    const next  = document.getElementById('gallery-next');
    let cur = 0;

    function go(i){
      if(!track || cards.length === 0) return;
      cur = Math.max(0, Math.min(i, cards.length - 1));
      
      // Calculate gap dynamically from CSS
      const gap = parseInt(window.getComputedStyle(track).gap) || 12;
      track.scrollTo({ left: cur * (cards[0].offsetWidth + gap), behavior:'smooth' });
      
      dots.forEach((d,j) => {
        const isActive = j === cur;
        d.style.width = isActive ? '20px' : '8px';
        d.style.backgroundColor = isActive ? '#90caf9' : 'rgba(255,255,255,0.2)';
        d.setAttribute('aria-current', isActive ? 'true' : 'false');
      });

      prev.style.opacity = cur === 0 ? '0.3' : '1';
      next.style.opacity = cur === cards.length - 1 ? '0.3' : '1';
      prev.disabled = cur === 0;
      next.disabled = cur === cards.length - 1;
    }

    prev.onclick = () => go(cur - 1);
    next.onclick = () => go(cur + 1);
    dots.forEach((d, i) => d.onclick = () => go(i));

    let t;
    track.addEventListener('scroll', () => {
      clearTimeout(t);
      t = setTimeout(() => {
        const gap = parseInt(window.getComputedStyle(track).gap) || 12;
        const i = Math.round(track.scrollLeft / (cards[0].offsetWidth + gap));
        if(i !== cur) { cur = i; go(i); }
      }, 100);
    }, { passive: true });

    // Initial sync
    go(0);
  })();
</script>









<!--  EDITORIAL CTA — closing section -->
<section class="bg-surface border-t border-border/60 py-16">
  <div class="max-w-7xl mx-auto px-2 md:px-4 lg:px-16">
    <div class="grid lg:grid-cols-2 gap-10 items-center">

      <!-- LEFT: copy -->
      <div>
        <p class="text-primary text-xs tracking-[0.22em] uppercase font-semibold mb-4 flex items-center gap-3">
          <span class="w-8 h-px bg-primary inline-block"></span>
          Editorial Team
        </p>
        <h2 class="font-display text-secondary text-3xl sm:text-4xl font-normal leading-snug mb-4">
          Have a story or<br/>
          <span class="font-bold text-primary">tip for us?</span>
        </h2>
        <p class="text-muted text-sm leading-relaxed max-w-md">
          Our editorial team is always looking for stories from within the St. Paul's community — patient journeys, staff milestones, health education topics, and community events. If you have something worth sharing, we'd love to hear from you.
        </p>
      </div>

      <!-- RIGHT: contact card -->
      <div class="bg-white border border-border/60 p-8 flex flex-col gap-6">

        <div class="flex items-start gap-4">
          <div class="size-11 bg-surface-2 border border-border/60 flex items-center justify-center shrink-0">
            <svg class="size-5 text-primary" fill="none" stroke="currentColor"
                 stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round"
                d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10"/>
            </svg>
          </div>
          <div>
            <p class="text-secondary font-semibold text-sm mb-1">Pitch a story</p>
            <p class="text-muted text-xs leading-relaxed">
              Send us a brief summary of your story idea, event, or topic. We'll get back to you within 3 working days.
            </p>
          </div>
        </div>

        <div class="h-px bg-border/60"></div>

        <!-- What to include -->
        <div>
          <p class="text-secondary text-[0.62rem] font-bold tracking-[0.16em] uppercase mb-3">
            Include in your message:
          </p>
          <div class="space-y-2">
            {[
              "Your name and role or connection to St. Paul's",
              "A brief description of the story or topic",
              "Any photos or supporting materials you can share",
            ].map(item => (
              <div class="flex items-start gap-2.5">
                <svg class="size-3.5 text-primary shrink-0 mt-0.5"
                     fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                </svg>
                <span class="text-muted text-xs leading-relaxed">{item}</span>
              </div>
            ))}
          </div>
        </div>

        <div class="h-px bg-border/60"></div>

        <!-- CTA -->
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
          <div>
            <p class="text-muted/50 text-[0.58rem] tracking-widest uppercase mb-1">Contact</p>
            <p class="text-secondary font-semibold text-sm">Editorial Team</p>
          </div>
          <a
            href={`mailto:spmheditorial@gmail.com?subject=${encodeURIComponent("Story Pitch — St. Paul's News & Media")}`}
            class="group inline-flex items-center gap-2.5 bg-primary hover:bg-primary-dark
                   text-white font-bold text-xs tracking-[0.12em] uppercase
                   px-6 py-3.5 transition-all duration-200
                   hover:-translate-y-0.5 hover:shadow-lg hover:shadow-primary/30"
          >
            <svg class="size-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            Email the team
            <svg class="size-3.5 group-hover:translate-x-1 transition-transform duration-200"
                 fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
        </div>

      </div>
    </div>
  </div>
</section>


</Layout>