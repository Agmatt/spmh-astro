---
export const prerender = true

import Layout from '../../../Layout/Layout.astro'
import { getCollection } from 'astro:content'
import type { GetStaticPaths } from 'astro'

/**
 * Individual Gallery Album Page
 * File placement: src/pages/news-and-media/gallery/[slug].astro
 */


export const getStaticPaths: GetStaticPaths = async () => {
  const albums = await getCollection('gallery', ({ data }) => !data.draft)
  return albums.map(album => ({
    params: { slug: album.id },
    props:  { album },
  }))
}

const { album } = Astro.props

function formatDate(date: Date) {
  return new Date(date).toLocaleDateString('en-KE', {
    day: 'numeric', month: 'long', year: 'numeric'
  })
}
---

<Layout title={`${album.data.title} — Gallery | St. Paul's Mission Hospital`}>

  <!-- Breadcrumb -->
  <div class="bg-surface border-b border-border/60">
    <div class="max-w-7xl mx-auto px-6 lg:px-16 py-3">
      <nav class="flex items-center gap-2 text-[0.6rem] font-semibold tracking-[0.12em] uppercase text-muted/50">
        <a href="/news-and-media" class="hover:text-primary transition-colors duration-200">News & Media</a>
        <span>›</span>
        <a href="/news-and-media/gallery" class="hover:text-primary transition-colors duration-200">Gallery</a>
        <span>›</span>
        <span class="text-muted/30 truncate max-w-[200px]">{album.data.title}</span>
      </nav>
    </div>
  </div>


  <!-- Album header -->
  <header class="bg-white border-b border-border/60">
    <div class="max-w-7xl mx-auto px-6 lg:px-16 py-10">
      <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4">
        <div>
          <span class="text-primary text-[0.6rem] font-bold tracking-[0.2em] uppercase mb-2 block">
            {album.data.category}
          </span>
          <h1 class="font-display text-secondary text-3xl sm:text-4xl font-semibold leading-tight">
            {album.data.title}
          </h1>
        </div>
        <div class="text-right">
          <p class="text-muted/50 text-[0.58rem] tracking-widest uppercase">Date</p>
          <p class="text-secondary text-sm font-semibold mt-0.5">
            {formatDate(new Date(album.data.date))}
          </p>
          <p class="text-muted/40 text-[0.58rem] mt-1">
            {album.data.photos.length} photo{album.data.photos.length !== 1 ? 's' : ''}
          </p>
        </div>
      </div>
    </div>
  </header>


  <!-- Photo grid -->
  <section class="max-w-7xl mx-auto px-6 lg:px-16 py-12">
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3" id="photo-grid">
      {album.data.photos.map((photo, i) => (
        <button
          class="group relative overflow-hidden aspect-square bg-surface-2
                 cursor-pointer focus:outline-none focus:ring-2 focus:ring-primary"
          data-index={i}
          aria-label={photo.caption ?? `Photo ${i + 1}`}
        >
          <img
            src={photo.src}
            alt={photo.caption ?? `Photo ${i + 1} from ${album.data.title}`}
            class="absolute inset-0 w-full h-full object-cover
                   transition-transform duration-500 group-hover:scale-[1.06]"
            loading={i < 8 ? 'eager' : 'lazy'}
          />
          <!-- Hover overlay -->
          <div class="absolute inset-0 bg-secondary/0 group-hover:bg-secondary/30
                      transition-all duration-300 flex items-center justify-center">
            <svg class="size-8 text-white opacity-0 group-hover:opacity-100
                        transition-opacity duration-300 drop-shadow-lg"
                 fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round"
                d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607zM10.5 7.5v6m3-3h-6"/>
            </svg>
          </div>
        </button>
      ))}
    </div>
  </section>


  <!-- Back link -->
  <div class="max-w-7xl mx-auto px-6 lg:px-16 pb-12 border-t border-border/60 pt-8">
    <a href="/news-and-media/gallery"
       class="inline-flex items-center gap-2 text-primary text-xs font-bold
              tracking-[0.1em] uppercase hover:gap-3 transition-all duration-200">
      <svg class="size-3.5 rotate-180" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
      </svg>
      Back to gallery
    </a>
  </div>


  <!-- ════════════════════════════════════
       LIGHTBOX — vanilla JS, no library
  ════════════════════════════════════ -->
  <div id="lightbox"
       class="fixed inset-0 z-[300] bg-black/95 hidden items-center justify-center"
       role="dialog" aria-modal="true" aria-label="Photo lightbox">

    <!-- Close -->
    <button id="lb-close"
            class="absolute top-5 right-5 size-10 flex items-center justify-center
                   text-white/60 hover:text-white hover:bg-white/10
                   transition-all duration-200 z-10"
            aria-label="Close lightbox">
      <svg class="size-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>

    <!-- Prev -->
    <button id="lb-prev"
            class="absolute left-4 top-1/2 -translate-y-1/2 size-11 flex items-center justify-center
                   border border-white/20 text-white/60 hover:text-white hover:bg-white/10
                   transition-all duration-200 z-10"
            aria-label="Previous photo">
      <svg class="size-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
      </svg>
    </button>

    <!-- Next -->
    <button id="lb-next"
            class="absolute right-4 top-1/2 -translate-y-1/2 size-11 flex items-center justify-center
                   border border-white/20 text-white/60 hover:text-white hover:bg-white/10
                   transition-all duration-200 z-10"
            aria-label="Next photo">
      <svg class="size-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
      </svg>
    </button>

    <!-- Image + caption -->
    <div class="flex flex-col items-center gap-4 px-16 max-w-5xl w-full">
      <img id="lb-img" src="" alt=""
           class="max-h-[80vh] max-w-full object-contain shadow-2xl"/>
      <p id="lb-caption"
         class="text-white/50 text-sm text-center max-w-lg leading-relaxed min-h-[1.5rem]">
      </p>
      <p id="lb-counter" class="text-white/25 text-xs tracking-widest uppercase"></p>
    </div>

  </div>

</Layout>


<script define:vars={{ photos: album.data.photos }}>
  (function () {
    const lightbox  = document.getElementById('lightbox')
    const lbImg     = document.getElementById('lb-img')
    const lbCaption = document.getElementById('lb-caption')
    const lbCounter = document.getElementById('lb-counter')
    const lbClose   = document.getElementById('lb-close')
    const lbPrev    = document.getElementById('lb-prev')
    const lbNext    = document.getElementById('lb-next')
    const grid      = document.getElementById('photo-grid')

    let current = 0

    function open(i) {
      current = i
      show()
      lightbox.classList.remove('hidden')
      lightbox.classList.add('flex')
      document.body.style.overflow = 'hidden'
    }

    function close() {
      lightbox.classList.add('hidden')
      lightbox.classList.remove('flex')
      document.body.style.overflow = ''
    }

    function show() {
      const photo = photos[current]
      lbImg.src         = photo.src
      lbImg.alt         = photo.caption ?? `Photo ${current + 1}`
      lbCaption.textContent = photo.caption ?? ''
      lbCounter.textContent = `${current + 1} / ${photos.length}`
      lbPrev.style.opacity = current === 0 ? '0.3' : '1'
      lbNext.style.opacity = current === photos.length - 1 ? '0.3' : '1'
      lbPrev.disabled = current === 0
      lbNext.disabled = current === photos.length - 1
    }

    function prev() { if (current > 0) { current--; show() } }
    function next() { if (current < photos.length - 1) { current++; show() } }

    // Grid click
    grid.querySelectorAll('button[data-index]').forEach(btn => {
      btn.addEventListener('click', () => open(parseInt(btn.dataset.index)))
    })

    // Controls
    lbClose.addEventListener('click', close)
    lbPrev.addEventListener('click', prev)
    lbNext.addEventListener('click', next)

    // Click outside image to close
    lightbox.addEventListener('click', e => {
      if (e.target === lightbox) close()
    })

    // Keyboard navigation
    document.addEventListener('keydown', e => {
      if (lightbox.classList.contains('hidden')) return
      if (e.key === 'Escape')      close()
      if (e.key === 'ArrowLeft')   prev()
      if (e.key === 'ArrowRight')  next()
    })
  })()
</script>