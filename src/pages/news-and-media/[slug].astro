---
import { getCollection } from 'astro:content';
export async function getStaticPaths() {
  const posts = await getCollection('media');
  return posts.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<article class='max-w-3xl mx-auto p-6'>
  <span class='uppercase text-blue-600 font-bold text-sm'
    >{entry.data.category}</span
  >
  <h1 class='text-4xl font-bold my-4'>{entry.data.title}</h1>

  <div class='prose lg:prose-xl'>
    <Content />
  </div>

  {
    entry.data.category === 'press-release' && (
      <div class='mt-10 p-4 bg-gray-100 border-l-4 border-blue-600'>
        <p class='font-bold'>Media Contact</p>
        <p>For inquiries, email the team at info@stpauls.org</p>
      </div>
    )
  }
</article>
