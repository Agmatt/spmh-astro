---
export const prerender = true


import Layout from '../../../Layout/Layout.astro';
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';

/**
 * Individual Event Page
 * File placement: src/pages/news-and-media/events/[slug].astro
 */

export const getStaticPaths: GetStaticPaths = async () => {
  const events = await getCollection('events', ({ data }) => !data.draft);
  return events.map((event) => ({
    params: { slug: event.slug },
    props: { event },
  }));
};

const { event } = Astro.props;
const { Content } = await render(event);

const today = new Date();
today.setHours(0, 0, 0, 0);
const isPast = new Date(event.data.date) < today;

function formatDate(date: Date) {
  return date.toLocaleDateString('en-KE', {
    weekday: 'long',
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });
}

// Related — same category, exclude current
const allEvents = await getCollection('events', ({ data }) => !data.draft);
const related = allEvents
  .filter(
    (e) => e.slug !== event.slug && e.data.category === event.data.category,
  )
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<Layout title={`${event.data.title} | St. Paul's Mission Hospital`}>
  <!-- Breadcrumb -->
  <div class='bg-surface border-b border-border/60'>
    <div class='max-w-4xl mx-auto px-6 lg:px-8 py-3'>
      <nav
        class='flex items-center gap-2 text-[0.6rem] font-semibold tracking-[0.12em] uppercase text-muted/50'>
        <a
          href='/news-and-media'
          class='hover:text-primary transition-colors duration-200'
          >News & Media</a
        >
        <span>›</span>
        <a
          href='/news-and-media/events'
          class='hover:text-primary transition-colors duration-200'>Events</a
        >
        <span>›</span>
        <span class='text-muted/30 truncate max-w-[200px]'
          >{event.data.title}</span
        >
      </nav>
    </div>
  </div>

  <!-- Event header -->
  <header class='bg-white border-b border-border/60'>
    <div class='max-w-4xl mx-auto px-6 lg:px-8 py-10 lg:py-14'>
      <div class='flex items-center gap-3 mb-4'>
        <span
          class='text-primary text-[0.6rem] font-bold tracking-[0.2em] uppercase'>
          {event.data.category}
        </span>
        {
          isPast && (
            <span class='bg-surface-2 text-muted text-[0.58rem] font-bold tracking-[0.14em] uppercase px-2.5 py-1'>
              Past Event
            </span>
          )
        }
        {
          !isPast && (
            <span class='bg-primary/10 text-primary text-[0.58rem] font-bold tracking-[0.14em] uppercase px-2.5 py-1'>
              Upcoming
            </span>
          )
        }
      </div>

      <h1
        class='font-display text-secondary text-3xl sm:text-4xl lg:text-5xl font-semibold
                 leading-tight mb-6'>
        {event.data.title}
      </h1>

      <p class='text-muted text-base leading-relaxed max-w-2xl mb-8 italic'>
        {event.data.excerpt}
      </p>

      <!-- Event meta -->
      <div class='grid sm:grid-cols-3 gap-4'>
        <div class='bg-surface border border-border/60 px-4 py-4'>
          <div class='flex items-center gap-2 mb-1'>
            <svg
              class='size-3.5 text-primary shrink-0'
              fill='none'
              stroke='currentColor'
              stroke-width='2'
              viewBox='0 0 24 24'>
              <path
                stroke-linecap='round'
                stroke-linejoin='round'
                d='M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 9v7.5'
              ></path>
            </svg>
            <p
              class='text-muted/50 text-[0.58rem] tracking-widest uppercase font-semibold'>
              Date
            </p>
          </div>
          <p class='text-secondary text-xs font-semibold leading-snug'>
            {formatDate(event.data.date)}
          </p>
        </div>

        <div class='bg-surface border border-border/60 px-4 py-4'>
          <div class='flex items-center gap-2 mb-1'>
            <svg
              class='size-3.5 text-primary shrink-0'
              fill='none'
              stroke='currentColor'
              stroke-width='2'
              viewBox='0 0 24 24'>
              <path
                stroke-linecap='round'
                stroke-linejoin='round'
                d='M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z'></path>
            </svg>
            <p
              class='text-muted/50 text-[0.58rem] tracking-widest uppercase font-semibold'>
              Time
            </p>
          </div>
          <p class='text-secondary text-xs font-semibold'>{event.data.time}</p>
        </div>

        <div class='bg-surface border border-border/60 px-4 py-4'>
          <div class='flex items-center gap-2 mb-1'>
            <svg
              class='size-3.5 text-primary shrink-0'
              fill='none'
              stroke='currentColor'
              stroke-width='2'
              viewBox='0 0 24 24'>
              <path
                stroke-linecap='round'
                stroke-linejoin='round'
                d='M15 10.5a3 3 0 11-6 0 3 3 0 016 0zM19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z'
              ></path>
            </svg>
            <p
              class='text-muted/50 text-[0.58rem] tracking-widest uppercase font-semibold'>
              Location
            </p>
          </div>
          <p class='text-secondary text-xs font-semibold leading-snug'>
            {event.data.location}
          </p>
        </div>
      </div>
    </div>
  </header>

  <!-- Featured image -->
  {
    event.data.image && (
      <div class='max-w-4xl mx-auto px-6 lg:px-8 py-8'>
        <div class='overflow-hidden aspect-[16/9]'>
          <img
            src={event.data.image}
            alt={event.data.title}
            class={`w-full h-full object-cover ${isPast ? 'grayscale' : ''}`}
            loading='eager'
          />
        </div>
      </div>
    )
  }

  <!-- Event body -->
  <article class='max-w-4xl mx-auto px-6 lg:px-8 pb-16'>
    <div
      class='prose prose-lg max-w-none
                prose-headings:font-display prose-headings:text-secondary
                prose-h2:text-2xl prose-h3:text-xl
                prose-p:text-muted prose-p:leading-relaxed
                prose-a:text-primary prose-a:no-underline hover:prose-a:underline
                prose-strong:text-secondary
                prose-ul:text-muted prose-li:text-muted
                prose-blockquote:border-primary prose-blockquote:text-muted'>
      <Content />
    </div>
  </article>

  <!-- Related events -->
  {
    related.length > 0 && (
      <section class='bg-surface border-t border-border/60 py-12 lg:py-16'>
        <div class='max-w-7xl mx-auto px-6 lg:px-16'>
          <p class='text-primary text-xs tracking-[0.22em] uppercase font-semibold mb-3 flex items-center gap-3'>
            <span class='w-8 h-px bg-primary inline-block' />
            More {event.data.category} events
          </p>
          <h2 class='font-display text-secondary text-2xl font-normal leading-snug mb-8'>
            Related{' '}
            <span class='font-semibold italic text-primary'>events.</span>
          </h2>
          <div class='grid sm:grid-cols-2 lg:grid-cols-3 gap-5'>
            {related.map((rel) => (
              <a
                href={`/news-and-media/events/${rel.slug}`}
                class='group flex flex-col bg-white border border-border/60
                      hover:border-primary/30 hover:shadow-md transition-all duration-300'>
                {rel.data.image && (
                  <div class='overflow-hidden aspect-[16/10]'>
                    <img
                      src={rel.data.image}
                      alt={rel.data.title}
                      class='w-full h-full object-cover transition-transform duration-700
                           group-hover:scale-[1.03]'
                      loading='lazy'
                    />
                  </div>
                )}
                <div class='p-5'>
                  <span class='text-primary text-[0.58rem] font-bold tracking-[0.18em] uppercase'>
                    {rel.data.category}
                  </span>
                  <h3
                    class='font-display text-secondary font-semibold text-sm leading-snug mt-1.5
                           group-hover:text-primary transition-colors duration-200'>
                    {rel.data.title}
                  </h3>
                  <p class='text-muted/50 text-[0.6rem] mt-3'>
                    {formatDate(rel.data.date)}
                  </p>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <!-- Back link -->
  <div class='max-w-7xl mx-auto px-6 lg:px-16 py-8 border-t border-border/60'>
    <a
      href='/news-and-media/events'
      class='inline-flex items-center gap-2 text-primary text-xs font-bold
              tracking-[0.1em] uppercase hover:gap-3 transition-all duration-200'>
      <svg
        class='size-3.5 rotate-180'
        fill='none'
        stroke='currentColor'
        stroke-width='2.5'
        viewBox='0 0 24 24'>
        <path
          stroke-linecap='round'
          stroke-linejoin='round'
          d='M17 8l4 4m0 0l-4 4m4-4H3'></path>
      </svg>
      Back to all events
    </a>
  </div>
</Layout>
