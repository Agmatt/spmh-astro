---
import Layout from '../Layout/Layout.astro';
import Carousel from '../components/Carousel.jsx';
import IntroBand from '../components/IntroBand.astro';
import AboutSection from '../components/AboutSection.astro';
import ServicesGrid from '../components/ServicesGrid.astro';
import StatsBar from '../components/StatsBar.astro';
import AppointmentCTA from '../components/AppointmentCTA.astro';
import FeaturedServices from '../react-islands/FeaturedServices.tsx'; // .tsx — no extension needed
import LatestDevelopments from '../components/LatestDevelopments.astro';
---

<Layout title="St Paul's Mission Hospital">
  <Carousel client:load />
  <IntroBand />
  <AboutSection />
  <ServicesGrid />
  <FeaturedServices client:visible />
  <StatsBar />
  <LatestDevelopments />
  <AppointmentCTA />
</Layout>
