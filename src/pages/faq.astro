---
import Layout from '../Layout/Layout.astro';

const faqs = [
  {
    q: "How do I book an appointment?",
    a: "You can book an appointment using our online booking form — tap 'Book an Appointment' anywhere on the site. You can also reach us directly on WhatsApp using the green button at the bottom-right of your screen, or call us on +254 111 817447 during working hours (Mon – Sat, 8 am – 5 pm).",
  },
  {
    q: "What are your visiting hours?",
    a: "General visiting hours are 10:00 am – 12:00 pm and 4:00 pm – 6:00 pm daily. Some wards — including the Maternity Unit and Newborn Unit — have specific visiting arrangements. Please check with the ward in advance or ask at reception on arrival.",
  },
  {
    q: "Do you have a 24-hour Emergency Unit?",
    a: "Yes. Our Emergency & Trauma Unit is open 24 hours a day, every day of the year — including public holidays. No appointment or referral is needed. Walk in and you will be triaged immediately.",
  },
  {
    q: "What insurance and payment options do you accept?",
    a: "We are accredited by the Social Health Authority (SHA) and accept SHA cover for eligible inpatient and outpatient services. We also work with a range of NHIF-affiliated and private insurance providers. For cash payments and billing queries, please speak to our Patient Affairs team at the front desk.",
  },
  {
    q: "Is there maternity care available at St. Paul's?",
    a: "Yes. Our Maternity & Newborn Unit provides full antenatal, delivery, and postnatal care. We also have a dedicated Newborn Unit for babies requiring additional support after birth. To book an antenatal visit, use our appointment form or contact us on WhatsApp.",
  },
  {
    q: "What is the Comprehensive Care Centre (CCC)?",
    a: "The CCC provides integrated, confidential HIV/AIDS services — including voluntary counselling and testing (VCT), antiretroviral therapy (ART), nutritional support, and long-term management. All services are handled with complete dignity and discretion. No referral is required to access the CCC.",
  },
  {
    q: "Where are you located?",
    a: "St. Paul's Mission Hospital is located at 426 Gov. Cyprian Awiti Street, Homa Bay, Kenya. We are a short distance from the Homa Bay town centre. If you need directions, please call us on +254 111 817447 and our team will assist you.",
  },
  {
    q: "Do you offer physiotherapy and rehabilitation?",
    a: "Yes. Our Physiotherapy & Rehabilitation department provides evidence-based treatment to help patients recover movement, strength, and independence following illness, injury, or surgery. Appointments can be booked through our standard booking channels.",
  },
]
---

<Layout title='FAQ'>
<section id="faq" class="py-20 lg:py-28 bg-surface overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 lg:px-10">

    <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start">

      <!-- ── LEFT: header + contact nudge ── -->
      <div class="lg:col-span-4 lg:sticky lg:top-28">

        <!-- Eyebrow -->
        <div class="flex items-center gap-3 mb-5">
          <p class="text-primary text-xs tracking-[0.22em] uppercase font-semibold">
            FAQ
          </p>
          <div class="h-px w-10 bg-primary/30"></div>
        </div>

        <h2 class="font-display text-secondary text-3xl sm:text-4xl lg:text-[2.6rem] font-normal leading-snug mb-5">
          Questions we<br/>
          <span class="font-semibold italic text-primary">hear often.</span>
        </h2>

        <p class="text-muted text-sm leading-relaxed mb-8">
          If you don't find what you're looking for here, our team is happy to help — by phone, WhatsApp, or in person.
        </p>

        <!-- Contact nudge card -->
        <a
          href="/about-us/contact"
          class="group flex flex-col gap-3 p-6 bg-surface border border-border/60
                 hover:border-primary/30 hover:shadow-md hover:shadow-primary/5
                 transition-all duration-200"
        >
          <div class="size-10 bg-primary/10 flex items-center justify-center
                      group-hover:bg-primary transition-colors duration-300">
            <svg class="size-5 text-primary group-hover:text-white transition-colors duration-300"
                 fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round"
                d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/>
            </svg>
          </div>
          <div>
            <p class="text-secondary font-semibold text-sm mb-0.5">Still have a question?</p>
            <p class="text-muted text-xs leading-relaxed">
              Reach our team directly — we'll get back to you as soon as possible.
            </p>
          </div>
          <div class="flex items-center gap-2 text-primary text-xs font-semibold">
            Contact us
            <svg class="size-3.5 group-hover:translate-x-1 transition-transform duration-200"
                 fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </div>
        </a>

        <!-- Emergency note -->
        <div class="flex items-center gap-2.5 mt-6">
          <span class="relative flex size-2 shrink-0">
            <span class="absolute inline-flex size-full rounded-full bg-accent/70 animate-ping"></span>
            <span class="relative inline-flex size-2 rounded-full bg-accent"></span>
          </span>
          <p class="text-muted text-xs">
            Emergency?
            <span class="text-secondary font-semibold">Walk in — we're open 24 / 7.</span>
          </p>
        </div>

      </div>

      <!-- ── RIGHT: accordion ── -->
      <div
        class="lg:col-span-8"
        x-data="{ open: null }"
      >
        <div class="divide-y divide-border/60 border-y border-border/60">

          {faqs.map((faq, i) => (
            <div>
              <!-- Question button -->
              <button
                @click={`open = open === ${i} ? null : ${i}`}
                class="w-full flex items-start justify-between gap-4 py-5 text-left
                       group cursor-pointer focus:outline-none"
                :aria-expanded={`open === ${i}`}
              >
                <span
                  class="text-secondary font-semibold text-sm sm:text-base leading-snug
                         group-hover:text-primary transition-colors duration-200"
                  :class={`open === ${i} ? 'text-primary' : ''`}
                >
                  {faq.q}
                </span>

                <!-- +/– icon -->
                <span
                  class="size-6 rounded-full border border-border/70 flex items-center
                         justify-center shrink-0 mt-0.5 transition-all duration-300
                         group-hover:border-primary/40 group-hover:bg-primary/5"
                  :class={`open === ${i} ? 'bg-primary border-primary rotate-45' : ''`}
                >
                  <svg
                    class="size-3 text-muted transition-colors duration-200"
                    :class={`open === ${i} ? 'text-white' : 'group-hover:text-primary'`}
                    fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
                  </svg>
                </span>
              </button>

              <!-- Answer panel -->
              <div
                x-show={`open === ${i}`}
                x-transition:enter="transition duration-300 ease-out"
                x-transition:enter-start="opacity-0 -translate-y-1"
                x-transition:enter-end="opacity-100 translate-y-0"
                x-transition:leave="transition duration-150 ease-in"
                x-transition:leave-start="opacity-100"
                x-transition:leave-end="opacity-0"
                x-cloak
              >
                <div class="pb-5 pr-10">
                  <p class="text-muted text-sm leading-relaxed">
                    {faq.a}
                  </p>
                </div>
              </div>
            </div>
          ))}

        </div>

        <!-- Item count -->
        <p class="text-border text-[0.65rem] tracking-widest uppercase mt-5 text-right">
          {faqs.length} frequently asked questions
        </p>

      </div>

    </div>

  </div>
</section>
</Layout>
