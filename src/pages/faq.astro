---
import Layout from '../Layout/Layout.astro';

const faqCategories = [
  {
    title: "Getting Care",
    icon: "M12 8v4l3 1.5m6-3a9 9 0 11-18 0 9 9 0 0118 0z",
    accentColor: "text-[#1565c0]",
    faqs: [
      {
        q: "How do I book an appointment?",
        a: "You can book an appointment using our online booking form — tap 'Book an Appointment' anywhere on the site. You can also reach us directly by calling +254 111 817447 during working hours (Mon – Sat, 8 am – 5 pm).",
      },
      {
        q: "What are your visiting hours?",
        a: "General visiting hours are 10:00 am – 12:00 pm and 4:00 pm – 6:00 pm daily. Some wards — including the Maternity Unit and Newborn Unit — have specific visiting arrangements. Please check with the ward in advance or ask at reception on arrival.",
      },
      {
        q: "What insurance and payment options do you accept?",
        a: "We are accredited by the Social Health Authority (SHA) and accept SHA cover for eligible inpatient and outpatient services. We also work with a range of NHIF-affiliated and private insurance providers. For cash payments and billing queries, please speak to our Patient Affairs team at the front desk.",
      },
    ],
  },
  {
    title: "Our Services",
    icon: "M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4",
    accentColor: "text-[#125276]",
    faqs: [
      {
        q: "Is there maternity care available at St. Paul's?",
        a: "Yes. Our Maternity & Newborn Unit provides full antenatal, delivery, and postnatal care. We also have a dedicated Newborn Unit for babies requiring additional support after birth. To book an antenatal visit, use our appointment form or contact us directly.",
      },
      {
        q: "What is the Comprehensive Care Centre (CCC)?",
        a: "The CCC provides integrated, confidential HIV/AIDS services — including voluntary counselling and testing (VCT), antiretroviral therapy (ART), nutritional support, and long-term management. All services are handled with complete dignity and discretion. No referral is required to access the CCC.",
      },
      {
        q: "Do you offer physiotherapy and rehabilitation?",
        a: "Yes. Our Physiotherapy & Rehabilitation department provides evidence-based treatment to help patients recover movement, strength, and independence following illness, injury, or surgery. Appointments can be booked through our standard booking channels.",
      },
    ],
  },
  {
    title: "Emergency & Urgent Care",
    icon: "M12 8v4m0 4v.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z",
    accentColor: "text-[#860f0f]",
    faqs: [
      {
        q: "Do you have a 24-hour Emergency Unit?",
        a: "Yes. Our Emergency & Trauma Unit is open 24 hours a day, every day of the year — including public holidays. No appointment or referral is needed. Walk in and you will be triaged immediately.",
      },
      {
        q: "What should I do in a medical emergency?",
        a: "Call our emergency hotline immediately at +254 111 817447, or walk directly to our Emergency & Trauma Unit at any time. Our team is ready to provide immediate care.",
      },
    ],
  },
  {
    title: "Location & Access",
    icon: "M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z",
    accentColor: "text-[#1565c0]",
    faqs: [
      {
        q: "Where are you located?",
        a: "St. Paul's Mission Hospital is located at P.O Box 426, Gov. Cyprian Awiti Street, Homa Bay, Kenya. We are a short distance from the Homa Bay town centre. If you need directions, call us on +254 111 817447 and our team will assist you.",
      },
      {
        q: "Is parking available?",
        a: "Yes, we have dedicated parking for patients and visitors. Parking is free of charge. Ask our reception team for assistance if needed.",
      },
    ],
  },
]
---

<Layout title="FAQ">
  <main class="bg-white">
    <!-- ── HEADER ── -->
    <header class="bg-white border-b border-[#c5d8f7]">
      <div class="container mx-auto max-w-6xl px-6 lg:px-8 py-12 lg:py-16">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-1 h-8 bg-[#1565c0]"></div>
          <h1 class="text-4xl lg:text-5xl font-black text-[#125276] tracking-tight">
            Frequently Asked Questions
          </h1>
        </div>
        <p class="text-[#5a6f8c] text-lg max-w-2xl">
          Find answers about appointments, services, emergency care, and how to reach us. If you need more help, contact our team directly.
        </p>
      </div>
    </header>

    <!-- ── FAQ SECTIONS ── -->
    <section class="container mx-auto max-w-6xl px-6 lg:px-8 py-16 lg:py-20">
      <div class="space-y-16">
        {faqCategories.map((category, catIdx) => (
          <div>
            <!-- Category Title -->
            <div class="mb-8 flex items-center gap-3">
              <svg class={`w-6 h-6 ${category.accentColor}`} fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d={category.icon}/>
              </svg>
              <h2 class={`text-2xl font-bold ${category.accentColor}`}>
                {category.title}
              </h2>
            </div>

            <!-- FAQs for this category -->
            <div
              class="divide-y divide-[#c5d8f7]"
              x-data={`{ open: ${catIdx === 0 ? '0' : 'null'} }`}
            >
              {category.faqs.map((faq, idx) => (
                <div>
                  <!-- Question Button -->
                  <button
                    @click={`open = open === ${idx} ? null : ${idx}`}
                    class="w-full flex items-start justify-between gap-4 py-5 text-left
                           hover:bg-[#f4f8ff] transition-colors duration-200 focus:outline-none"
                    :aria-expanded={`open === ${idx}`}
                  >
                    <span class="text-[#125276] font-semibold text-base leading-snug flex-1">
                      {faq.q}
                    </span>

                    <!-- Plus/Minus Icon -->
                    <span class="size-6 flex items-center justify-center shrink-0 mt-0.5">
                      <svg
                        class="size-5 text-[#5a6f8c] transition-transform duration-300"
                        :class={`open === ${idx} ? 'rotate-45' : ''`}
                        fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"
                      >
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
                      </svg>
                    </span>
                  </button>

                  <!-- Answer Panel -->
                  <div
                    x-show={`open === ${idx}`}
                    x-transition:enter="transition duration-200"
                    x-transition:enter-start="opacity-0 -translate-y-1"
                    x-transition:enter-end="opacity-100 translate-y-0"
                    x-transition:leave="transition duration-150"
                    x-transition:leave-start="opacity-100"
                    x-transition:leave-end="opacity-0"
                    style="display:none"
                    class="py-5 pr-10"
                  >
                    <p class="text-[#5a6f8c] text-base leading-relaxed">
                      {faq.a}
                    </p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- ── CTA SECTION ── -->
    <section class="bg-[#f4f8ff] border-t border-b border-[#c5d8f7]">
      <div class="container mx-auto max-w-6xl px-6 lg:px-8 py-12 lg:py-16">
        <div class="max-w-2xl">
          <h3 class="text-2xl font-bold text-[#125276] mb-3">
            Still have a question?
          </h3>
          <p class="text-[#5a6f8c] text-base mb-6">
            Our team is ready to help. Reach us by phone, email, or contact form.
          </p>
          <a
            href="/about-us/contact"
            class="inline-flex items-center gap-2 px-6 py-3 bg-[#1565c0] text-white font-semibold
                   hover:bg-[#0d47a1] transition-colors duration-200"
          >
            Contact Us
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
        </div>
      </div>
    </section>    
  </main>
</Layout>