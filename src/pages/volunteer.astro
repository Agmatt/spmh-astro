---
import '../styles/global.css';
import VolunteerForm from '../react-islands/VolunteerForm';
---

<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>Volunteer — SPMH Outreach</title>
  </head>
  <body class='font-sans antialiased text-gray-900 overflow-x-hidden'>
    <!-- ══════════════════════════════════════════
       HERO
  ══════════════════════════════════════════ -->
    <section
      class='relative min-h-[380px] flex items-center justify-center text-center px-6 py-24'
      style="background: linear-gradient(rgba(10,25,55,0.62), rgba(10,25,55,0.68)), url('https://images.unsplash.com/photo-1559027615-cd4628902d4a?w=1400&q=80') center/cover no-repeat;">
      <div class='max-w-2xl mx-auto'>
        <div
          class='inline-flex items-center gap-2 bg-orange-500/20 border border-orange-400/40 text-orange-300 text-sm font-semibold px-4 py-1.5 rounded-full mb-5'>
          <!-- Heroicon: hand-raised -->
          <svg
            xmlns='http://www.w3.org/2000/svg'
            viewBox='0 0 24 24'
            fill='currentColor'
            class='w-4 h-4'>
            <path
              d='M10.5 1.5a.75.75 0 0 1 .75.75V4.5a.75.75 0 0 1-1.5 0V2.25a.75.75 0 0 1 .75-.75ZM5.628 5.165a.75.75 0 0 1 0 1.061l-1.5 1.5a.75.75 0 1 1-1.06-1.061l1.5-1.5a.75.75 0 0 1 1.06 0ZM2.25 10.5a.75.75 0 0 1 .75-.75h1.5a.75.75 0 0 1 0 1.5H3a.75.75 0 0 1-.75-.75Zm12.47-5.335a.75.75 0 0 1 1.06 0l1.5 1.5a.75.75 0 1 1-1.06 1.06l-1.5-1.5a.75.75 0 0 1 0-1.06ZM21 10.5a.75.75 0 0 1-.75.75h-1.5a.75.75 0 0 1 0-1.5h1.5a.75.75 0 0 1 .75.75Z'
            ></path>
          </svg>
          Join Our Volunteer Team
        </div>
        <h1
          class='text-4xl md:text-5xl font-extrabold text-white leading-tight mb-4'>
          Make a Difference in Your Community
        </h1>
        <p class='text-lg text-white/80'>
          Your time and skills can transform lives. Sign up to volunteer with
          SPMH Outreach and be part of something meaningful.
        </p>
      </div>

      <!-- wave bottom -->
      <!-- <div
        class='absolute bottom-0 left-0 right-0 overflow-hidden leading-none'>
        <svg
          viewBox='0 0 1440 50'
          xmlns='http://www.w3.org/2000/svg'
          preserveAspectRatio='none'
          class='w-full h-10 block'>
          <path d='M0,25 C480,50 960,0 1440,25 L1440,50 L0,50 Z' fill='#fdf6ee'
          ></path>
        </svg>
      </div> -->
    </section>

    <!-- ══════════════════════════════════════════
       WHY VOLUNTEER — 3 QUICK REASONS
  ══════════════════════════════════════════ -->
    <section class='bg-[#fdf6ee] px-4 md:px-6 py-16'>
      <div class='max-w-5xl mx-auto'>
        <h2 class='text-center text-2xl font-bold text-blue-900 mb-2'>
          Why Volunteer With Us?
        </h2>
        <div class='flex justify-center mb-10'>
          <div class='w-14 h-1 bg-orange-500 rounded'></div>
        </div>

        <div class='grid sm:grid-cols-3 gap-6'>
          <div class='bg-white rounded-2xl p-7 text-center shadow-sm'>
            <div
              class='inline-flex items-center justify-center w-12 h-12 rounded-full bg-orange-100 mb-4'>
              <!-- Heroicon: globe-alt -->
              <svg
                xmlns='http://www.w3.org/2000/svg'
                viewBox='0 0 24 24'
                fill='currentColor'
                class='w-6 h-6 text-orange-500'>
                <path
                  d='M21.721 12.752a9.711 9.711 0 0 0-.945-5.003 12.754 12.754 0 0 1-4.339 2.708 18.991 18.991 0 0 1-.214 4.772 17.165 17.165 0 0 0 5.498-2.477ZM14.634 15.55a17.324 17.324 0 0 0 .332-4.647c-.952.227-1.945.347-2.966.347-1.021 0-2.014-.12-2.966-.347a17.515 17.515 0 0 0 .332 4.647 17.385 17.385 0 0 0 5.268 0ZM9.772 17.119a18.963 18.963 0 0 0 4.456 0A17.182 17.182 0 0 1 12 21.724a17.18 17.18 0 0 1-2.228-4.605ZM7.777 15.23a18.87 18.87 0 0 1-.214-4.774 12.753 12.753 0 0 1-4.34-2.708 9.711 9.711 0 0 0-.944 5.004 17.165 17.165 0 0 0 5.498 2.477ZM21.356 14.752a9.765 9.765 0 0 1-7.478 6.817 18.64 18.64 0 0 0 1.988-4.718 18.627 18.627 0 0 0 5.49-2.098ZM2.644 14.752c1.682.971 3.53 1.688 5.49 2.099a18.64 18.64 0 0 0 1.988 4.718 9.765 9.765 0 0 1-7.478-6.816ZM13.878 2.43a9.755 9.755 0 0 1 6.116 3.986 11.267 11.267 0 0 1-3.746 2.504 18.63 18.63 0 0 0-2.37-6.49ZM12 2.276a17.152 17.152 0 0 1 2.805 7.121c-.897.23-1.837.353-2.805.353-.968 0-1.908-.122-2.805-.353A17.151 17.151 0 0 1 12 2.276ZM10.122 2.43a18.629 18.629 0 0 0-2.37 6.49 11.266 11.266 0 0 1-3.746-2.504 9.754 9.754 0 0 1 6.116-3.985Z'
                ></path>
              </svg>
            </div>
            <h3 class='font-bold text-gray-800 mb-2'>Community Impact</h3>
            <p class='text-sm text-gray-500 leading-relaxed'>
              Directly improve lives in underserved areas across the Diocese of
              Homa Bay.
            </p>
          </div>

          <div class='bg-white rounded-2xl p-7 text-center shadow-sm'>
            <div
              class='inline-flex items-center justify-center w-12 h-12 rounded-full bg-orange-100 mb-4'>
              <!-- Heroicon: academic-cap -->
              <svg
                xmlns='http://www.w3.org/2000/svg'
                viewBox='0 0 24 24'
                fill='currentColor'
                class='w-6 h-6 text-orange-500'>
                <path
                  d='M11.7 2.805a.75.75 0 0 1 .6 0A60.65 60.65 0 0 1 22.83 8.72a.75.75 0 0 1-.231 1.337 49.948 49.948 0 0 0-9.902 3.912l-.003.002c-.114.06-.227.119-.34.18a.75.75 0 0 1-.707 0A50.88 50.88 0 0 0 7.5 12.173v-.224c0-.131.067-.248.172-.311a54.615 54.615 0 0 1 4.653-2.52.75.75 0 0 0-.65-1.352 56.123 56.123 0 0 0-4.78 2.589 1.858 1.858 0 0 0-.859 1.228 49.803 49.803 0 0 0-4.634-1.527.75.75 0 0 1-.231-1.337A60.653 60.653 0 0 1 11.7 2.805Z'
                ></path>
                <path
                  d='M13.06 15.473a48.45 48.45 0 0 1 7.666-3.282c.134 1.414.22 2.843.255 4.284a.75.75 0 0 1-.46.711 47.87 47.87 0 0 0-8.105 4.342.75.75 0 0 1-.832 0 47.87 47.87 0 0 0-8.104-4.342.75.75 0 0 1-.461-.71c.035-1.442.121-2.87.255-4.286.921.304 1.83.634 2.726.99v1.27a1.5 1.5 0 0 0-.14 2.508c-.09.38-.222.753-.397 1.11.452.213.901.434 1.346.66a6.727 6.727 0 0 0 .551-1.608 1.5 1.5 0 0 0 .14-2.67v-.645a48.549 48.549 0 0 1 3.44 1.667 2.25 2.25 0 0 0 2.12 0Z'
                ></path>
              </svg>
            </div>
            <h3 class='font-bold text-gray-800 mb-2'>Grow Your Skills</h3>
            <p class='text-sm text-gray-500 leading-relaxed'>
              Gain hands-on experience in healthcare outreach, logistics, and
              community engagement.
            </p>
          </div>

          <div class='bg-white rounded-2xl p-7 text-center shadow-sm'>
            <div
              class='inline-flex items-center justify-center w-12 h-12 rounded-full bg-orange-100 mb-4'>
              <!-- Heroicon: heart -->
              <svg
                xmlns='http://www.w3.org/2000/svg'
                viewBox='0 0 24 24'
                fill='currentColor'
                class='w-6 h-6 text-orange-500'>
                <path
                  d='m11.645 20.91-.007-.003-.022-.012a15.247 15.247 0 0 1-.383-.218 25.18 25.18 0 0 1-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0 1 12 5.052 5.5 5.5 0 0 1 16.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 0 1-4.244 3.17 15.247 15.247 0 0 1-.383.219l-.022.012-.007.004-.003.001a.752.752 0 0 1-.704 0l-.003-.001Z'
                ></path>
              </svg>
            </div>
            <h3 class='font-bold text-gray-800 mb-2'>Faith in Action</h3>
            <p class='text-sm text-gray-500 leading-relaxed'>
              Live out the mission of compassionate service rooted in Catholic
              social teaching.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
       VOLUNTEER FORM
  ══════════════════════════════════════════ -->
    <VolunteerForm client:load />
  </body>
</html>
