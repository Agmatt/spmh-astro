---
import '../styles/global.css';
---

<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>Volunteer — SPMH Outreach</title>
  </head>
  <body class='font-sans antialiased text-gray-900 overflow-x-hidden'>
    <!-- ══════════════════════════════════════════
       HERO
  ══════════════════════════════════════════ -->
    <section
      class='relative min-h-[380px] flex items-center justify-center text-center px-6 py-24'
      style="background: linear-gradient(rgba(10,25,55,0.62), rgba(10,25,55,0.68)), url('https://images.unsplash.com/photo-1559027615-cd4628902d4a?w=1400&q=80') center/cover no-repeat;">
      <div class='max-w-2xl mx-auto'>
        <div
          class='inline-flex items-center gap-2 bg-orange-500/20 border border-orange-400/40 text-orange-300 text-sm font-semibold px-4 py-1.5 rounded-full mb-5'>
          <!-- Heroicon: hand-raised -->
          <svg
            xmlns='http://www.w3.org/2000/svg'
            viewBox='0 0 24 24'
            fill='currentColor'
            class='w-4 h-4'>
            <path
              d='M10.5 1.5a.75.75 0 0 1 .75.75V4.5a.75.75 0 0 1-1.5 0V2.25a.75.75 0 0 1 .75-.75ZM5.628 5.165a.75.75 0 0 1 0 1.061l-1.5 1.5a.75.75 0 1 1-1.06-1.061l1.5-1.5a.75.75 0 0 1 1.06 0ZM2.25 10.5a.75.75 0 0 1 .75-.75h1.5a.75.75 0 0 1 0 1.5H3a.75.75 0 0 1-.75-.75Zm12.47-5.335a.75.75 0 0 1 1.06 0l1.5 1.5a.75.75 0 1 1-1.06 1.06l-1.5-1.5a.75.75 0 0 1 0-1.06ZM21 10.5a.75.75 0 0 1-.75.75h-1.5a.75.75 0 0 1 0-1.5h1.5a.75.75 0 0 1 .75.75Z'
            ></path>
          </svg>
          Join Our Volunteer Team
        </div>
        <h1
          class='text-4xl md:text-5xl font-extrabold text-white leading-tight mb-4'>
          Make a Difference in Your Community
        </h1>
        <p class='text-lg text-white/80'>
          Your time and skills can transform lives. Sign up to volunteer with
          SPMH Outreach and be part of something meaningful.
        </p>
      </div>

      <!-- wave bottom -->
      <!-- <div
        class='absolute bottom-0 left-0 right-0 overflow-hidden leading-none'>
        <svg
          viewBox='0 0 1440 50'
          xmlns='http://www.w3.org/2000/svg'
          preserveAspectRatio='none'
          class='w-full h-10 block'>
          <path d='M0,25 C480,50 960,0 1440,25 L1440,50 L0,50 Z' fill='#fdf6ee'
          ></path>
        </svg>
      </div> -->
    </section>

    <!-- ══════════════════════════════════════════
       WHY VOLUNTEER — 3 QUICK REASONS
  ══════════════════════════════════════════ -->
    <section class='bg-[#fdf6ee] px-4 md:px-6 py-16'>
      <div class='max-w-5xl mx-auto'>
        <h2 class='text-center text-2xl font-bold text-blue-900 mb-2'>
          Why Volunteer With Us?
        </h2>
        <div class='flex justify-center mb-10'>
          <div class='w-14 h-1 bg-orange-500 rounded'></div>
        </div>

        <div class='grid sm:grid-cols-3 gap-6'>
          <div class='bg-white rounded-2xl p-7 text-center shadow-sm'>
            <div
              class='inline-flex items-center justify-center w-12 h-12 rounded-full bg-orange-100 mb-4'>
              <!-- Heroicon: globe-alt -->
              <svg
                xmlns='http://www.w3.org/2000/svg'
                viewBox='0 0 24 24'
                fill='currentColor'
                class='w-6 h-6 text-orange-500'>
                <path
                  d='M21.721 12.752a9.711 9.711 0 0 0-.945-5.003 12.754 12.754 0 0 1-4.339 2.708 18.991 18.991 0 0 1-.214 4.772 17.165 17.165 0 0 0 5.498-2.477ZM14.634 15.55a17.324 17.324 0 0 0 .332-4.647c-.952.227-1.945.347-2.966.347-1.021 0-2.014-.12-2.966-.347a17.515 17.515 0 0 0 .332 4.647 17.385 17.385 0 0 0 5.268 0ZM9.772 17.119a18.963 18.963 0 0 0 4.456 0A17.182 17.182 0 0 1 12 21.724a17.18 17.18 0 0 1-2.228-4.605ZM7.777 15.23a18.87 18.87 0 0 1-.214-4.774 12.753 12.753 0 0 1-4.34-2.708 9.711 9.711 0 0 0-.944 5.004 17.165 17.165 0 0 0 5.498 2.477ZM21.356 14.752a9.765 9.765 0 0 1-7.478 6.817 18.64 18.64 0 0 0 1.988-4.718 18.627 18.627 0 0 0 5.49-2.098ZM2.644 14.752c1.682.971 3.53 1.688 5.49 2.099a18.64 18.64 0 0 0 1.988 4.718 9.765 9.765 0 0 1-7.478-6.816ZM13.878 2.43a9.755 9.755 0 0 1 6.116 3.986 11.267 11.267 0 0 1-3.746 2.504 18.63 18.63 0 0 0-2.37-6.49ZM12 2.276a17.152 17.152 0 0 1 2.805 7.121c-.897.23-1.837.353-2.805.353-.968 0-1.908-.122-2.805-.353A17.151 17.151 0 0 1 12 2.276ZM10.122 2.43a18.629 18.629 0 0 0-2.37 6.49 11.266 11.266 0 0 1-3.746-2.504 9.754 9.754 0 0 1 6.116-3.985Z'
                ></path>
              </svg>
            </div>
            <h3 class='font-bold text-gray-800 mb-2'>Community Impact</h3>
            <p class='text-sm text-gray-500 leading-relaxed'>
              Directly improve lives in underserved areas across the Diocese of
              Homa Bay.
            </p>
          </div>

          <div class='bg-white rounded-2xl p-7 text-center shadow-sm'>
            <div
              class='inline-flex items-center justify-center w-12 h-12 rounded-full bg-orange-100 mb-4'>
              <!-- Heroicon: academic-cap -->
              <svg
                xmlns='http://www.w3.org/2000/svg'
                viewBox='0 0 24 24'
                fill='currentColor'
                class='w-6 h-6 text-orange-500'>
                <path
                  d='M11.7 2.805a.75.75 0 0 1 .6 0A60.65 60.65 0 0 1 22.83 8.72a.75.75 0 0 1-.231 1.337 49.948 49.948 0 0 0-9.902 3.912l-.003.002c-.114.06-.227.119-.34.18a.75.75 0 0 1-.707 0A50.88 50.88 0 0 0 7.5 12.173v-.224c0-.131.067-.248.172-.311a54.615 54.615 0 0 1 4.653-2.52.75.75 0 0 0-.65-1.352 56.123 56.123 0 0 0-4.78 2.589 1.858 1.858 0 0 0-.859 1.228 49.803 49.803 0 0 0-4.634-1.527.75.75 0 0 1-.231-1.337A60.653 60.653 0 0 1 11.7 2.805Z'
                ></path>
                <path
                  d='M13.06 15.473a48.45 48.45 0 0 1 7.666-3.282c.134 1.414.22 2.843.255 4.284a.75.75 0 0 1-.46.711 47.87 47.87 0 0 0-8.105 4.342.75.75 0 0 1-.832 0 47.87 47.87 0 0 0-8.104-4.342.75.75 0 0 1-.461-.71c.035-1.442.121-2.87.255-4.286.921.304 1.83.634 2.726.99v1.27a1.5 1.5 0 0 0-.14 2.508c-.09.38-.222.753-.397 1.11.452.213.901.434 1.346.66a6.727 6.727 0 0 0 .551-1.608 1.5 1.5 0 0 0 .14-2.67v-.645a48.549 48.549 0 0 1 3.44 1.667 2.25 2.25 0 0 0 2.12 0Z'
                ></path>
              </svg>
            </div>
            <h3 class='font-bold text-gray-800 mb-2'>Grow Your Skills</h3>
            <p class='text-sm text-gray-500 leading-relaxed'>
              Gain hands-on experience in healthcare outreach, logistics, and
              community engagement.
            </p>
          </div>

          <div class='bg-white rounded-2xl p-7 text-center shadow-sm'>
            <div
              class='inline-flex items-center justify-center w-12 h-12 rounded-full bg-orange-100 mb-4'>
              <!-- Heroicon: heart -->
              <svg
                xmlns='http://www.w3.org/2000/svg'
                viewBox='0 0 24 24'
                fill='currentColor'
                class='w-6 h-6 text-orange-500'>
                <path
                  d='m11.645 20.91-.007-.003-.022-.012a15.247 15.247 0 0 1-.383-.218 25.18 25.18 0 0 1-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0 1 12 5.052 5.5 5.5 0 0 1 16.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 0 1-4.244 3.17 15.247 15.247 0 0 1-.383.219l-.022.012-.007.004-.003.001a.752.752 0 0 1-.704 0l-.003-.001Z'
                ></path>
              </svg>
            </div>
            <h3 class='font-bold text-gray-800 mb-2'>Faith in Action</h3>
            <p class='text-sm text-gray-500 leading-relaxed'>
              Live out the mission of compassionate service rooted in Catholic
              social teaching.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
       VOLUNTEER FORM
  ══════════════════════════════════════════ -->
    <section class='bg-white px-4 md:px-6 py-16'>
      <div class='max-w-3xl mx-auto'>
        <h2 class='text-2xl font-bold text-blue-900 mb-2'>
          Sign Up to Volunteer
        </h2>
        <div class='w-12 h-1 bg-orange-500 rounded mb-8'></div>

        <form class='space-y-6' id='volunteer-form' novalidate>
          <div class='grid sm:grid-cols-2 gap-5'>
            <div>
              <label
                class='block text-sm font-semibold text-gray-700 mb-1.5'
                for='first-name'>
                First Name <span class='text-orange-500'>*</span>
              </label>
              <input
                id='first-name'
                type='text'
                placeholder='e.g. Mary'
                required
                class='w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-900 focus:border-transparent transition'
              />
            </div>
            <div>
              <label
                class='block text-sm font-semibold text-gray-700 mb-1.5'
                for='last-name'>
                Last Name <span class='text-orange-500'>*</span>
              </label>
              <input
                id='last-name'
                type='text'
                placeholder='e.g. Achieng'
                required
                class='w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-900 focus:border-transparent transition'
              />
            </div>
          </div>

          <div class='grid sm:grid-cols-2 gap-5'>
            <div>
              <label
                class='block text-sm font-semibold text-gray-700 mb-1.5'
                for='email'>
                Email Address
              </label>
              <div class='relative'>
                <span
                  class='absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none'>
                  <svg
                    xmlns='http://www.w3.org/2000/svg'
                    viewBox='0 0 24 24'
                    fill='currentColor'
                    class='w-4 h-4 text-gray-400'>
                    <path
                      d='M1.5 8.67v8.58a3 3 0 0 0 3 3h15a3 3 0 0 0 3-3V8.67l-8.928 5.493a3 3 0 0 1-3.144 0L1.5 8.67Z'
                    ></path>
                    <path
                      d='M22.5 6.908V6.75a3 3 0 0 0-3-3h-15a3 3 0 0 0-3 3v.158l9.714 5.978a1.5 1.5 0 0 0 1.572 0L22.5 6.908Z'
                    ></path>
                  </svg>
                </span>
                <input
                  id='email'
                  type='email'
                  placeholder='you@example.com'
                  class='w-full border border-gray-300 rounded-lg pl-9 pr-4 py-2.5 text-sm text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-900 focus:border-transparent transition'
                />
              </div>
            </div>
            <div>
              <label
                class='block text-sm font-semibold text-gray-700 mb-1.5'
                for='phone'>
                Phone Number <span class='text-orange-500'>*</span>
              </label>
              <div class='relative'>
                <span
                  class='absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none'>
                  <svg
                    xmlns='http://www.w3.org/2000/svg'
                    viewBox='0 0 24 24'
                    fill='currentColor'
                    class='w-4 h-4 text-gray-400'>
                    <path
                      fill-rule='evenodd'
                      d='M1.5 4.5a3 3 0 0 1 3-3h1.372c.86 0 1.61.586 1.819 1.42l1.105 4.423a1.875 1.875 0 0 1-.694 1.955l-1.293.97c-.135.101-.164.249-.126.352a11.285 11.285 0 0 0 6.697 6.697c.103.038.25.009.352-.126l.97-1.293a1.875 1.875 0 0 1 1.955-.694l4.423 1.105c.834.209 1.42.959 1.42 1.82V19.5a3 3 0 0 1-3 3h-2.25C8.552 22.5 1.5 15.448 1.5 6.75V4.5Z'
                      clip-rule='evenodd'></path>
                  </svg>
                </span>
                <input
                  id='phone'
                  type='tel'
                  placeholder='+254 7XX XXX XXX'
                  required
                  class='w-full border border-gray-300 rounded-lg pl-9 pr-4 py-2.5 text-sm text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-900 focus:border-transparent transition'
                />
              </div>
            </div>
          </div>

          <div class='grid sm:grid-cols-2 gap-5'>
            <div>
              <label
                class='block text-sm font-semibold text-gray-700 mb-1.5'
                for='location'>Town / Sub-County</label
              >
              <input
                id='location'
                type='text'
                placeholder='e.g. Homa Bay'
                class='w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-900 focus:border-transparent transition'
              />
            </div>
            <div>
              <label
                class='block text-sm font-semibold text-gray-700 mb-1.5'
                for='occupation'>Occupation / Profession</label
              >
              <input
                id='occupation'
                type='text'
                placeholder='e.g. Nurse'
                class='w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-900 focus:border-transparent transition'
              />
            </div>
          </div>

          <div>
            <label class='block text-sm font-semibold text-gray-700 mb-2'>
              Area of Interest <span class='text-orange-500'>*</span>
            </label>
            <div
              class='grid sm:grid-cols-3 gap-3 p-1.5 rounded-xl transition border border-transparent'
              id='interest-container'>
              {
                [
                  'Health Clinics',
                  'Food Assistance',
                  'Community Outreach',
                  'Administration',
                  'Logistics',
                  'Other',
                ].map((area) => (
                  <label class='flex items-center gap-2.5 bg-[#fdf6ee] border border-gray-200 rounded-lg px-4 py-2.5 cursor-pointer hover:border-orange-400 transition-colors'>
                    <input
                      type='checkbox'
                      name='interest'
                      class='accent-orange-500 w-4 h-4'
                    />
                    <span class='text-sm text-gray-700'>{area}</span>
                  </label>
                ))
              }
            </div>
            <p id='interest-error' class='text-xs text-red-500 mt-1.5 hidden'>
              Please select at least one area of interest.
            </p>
          </div>

          <div>
            <label class='block text-sm font-semibold text-gray-700 mb-2'>
              Availability <span class='text-orange-500'>*</span>
            </label>
            <div
              class='grid sm:grid-cols-3 gap-3 p-1.5 rounded-xl transition border border-transparent'
              id='availability-container'>
              {
                [
                  'Weekdays',
                  'Weekends',
                  'Public Holidays',
                  'Flexible',
                  'One-off',
                  'Ongoing',
                ].map((slot) => (
                  <label class='flex items-center gap-2.5 bg-[#fdf6ee] border border-gray-200 rounded-lg px-4 py-2.5 cursor-pointer hover:border-orange-400 transition-colors'>
                    <input
                      type='checkbox'
                      name='availability'
                      class='accent-orange-500 w-4 h-4'
                    />
                    <span class='text-sm text-gray-700'>{slot}</span>
                  </label>
                ))
              }
            </div>
            <p
              id='availability-error'
              class='text-xs text-red-500 mt-1.5 hidden'>
              Please select your availability.
            </p>
          </div>

          <div>
            <label
              class='block text-sm font-semibold text-gray-700 mb-1.5'
              for='message'>
              Why do you want to volunteer? <span
                class='text-gray-400 font-normal'>(optional)</span
              >
            </label>
            <textarea
              id='message'
              rows='4'
              placeholder='Tell us motivations...'
              class='w-full border border-gray-300 rounded-lg px-4 py-3 text-sm text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-900 focus:border-transparent transition resize-none'
            ></textarea>
          </div>

          <div class='flex items-center gap-4 pt-2'>
            <button
              type='submit'
              class='bg-orange-500 hover:bg-orange-600 text-white font-bold px-8 py-3 rounded-lg transition-colors'>
              Submit Application
            </button>
          </div>
        </form>
      </div>
    </section>
  </body>
  <script>
    document
      .getElementById('volunteer-form')
      .addEventListener('submit', function (e) {
        let isFormValid = true;

        // 1. Text Fields Validation (First Name, Last Name, Phone)
        const requiredInputs = this.querySelectorAll('input[required]');
        requiredInputs.forEach((input) => {
          if (!input.value.trim()) {
            isFormValid = false;
            input.classList.add('border-red-500', 'focus:ring-red-500');
            input.classList.remove('border-gray-300', 'focus:ring-blue-900');
          } else {
            input.classList.remove('border-red-500', 'focus:ring-red-500');
            input.classList.add('border-gray-300', 'focus:ring-blue-900');
          }
        });

        // 2. Checkbox Group 1 Validation (Areas of Interest)
        const interests = document.querySelectorAll(
          'input[name="interest"]:checked',
        );
        const interestContainer = document.getElementById('interest-container');
        const interestError = document.getElementById('interest-error');

        if (interests.length === 0) {
          isFormValid = false;
          interestContainer.classList.add('border-red-400', 'bg-red-50/30');
          interestError.classList.remove('hidden');
        } else {
          interestContainer.classList.remove('border-red-400', 'bg-red-50/30');
          interestError.classList.add('hidden');
        }

        // 3. Checkbox Group 2 Validation (Availability)
        const availability = document.querySelectorAll(
          'input[name="availability"]:checked',
        );
        const availabilityContainer = document.getElementById(
          'availability-container',
        );
        const availabilityError = document.getElementById('availability-error');

        if (availability.length === 0) {
          isFormValid = false;
          availabilityContainer.classList.add('border-red-400', 'bg-red-50/30');
          availabilityError.classList.remove('hidden');
        } else {
          availabilityContainer.classList.remove(
            'border-red-400',
            'bg-red-50/30',
          );
          availabilityError.classList.add('hidden');
        }

        // Prevent Form submission if any verification fails
        if (!isFormValid) {
          e.preventDefault();

          // Smooth scroll directly to the first error element
          const firstError = document.querySelector(
            '.border-red-500, .border-red-400',
          );
          if (firstError) {
            firstError.scrollIntoView({ behavior: 'smooth', block: 'center' });
          }
        }
      });

    // Clear red text highlights instantly when user types or updates inputs
    document.querySelectorAll('input[required]').forEach((input) => {
      input.addEventListener('input', function () {
        if (this.value.trim()) {
          this.classList.remove('border-red-500', 'focus:ring-red-500');
          this.classList.add('border-gray-300', 'focus:ring-blue-900');
        }
      });
    });
  </script>
</html>
