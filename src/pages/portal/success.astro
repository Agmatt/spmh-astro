---
import Layout from '../../Layout/Layout.astro';
---

<Layout title='Appointment Confirmed'>
  <div
    class="min-h-screen bg-[var(--color-surface)] text-[var(--color-secondary)] antialiased font-['Outfit',_system-ui,_sans-serif] flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
    <!-- Success Card Container -->
    <div
      class='max-w-xl w-full bg-white rounded-3xl shadow-xl border border-[var(--color-border)] p-8 sm:p-12 text-center relative overflow-hidden'>
      <!-- Top Decorative Brand Accent Line -->
      <div class='absolute top-0 left-0 right-0 h-2 bg-[var(--color-primary)]'>
      </div>

      <!-- Success Checkmark Graphic Container -->
      <div
        class='mx-auto flex items-center justify-center h-20 w-20 rounded-full bg-[var(--color-surface-2)] text-[var(--color-primary)] mb-6 animate-pulse'>
        <svg
          xmlns='http://www.w3.org/2000/svg'
          class='h-10 w-10'
          fill='none'
          viewBox='0 0 24 24'
          stroke='currentColor'
          stroke-width='2.5'>
          <path
            stroke-linecap='round'
            stroke-linejoin='round'
            d='M5 13l4 4L19 7'></path>
        </svg>
      </div>

      <!-- Confirmation Header -->
      <h1
        class="text-3xl font-extrabold text-[var(--color-primary-dark)] tracking-tight font-['Playfair_Display',_Georgia,_serif] mb-3">
        Appointment Request Received
      </h1>
      <p class='text-[var(--color-muted)] text-base max-w-sm mx-auto mb-8'>
        Thank you for choosing St. Paul's Mission Hospital. Your scheduling
        details have been securely logged into our system.
      </p>

      <!-- Clear, Step-by-Step Next Phases Advisory Box -->
      <div
        class='bg-[var(--color-surface)] border border-[var(--color-border)] rounded-2xl p-6 text-left space-y-4 mb-8'>
        <h3
          class='font-bold text-sm text-[var(--color-primary-dark)] tracking-wide uppercase'>
          What Happens Next?
        </h3>

        <ol
          class='space-y-4 text-sm leading-relaxed text-[var(--color-secondary)]'>
          <li class='flex gap-3 items-start'>
            <span
              class='flex items-center justify-center bg-[var(--color-primary)] text-white text-xs font-bold rounded-full h-5 w-5 shrink-0 mt-0.5'>
              1
            </span>
            <div>
              <strong class='text-[var(--color-primary-dark)] block'
                >Clinical Schedule Review</strong
              >
              Our medical administrative desk will check availability for your selected
              specialty clinic.
            </div>
          </li>
          <li class='flex gap-3 items-start'>
            <span
              class='flex items-center justify-center bg-[var(--color-primary)] text-white text-xs font-bold rounded-full h-5 w-5 shrink-0 mt-0.5'>
              2
            </span>
            <div>
              <strong class='text-[var(--color-primary-dark)] block'
                >SMS / Phone Confirmation</strong
              >
              A staff representative will contact you via phone or SMS within <strong
                class='text-[var(--color-primary-dark)]'
                >24 business hours</strong
              > to confirm your exact arrival time.
            </div>
          </li>
          <li class='flex gap-3 items-start'>
            <span
              class='flex items-center justify-center bg-[var(--color-primary)] text-white text-xs font-bold rounded-full h-5 w-5 shrink-0 mt-0.5'>
              3
            </span>
            <div>
              <strong class='text-[var(--color-primary-dark)] block'
                >Arrival Registration</strong
              >
              On the day of your confirmed visit, please arrive 15 minutes early and
              check in at the main outpatient reception desk.
            </div>
          </li>
        </ol>
      </div>

      <!-- Emergency Reminder Footer Tag using your emergency/alert red color token -->
      <div
        class='border-t border-[var(--color-surface-2)] pt-6 mb-8 text-xs text-[var(--color-muted)] flex items-start gap-3 text-left'>
        <span class='text-[var(--color-accent)] shrink-0 mt-0.5'>
          <svg
            xmlns='http://www.w3.org/2000/svg'
            class='h-4 w-4'
            fill='none'
            viewBox='0 0 24 24'
            stroke='currentColor'
            stroke-width='2'>
            <path
              stroke-linecap='round'
              stroke-linejoin='round'
              d='M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z'
            ></path>
          </svg>
        </span>
        <p>
          <span
            class='font-bold text-[var(--color-accent)] uppercase tracking-wider block mb-0.5'
            >Change of Condition?</span
          >
          If your medical symptoms worsen significantly before your appointment, do
          not wait for our call. Proceed directly to our emergency casualty wing.
        </p>
      </div>

      <!-- Navigation Actions -->
      <div class='flex flex-col sm:flex-row gap-3 items-center justify-center'>
        <a
          href='/'
          class='w-full sm:w-auto bg-[var(--color-primary)] hover:bg-[var(--color-primary-dark)] text-white text-sm font-semibold py-3 px-6 rounded-xl shadow-md transition-colors duration-150 text-center'>
          Return to Homepage
        </a>
        <a
          href='tel:+254111817447'
          class='w-full sm:w-auto bg-white hover:bg-[var(--color-surface)] text-[var(--color-primary)] text-sm font-semibold py-3 px-6 rounded-xl border border-[var(--color-border)] transition-colors duration-150 text-center'>
          Call Medical Desk
        </a>
      </div>
    </div>
  </div>
</Layout>
