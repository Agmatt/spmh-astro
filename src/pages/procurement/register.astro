---
import '../../styles/global.css';
import ProcurementHero from '../../components/ProcurementHero.astro';
import ProcurementFooter from '../../components/ProcurementFooter.astro';

const categories = [
  'Medical Supplies & Equipment',
  'Pharmaceuticals',
  'Construction & Works',
  'ICT & Software Services',
  'Food & Catering Supplies',
  'General Services & Consultancy',
];
---

<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>Register as Vendor | SPMH Procurement</title>
  </head>
  <body>
    <main
      class='bg-[var(--color-surface)] min-h-screen pb-24 antialiased'
      style='font-family: var(--font-body);'>
      <ProcurementHero
        eyebrow='Vendor Framework Registry'
        title='Register as a'
        titleAccent='Vendor'
        description='Join the framework registry to be notified when a notice in your category opens, ahead of the next procurement cycle.'
      />

      <div class='max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 mt-10'>
        <div
          x-data='vendorRegisterForm()'
          class='bg-white border border-[var(--color-border)] rounded-lg shadow-sm p-6 sm:p-8 relative'>
          <template x-if='!submitted'>
            <form @submit.prevent='submit' class='space-y-5' novalidate>
              <div class='grid grid-cols-1 sm:grid-cols-2 gap-5'>
                <div>
                  <label
                    class='text-[10px] font-mono uppercase tracking-wider text-[var(--color-muted)] block mb-1.5'>
                    Company Name
                  </label>
                  <input
                    type='text'
                    required
                    x-model='form.companyName'
                    class='w-full text-sm border border-[var(--color-border)] rounded-md px-3 py-2.5 focus:outline-none focus:ring-1 focus:ring-[var(--color-primary)] focus:border-[var(--color-primary)]'
                  />
                </div>
                <div>
                  <label
                    class='text-[10px] font-mono uppercase tracking-wider text-[var(--color-muted)] block mb-1.5'>
                    KRA PIN
                  </label>
                  <input
                    type='text'
                    required
                    x-model='form.kraPin'
                    @input='validateKraPin()'
                    @blur='validateKraPin()'
                    maxlength='11'
                    placeholder='A000000000Z'
                    autocomplete='off'
                    :aria-invalid='!!fieldErrors.kraPin'
                    :class='fieldErrors.kraPin
                      ? "border-[var(--color-accent)] focus:ring-[var(--color-accent)] focus:border-[var(--color-accent)] bg-red-50/40"
                      : "border-[var(--color-border)] focus:ring-[var(--color-primary)] focus:border-[var(--color-primary)]"'
                    class='w-full text-sm rounded-md px-3 py-2.5 focus:outline-none focus:ring-1 uppercase'
                  />
                  <p
                    x-show='fieldErrors.kraPin'
                    x-text='fieldErrors.kraPin'
                    x-cloak
                    class='text-xs text-[var(--color-accent)] font-medium mt-1.5'>
                  </p>
                </div>
              </div>

              <div>
                <label
                  class='text-[10px] font-mono uppercase tracking-wider text-[var(--color-muted)] block mb-1.5'>
                  Business Registration Number
                </label>
                <input
                  type='text'
                  required
                  x-model='form.regNumber'
                  class='w-full text-sm border border-[var(--color-border)] rounded-md px-3 py-2.5 focus:outline-none focus:ring-1 focus:ring-[var(--color-primary)] focus:border-[var(--color-primary)]'
                />
              </div>

              <div>
                <label
                  class='text-[10px] font-mono uppercase tracking-wider text-[var(--color-muted)] block mb-1.5'>
                  Primary Supply Category
                </label>
                <select
                  required
                  x-model='form.category'
                  class='w-full text-sm border border-[var(--color-border)] rounded-md px-3 py-2.5 focus:outline-none focus:ring-1 focus:ring-[var(--color-primary)] focus:border-[var(--color-primary)] bg-white'>
                  <option value='' disabled selected>Select a category</option>
                  {categories.map((cat) => <option value={cat}>{cat}</option>)}
                </select>
              </div>

              <div class='grid grid-cols-1 sm:grid-cols-2 gap-5'>
                <div>
                  <label
                    class='text-[10px] font-mono uppercase tracking-wider text-[var(--color-muted)] block mb-1.5'>
                    Contact Email
                  </label>
                  <input
                    type='email'
                    required
                    x-model='form.email'
                    class='w-full text-sm border border-[var(--color-border)] rounded-md px-3 py-2.5 focus:outline-none focus:ring-1 focus:ring-[var(--color-primary)] focus:border-[var(--color-primary)]'
                  />
                </div>
                <div>
                  <label
                    class='text-[10px] font-mono uppercase tracking-wider text-[var(--color-muted)] block mb-1.5'>
                    Phone Number
                  </label>
                  <input
                    type='tel'
                    required
                    x-model='form.phone'
                    @input='validatePhone()'
                    @blur='validatePhone()'
                    placeholder='+2547XXXXXXXX or 07XXXXXXXX'
                    autocomplete='off'
                    :aria-invalid='!!fieldErrors.phone'
                    :class='fieldErrors.phone
                      ? "border-[var(--color-accent)] focus:ring-[var(--color-accent)] focus:border-[var(--color-accent)] bg-red-50/40"
                      : "border-[var(--color-border)] focus:ring-[var(--color-primary)] focus:border-[var(--color-primary)]"'
                    class='w-full text-sm rounded-md px-3 py-2.5 focus:outline-none focus:ring-1'
                  />
                  <p
                    x-show='fieldErrors.phone'
                    x-text='fieldErrors.phone'
                    x-cloak
                    class='text-xs text-[var(--color-accent)] font-medium mt-1.5'>
                  </p>
                </div>
              </div>

              <label class='flex items-start gap-2.5 pt-1'>
                <input
                  type='checkbox'
                  required
                  x-model='form.agree'
                  class='mt-0.5'
                />
                <span class='text-xs text-slate-600 leading-relaxed'>
                  I confirm the details above are accurate and I have read the
                  <a
                    href='/procurement/terms'
                    class='text-[var(--color-primary)] underline'
                    >Terms &amp; Conditions</a
                  >.
                </span>
              </label>

              <button
                type='submit'
                :disabled='loading'
                class='btn btn-primary w-full sm:w-auto text-center text-xs px-6 py-3 font-bold tracking-wide shadow-sm disabled:opacity-60'>
                <span x-show='!loading'>Submit Registration</span>
                <span x-show='loading'>Submitting&hellip;</span>
              </button>

              <p
                x-show='errorMsg'
                x-text='errorMsg'
                class='text-xs text-[var(--color-accent)] font-medium'>
              </p>
              <div class='mt-4 mx-auto max-w-xs text-center'>
                <a href='/' class='btn-tertiary text-white font-bold text-sm'>
                  Back to Main Website
                </a>
              </div>
            </form>
          </template>

          <template x-if='submitted'>
            <div class='text-center py-8'>
              <div
                class='w-12 h-12 rounded-full bg-emerald-100 border border-emerald-200 flex items-center justify-center mx-auto mb-4 text-emerald-600 text-lg font-bold select-none'>
                ✓
              </div>
              <h2
                class='text-sm font-bold text-[var(--color-secondary)] uppercase tracking-wider mb-2'>
                Registration Received
              </h2>
              <p
                class='text-xs text-[var(--color-muted)] leading-relaxed max-w-sm mx-auto'>
                You will be notified by email when a notice in your category is
                published on this portal.
              </p>
              <a
                href='/about-us/tenders'
                class='text-[var(--color-primary)] hover:text-accent'>
                View Active Notices
              </a>
            </div>
          </template>
        </div>
      </div>
    </main>

    <ProcurementFooter />

    <script>
      // NOTE: wire this up to a Supabase `vendors` table + Astro API route,
      // the same pattern used by src/pages/api for the clinic booking system
      // (insert on POST, Resend confirmation email on success). Left as a
      // client-side stub here since the vendors schema doesn't exist yet.
      function vendorRegisterForm() {
        return {
          loading: false,
          submitted: false,
          errorMsg: '',
          fieldErrors: {
            kraPin: '',
            phone: '',
          },
          form: {
            companyName: '',
            kraPin: '',
            regNumber: '',
            category: '',
            email: '',
            phone: '',
            agree: false,
          },
          // KRA PIN: one letter, 9 digits, one letter — e.g. A000000000Z
          validateKraPin() {
            const value = this.form.kraPin.trim().toUpperCase();
            this.form.kraPin = value;
            if (!value) {
              this.fieldErrors.kraPin = '';
              return true;
            }
            const pattern = /^[A-Z]\d{9}[A-Z]$/;
            if (!pattern.test(value)) {
              this.fieldErrors.kraPin =
                'Enter a valid KRA PIN — one letter, 9 digits, one letter (e.g. A000000000Z)';
              return false;
            }
            this.fieldErrors.kraPin = '';
            return true;
          },
          // Phone: must start with + or 0, e.g. +2547XXXXXXXX or 07XXXXXXXX
          validatePhone() {
            const value = this.form.phone.trim();
            if (!value) {
              this.fieldErrors.phone = '';
              return true;
            }
            const pattern = /^(\+\d{9,14}|0\d{9})$/;
            if (!pattern.test(value)) {
              this.fieldErrors.phone =
                'Enter a valid phone number starting with + or 0 (e.g. +2547XXXXXXXX or 07XXXXXXXX)';
              return false;
            }
            this.fieldErrors.phone = '';
            return true;
          },
          async submit() {
            const kraOk = this.validateKraPin();
            const phoneOk = this.validatePhone();
            if (!this.form.kraPin.trim()) {
              this.fieldErrors.kraPin = 'KRA PIN is required';
            }
            if (!this.form.phone.trim()) {
              this.fieldErrors.phone = 'Phone number is required';
            }
            if (
              this.fieldErrors.kraPin ||
              this.fieldErrors.phone ||
              !kraOk ||
              !phoneOk
            ) {
              this.errorMsg =
                'Please fix the highlighted fields before submitting.';
              return;
            }

            this.loading = true;
            this.errorMsg = '';
            try {
              const res = await fetch('/api/vendor-register', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(this.form),
              });
              if (!res.ok) throw new Error('Submission failed');
              this.submitted = true;
            } catch (err) {
              this.errorMsg =
                'Something went wrong. Please try again or email procurement@spmh.co.ke directly.';
            } finally {
              this.loading = false;
            }
          },
        };
      }
      window.vendorRegisterForm = vendorRegisterForm;
    </script>
  </body>
</html>
