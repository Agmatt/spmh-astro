---
import '../../styles/global.css';
import ProcurementHero from '../../components/ProcurementHero.astro';
import ProcurementFooter from '../../components/ProcurementFooter.astro';

// Static reference set for now. Once these documents live in Supabase
// storage, swap this array for a query against a `procurement_resources`
// table the same way `tenders.astro` queries the `tenders` table.
const resourceGroups = [
  {
    label: 'Prequalification',
    items: [
      {
        title: 'Standard Prequalification Form',
        format: 'DOCX',
        size: '48 KB',
      },
      {
        title: 'Vendor Category Reference Sheet',
        format: 'PDF',
        size: '112 KB',
      },
    ],
  },
  {
    label: 'Compliance Certificates',
    items: [
      {
        title: 'Tax Compliance Requirements Note',
        format: 'PDF',
        size: '86 KB',
      },
      {
        title: 'Business Registration Checklist',
        format: 'PDF',
        size: '64 KB',
      },
    ],
  },
  {
    label: 'Standard Forms',
    items: [
      { title: 'Bid Submission Cover Sheet', format: 'DOCX', size: '39 KB' },
      {
        title: 'Confidentiality & Conflict-of-Interest Declaration',
        format: 'DOCX',
        size: '41 KB',
      },
    ],
  },
];
---

<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>Supplier Resources | SPMH Procurement</title>
  </head>
  <body>
    <main
      class='bg-[var(--color-surface)] min-h-screen pb-24 antialiased'
      style='font-family: var(--font-body);'>
      <ProcurementHero
        eyebrow='Supply Chain Framework'
        title='Supplier'
        titleAccent='Resources'
        description='Standard forms, compliance references, and prequalification documents used across every notice on this portal. Download once and reuse for each submission.'
      />

      <div class='max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-10 space-y-10'>
        {
          resourceGroups.map((group) => (
            <section class='bg-white border border-[var(--color-border)] rounded-lg shadow-sm relative overflow-hidden'>
              <div class='absolute top-0 left-0 right-0 h-1 bg-[var(--color-primary)]' />
              <div class='p-5 sm:p-6 border-b border-[var(--color-border)]'>
                <h2 class='text-[10px] font-mono uppercase tracking-widest text-[var(--color-secondary)] font-bold'>
                  {group.label}
                </h2>
              </div>
              <ul class='divide-y divide-[var(--color-border)]'>
                {group.items.map((item) => (
                  <li class='flex items-center justify-between gap-4 px-5 sm:px-6 py-4'>
                    <div class='flex items-start gap-3'>
                      <span class='text-[var(--color-primary)] mt-0.5 select-none font-bold text-sm'>
                        ↓
                      </span>
                      <span class='text-xs sm:text-sm text-slate-700 font-medium leading-snug'>
                        {item.title}
                      </span>
                    </div>
                    <span class='text-[10px] text-[var(--color-muted)] font-mono shrink-0'>
                      {item.format} &middot; {item.size}
                    </span>
                  </li>
                ))}
              </ul>
            </section>
          ))
        }

        <div
          class='bg-[var(--color-secondary)] text-white rounded-lg p-6 sm:p-8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-5'>
          <div>
            <h3 class='text-sm font-bold tracking-wide mb-1'>
              Not registered yet?
            </h3>
            <p class='text-xs text-slate-300 max-w-md leading-relaxed'>
              Join the vendor framework registry to be notified when a notice in
              your category opens.
            </p>
          </div>
          <a
            href='/procurement/register'
            class='btn btn-primary text-center text-xs px-6 py-3 font-bold tracking-wide shadow-sm shrink-0'>
            Register as Vendor
          </a>
        </div>
      </div>
    </main>

    <ProcurementFooter />
  </body>
</html>
