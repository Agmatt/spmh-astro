---
// You can keep this empty for now
---

<form id='applyForm' class='p-8 max-w-lg mx-auto space-y-4'>
  <h1 class='text-2xl font-bold'>Apply for a Position</h1>

  <input
    type='text'
    name='fullname'
    placeholder='Full Name'
    required
    class='border p-2 w-full'
  />
  <input
    type='email'
    name='email'
    placeholder='Email Address'
    required
    class='border p-2 w-full'
  />
  <select name='jobTitle' class='border p-2 w-full'>
    <option>Nursing Staff</option>
    <option>Medical Officer</option>
    <option>Lab Technician</option>
  </select>

  <label class='block font-medium'>Upload CV (PDF)</label>
  <input type='file' name='resume' accept='.pdf' required class='w-full' />

  <button type='submit' class='bg-blue-600 text-white px-4 py-2 rounded'
    >Submit Application</button
  >
</form>

<script>
  const form = document.getElementById('applyForm') as HTMLFormElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(form);

    try {
      const response = await fetch('http://localhost:3001/apply', {
        method: 'POST',
        body: formData, // Note: Don't set headers, the browser does it for FormData
      });

      const result = await response.json();
      alert(result.message);
    } catch (error) {
      alert('Error connecting to the backend.');
    }
  });
</script>
