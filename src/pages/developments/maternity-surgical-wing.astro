---
// maternity-surgical-wing.astro
import Layout from '../../Layout/Layout.astro';
import GalleryCarousel from '../../components/GalleryCarousel.astro';

const pageTitle = 'New Maternity & Surgical Wing';
const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Developments', href: '/#developments' },
  { label: 'Maternity & Surgical Wing', href: '/maternity-surgical-wing' },
];
---

<Layout title={`${pageTitle} | St. Paul's Mission Hospital`}>
  <style>
    /* Keyframe animations — cannot be expressed as Tailwind utilities */
    @keyframes pulse-orange {
      0%,
      100% {
        box-shadow: 0 0 0 0 rgba(249, 115, 22, 0.4);
      }
      50% {
        box-shadow: 0 0 0 6px rgba(249, 115, 22, 0);
      }
    }
    .animate-pulse-orange {
      animation: pulse-orange 1.8s ease-in-out infinite;
    }
    .animate-pulse-orange-dot {
      animation: pulse-orange 1.8s infinite;
    }
  </style>

  <!-- ═══════════════════════════════════════════════
       HERO
  ═══════════════════════════════════════════════ -->
  <section
    class='relative min-h-[520px] flex items-end overflow-hidden'
    style='background: linear-gradient(135deg, var(--color-secondary) 0%, #1a3a5c 60%, #2c1a1a 100%);'>
    <!-- Background icon placeholder -->
    <div
      class='absolute inset-0 flex items-center justify-center opacity-[.18]'
      aria-hidden='true'>
    </div>

    <!-- Gradient overlay -->
    <div
      class='absolute inset-0'
      style='background: linear-gradient(to top, rgba(10,20,40,.92) 0%, rgba(10,20,40,.3) 60%, transparent 100%);'>
    </div>

    <!-- Content -->
    <div class='relative z-10 px-3 md:px-8 pb-14 pt-12 max-w-[860px]'>
      <!-- Eyebrow -->
      <span
        class='inline-flex items-center gap-2 bg-[#c0616b] text-white
               text-[.72rem] font-semibold tracking-[.12em] uppercase
               px-[.85rem] py-[.35rem] rounded-sm mb-[1.1rem]'
        style='font-family: var(--font-body);'>
        <svg width='12' height='12' viewBox='0 0 24 24' fill='currentColor'
          ><circle cx='12' cy='12' r='10'></circle></svg
        >
        Under Construction
      </span>

      <h1
        class='font-bold text-white leading-[1.18] mb-4'
        style='font-family: var(--font-display); font-size: clamp(2rem, 5vw, 3.2rem);'>
        New Maternity &amp;<br />Surgical Wing
      </h1>

      <p
        class='text-[1.05rem] text-white/[.78] max-w-[580px] leading-[1.65] mb-[1.6rem]'
        style='font-family: var(--font-body);'>
        A purpose-built facility designed to elevate maternal care and surgical
        services for the community of Homa Bay and the surrounding region.
      </p>

      <div class='flex flex-wrap gap-[1.2rem]'>
        <span
          class='flex items-center gap-[.4rem] text-[.82rem] text-white/[.65]'
          style='font-family: var(--font-body);'>
          <svg
            width='14'
            height='14'
            viewBox='0 0 24 24'
            fill='none'
            stroke='currentColor'
            stroke-width='2'>
            <rect x='3' y='4' width='18' height='18' rx='2'></rect>
            <line x1='16' y1='2' x2='16' y2='6'></line><line
              x1='8'
              y1='2'
              x2='8'
              y2='6'></line>
            <line x1='3' y1='10' x2='21' y2='10'></line>
          </svg>
          <strong class='text-white'>Groundbreaking:</strong>&nbsp;20 July 2025
        </span>
        <span
          class='flex items-center gap-[.4rem] text-[.82rem] text-white/[.65]'
          style='font-family: var(--font-body);'>
          <svg
            width='14'
            height='14'
            viewBox='0 0 24 24'
            fill='none'
            stroke='currentColor'
            stroke-width='2'>
            <path d='M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z'
            ></path><circle cx='12' cy='10' r='3'></circle>
          </svg>
          <strong class='text-white'>Location:</strong>&nbsp;SPMH, Homabay
        </span>
        <span
          class='flex items-center gap-[.4rem] text-[.82rem] text-white/[.65]'
          style='font-family: var(--font-body);'>
          <svg
            width='14'
            height='14'
            viewBox='0 0 24 24'
            fill='none'
            stroke='currentColor'
            stroke-width='2'>
            <path d='M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z'></path>
          </svg>
          <strong class='text-white'>Diocese of Homa Bay</strong>
        </span>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       BREADCRUMB
  ═══════════════════════════════════════════════ -->
  <nav
    class='bg-[var(--color-surface-2)] border-b border-[var(--color-border)] px-8 py-3'
    aria-label='Breadcrumb'>
    <ol
      class='max-w-[1100px] mx-auto flex items-center gap-2 flex-wrap
             text-[.8rem] text-[var(--color-muted)]'
      style='font-family: var(--font-body);'>
      {
        breadcrumbs.map((crumb, i) => (
          <li class='flex items-center gap-2'>
            {i < breadcrumbs.length - 1 ? (
              <>
                <a
                  href={crumb.href}
                  class='text-[var(--color-primary)] no-underline hover:underline'>
                  {crumb.label}
                </a>
                <span class='text-[var(--color-border)]'>›</span>
              </>
            ) : (
              <span class='text-[var(--color-muted)]'>{crumb.label}</span>
            )}
          </li>
        ))
      }
    </ol>
  </nav>

  <!-- ═══════════════════════════════════════════════
       PAGE BODY — two-column grid
  ═══════════════════════════════════════════════ -->
  <div
    class='max-w-[1100px] mx-auto px-2 md:px-8 pt-12 pb-20
           grid grid-cols-[1fr_340px] gap-12 items-start
           max-[860px]:grid-cols-1'>
    <!-- ─────────────────────────────────────────
         MAIN COLUMN
    ───────────────────────────────────────── -->
    <main>
      <!-- Status strip -->
      <div
        class='flex items-center gap-3
               bg-orange-50 border border-orange-300 border-l-4 border-l-orange-500
               rounded-md px-[1.2rem] py-[.9rem] mb-10'
        style='font-family: var(--font-body);'>
        <div
          class='w-[10px] h-[10px] rounded-full bg-orange-500 flex-shrink-0 animate-pulse-orange'>
        </div>
        <p class='text-[.88rem] text-orange-900 m-0'>
          <strong class='font-bold'>Construction in Progress</strong> — Groundbreaking
          was conducted on 20th July 2025. The project is currently in its early construction
          phase. We will update this page as the work progresses.
        </p>
      </div>

      <!-- Overview -->
      <div
        class='text-[.7rem] font-bold tracking-[.14em] uppercase text-[#c0616b] mb-2'
        style='font-family: var(--font-body);'>
        Overview
      </div>
      <h2
        class='text-[1.65rem] font-bold leading-[1.25] mb-[1.1rem] text-[var(--color-secondary)]'
        style='font-family: var(--font-display);'>
        A Wing Built for the Most Important Moments
      </h2>

      <p
        class='text-[.97rem] text-[#374151] leading-[1.78] mb-4'
        style='font-family: var(--font-body);'>
        The new Maternity and Surgical Wing represents one of the most
        significant infrastructure investments in the recent history of St.
        Paul's Mission Hospital. Designed to serve the growing healthcare needs
        of Homa Bay County and its neighbouring communities, the wing will bring
        dedicated, purpose-built facilities for obstetric care and surgical
        services under one roof — raising the standard of care available at SPMH
        to a new level.
      </p>
      <p
        class='text-[.97rem] text-[#374151] leading-[1.78] mb-4'
        style='font-family: var(--font-body);'>
        The groundbreaking ceremony, presided over by His Lordship <strong
          >Bishop Michael Odiwa</strong
        > of the Catholic Diocese of Homa Bay, marked the official start of construction
        on 20th July 2025. The Bishop led prayers at the site, blessed the ground,
        and made the first physical break — a moment that signalled the transition
        from vision to reality for a project years in the making.
      </p>
      <p
        class='text-[.97rem] text-[#374151] leading-[1.78] mb-4'
        style='font-family: var(--font-body);'>
        The wing has been designed in response to real and pressing gaps in
        service capacity — particularly in maternal health, where the demands on
        the existing facility have continued to grow. When complete, it will
        serve every mother who walks through the doors of SPMH and every patient
        requiring surgical intervention, in an environment built specifically
        for that purpose.
      </p>

      <!-- Features -->
      <div
        class='text-[.7rem] font-bold tracking-[.14em] uppercase text-[#c0616b] mb-2 mt-10'
        style='font-family: var(--font-body);'>
        What It Will Offer
      </div>
      <h2
        class='text-[1.65rem] font-bold leading-[1.25] mb-[1.1rem] text-[var(--color-secondary)]'
        style='font-family: var(--font-display);'>
        Key Features of the New Wing
      </h2>

      <div class='grid grid-cols-2 gap-4 mt-6 mb-10 max-[600px]:grid-cols-1'>
        {
          [
            {
              icon: `<path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/>`,
              title: 'Dedicated Maternity Ward',
              body: 'Purpose-built labour, delivery, and postnatal rooms designed around the safety and dignity of mothers and newborns.',
            },
            {
              icon: `<path d="M22 12h-4l-3 9L9 3l-3 9H2"/>`,
              title: 'Upgraded Surgical Theatre',
              body: 'A modern, fully equipped operating theatre meeting Level 4 standards, supporting a wider range of elective and emergency procedures.',
            },
            {
              icon: `<circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>`,
              title: 'Emergency Obstetric Care',
              body: 'Structured spaces for managing obstetric emergencies with the speed and resources required to save both mother and child.',
            },
            {
              icon: `<rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>`,
              title: 'Improved Recovery Spaces',
              body: 'Dedicated post-operative and postnatal recovery areas that provide the monitoring and comfort patients need after procedures.',
            },
            {
              icon: `<path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/>`,
              title: 'Family-Centred Design',
              body: 'Spaces that allow family presence during recovery, acknowledging the role of family support in patient wellbeing and healing.',
            },
            {
              icon: `<path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>`,
              title: 'Integrated Infrastructure',
              body: 'Built-in piped oxygen, reliable utilities, and infection prevention design aligned with national health facility standards.',
            },
          ].map((card) => (
            <div
              class='bg-[#fdf0f1] border border-[#f5c6ca] rounded-xl p-[1.2rem_1.3rem]
                   transition-all duration-200 hover:-translate-y-[3px] hover:shadow-[0_8px_24px_rgba(0,0,0,.07)]'>
              <div class='w-[38px] h-[38px] rounded-lg bg-[#c0616b] flex items-center justify-center mb-3'>
                <svg
                  class='w-5 h-5 text-white'
                  viewBox='0 0 24 24'
                  fill='none'
                  stroke='currentColor'
                  stroke-width='2'
                  set:html={card.icon}
                />
              </div>
              <h3
                class='text-[.92rem] font-bold text-[var(--color-secondary)] mb-[.4rem]'
                style='font-family: var(--font-body);'>
                {card.title}
              </h3>
              <p
                class='text-[.83rem] text-[#4b5563] leading-[1.6] m-0'
                style='font-family: var(--font-body);'>
                {card.body}
              </p>
            </div>
          ))
        }
      </div>

      <!-- Gallery -->
      <GalleryCarousel
        id='maternity-gallery'
        accentColor='#c0616b'
        accentLight='#fdf0f1'
        sectionLabel='Gallery'
        sectionTitle='From the Groundbreaking Ceremony'
        slides={[
          {
            src: '/gallery/19.jpg',
            alt: 'Bishop Michael Odiwa at the groundbreaking site',
            caption: 'Bishop Michael Odiwa at the groundbreaking site',
          },
          {
            src: '/img/38.jpg',
            alt: 'Morning Mass with Fr. Romanus',
            caption: 'Morning Mass with Fr. Romanus',
          },
          {
            src: '/gallery/16.jpg',
            alt: 'The first ground break',
            caption: 'The first ground break',
          },
          {
            src: '/gallery/17.jpg',
            alt: 'Board members & Diocese representatives',
            caption: 'Board members & Diocese representatives',
          },
          {
            src: '/gallery/18.jpg',
            alt: 'Group photo — SPMH Staff & Guests',
            caption: 'Group photo — SPMH Staff & Guests',
          },
        ]}
      />

      <!-- Progress Timeline -->
      <section class='my-10'>
        <div
          class='text-[.7rem] font-bold tracking-[.14em] uppercase text-[#c0616b] mb-2'
          style='font-family: var(--font-body);'>
          Current Status
        </div>
        <h2
          class='text-[1.65rem] font-bold leading-[1.25] mb-[1.1rem] text-[var(--color-secondary)]'
          style='font-family: var(--font-display);'>
          Project Progress
        </h2>

        <div
          class="relative pl-8
                 before:content-[''] before:absolute before:left-[7px] before:top-2 before:bottom-2
                 before:w-[2px] before:bg-[var(--color-border)]">
          <!-- Done: groundbreaking -->
          <div class='relative mb-[1.6rem]'>
            <div
              class='absolute left-[-2rem] top-1 w-[14px] h-[14px] rounded-full border-2 border-white
                     bg-green-500 shadow-[0_0_0_2px_#22c55e]'>
            </div>
            <div
              class='text-[.72rem] font-semibold uppercase tracking-[.08em] text-[#c0616b] mb-[.2rem]'
              style='font-family: var(--font-body);'>
              July 2025
            </div>
            <h4
              class='text-[.9rem] font-bold text-[var(--color-secondary)] mb-1'
              style='font-family: var(--font-body);'>
              Groundbreaking Ceremony
            </h4>
            <p
              class='text-[.82rem] text-[var(--color-muted)] m-0 leading-[1.55]'
              style='font-family: var(--font-body);'>
              Official groundbreaking conducted on 20th July 2025, presided over
              by Bishop Michael Odiwa. Morning Mass, site prayers, and first
              excavation completed.
            </p>
          </div>

          <!-- Active: construction -->
          <div class='relative mb-[1.6rem]'>
            <div
              class='absolute left-[-2rem] top-1 w-[14px] h-[14px] rounded-full border-2 border-white
                     bg-orange-500 shadow-[0_0_0_2px_#f97316] animate-pulse-orange-dot'>
            </div>
            <div
              class='text-[.72rem] font-semibold uppercase tracking-[.08em] text-[#c0616b] mb-[.2rem]'
              style='font-family: var(--font-body);'>
              Ongoing
            </div>
            <h4
              class='text-[.9rem] font-bold text-[var(--color-secondary)] mb-1'
              style='font-family: var(--font-body);'>
              Foundation &amp; Early Construction
            </h4>
            <p
              class='text-[.82rem] text-[var(--color-muted)] m-0 leading-[1.55]'
              style='font-family: var(--font-body);'>
              Construction is currently underway. The project team — architects,
              designers, and masons — is actively on site.
            </p>
          </div>

          <!-- Pending: structural -->
          <div class='relative mb-[1.6rem]'>
            <div
              class='absolute left-[-2rem] top-1 w-[14px] h-[14px] rounded-full border-2 border-white
                     bg-white shadow-[0_0_0_2px_var(--color-border)]'>
            </div>
            <div
              class='text-[.72rem] font-semibold uppercase tracking-[.08em] text-[#c0616b] mb-[.2rem]'
              style='font-family: var(--font-body);'>
              Upcoming
            </div>
            <h4
              class='text-[.9rem] font-bold text-[var(--color-secondary)] mb-1'
              style='font-family: var(--font-body);'>
              Structural Works &amp; Fit-Out
            </h4>
            <p
              class='text-[.82rem] text-[var(--color-muted)] m-0 leading-[1.55]'
              style='font-family: var(--font-body);'>
              Main structural works, roofing, and interior fit-out including
              medical infrastructure and utilities.
            </p>
          </div>

          <!-- Pending: commissioning -->
          <div class='relative mb-[1.6rem]'>
            <div
              class='absolute left-[-2rem] top-1 w-[14px] h-[14px] rounded-full border-2 border-white
                     bg-white shadow-[0_0_0_2px_var(--color-border)]'>
            </div>
            <div
              class='text-[.72rem] font-semibold uppercase tracking-[.08em] text-[#c0616b] mb-[.2rem]'
              style='font-family: var(--font-body);'>
              TBD
            </div>
            <h4
              class='text-[.9rem] font-bold text-[var(--color-secondary)] mb-1'
              style='font-family: var(--font-body);'>
              Commissioning &amp; Opening
            </h4>
            <p
              class='text-[.82rem] text-[var(--color-muted)] m-0 leading-[1.55]'
              style='font-family: var(--font-body);'>
              Final inspections, equipment installation, staff orientation, and
              official commissioning of the new wing.
            </p>
          </div>
        </div>
      </section>
    </main>

    <!-- ─────────────────────────────────────────
         SIDEBAR
    ───────────────────────────────────────── -->
    <aside class='flex flex-col gap-6'>
      <!-- Quick facts -->
      <div
        class='bg-white border border-[var(--color-border)] rounded-xl p-6
               shadow-[0_2px_12px_rgba(0,0,0,.04)]'>
        <h3
          class='text-[1.05rem] font-bold text-[var(--color-secondary)] mb-4
                 pb-[.6rem] border-b border-[var(--color-border)]'
          style='font-family: var(--font-display);'>
          Quick Facts
        </h3>
        <ul>
          {
            [
              {
                label: 'Project',
                value: 'Maternity & Surgical Wing',
                orange: false,
              },
              { label: 'Groundbreaking', value: '20 July 2025', orange: false },
              {
                label: 'Presided By',
                value: 'Bishop Michael Odiwa',
                orange: false,
              },
              { label: 'Status', value: 'Under Construction', orange: true },
              {
                label: 'Diocese',
                value: 'Catholic Diocese of Homa Bay',
                orange: false,
              },
              { label: 'Facility Level', value: 'Level 4', orange: false },
            ].map((row, i, arr) => (
              <li
                class={`flex justify-between items-center gap-2 py-2 text-[.85rem] text-[#374151]
                      ${i < arr.length - 1 ? 'border-b border-[var(--color-surface-2)]' : ''}`}
                style='font-family: var(--font-body);'>
                <span class='text-[.8rem] text-[var(--color-muted)]'>
                  {row.label}
                </span>
                <span
                  class={`font-semibold text-right
                        ${row.orange ? 'text-orange-500' : 'text-[var(--color-secondary)]'}`}>
                  {row.value}
                </span>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Related article -->
      <div
        class='bg-[#fdf0f1] border border-[#f5c6ca] rounded-xl p-6
               shadow-[0_2px_12px_rgba(0,0,0,.04)]'>
        <h3
          class='text-[1.05rem] font-bold text-[var(--color-secondary)] mb-4
                 pb-[.6rem] border-b border-[#f5c6ca]'
          style='font-family: var(--font-display);'>
          Related Article
        </h3>
        <a
          href='/news-and-media/articles/groundbreaking-maternity-surgical-wing'
          class='flex items-start gap-3 no-underline p-3 rounded-lg bg-white
                 border border-[#f5c6ca]
                 transition-shadow duration-200 hover:shadow-[0_4px_16px_rgba(0,0,0,.08)]'>
          <div
            class='w-9 h-9 rounded-md bg-[#c0616b] flex items-center justify-center flex-shrink-0'>
            <svg
              class='w-[18px] h-[18px] text-white'
              viewBox='0 0 24 24'
              fill='none'
              stroke='currentColor'
              stroke-width='2'>
              <path d='M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z'
              ></path>
              <polyline points='14 2 14 8 20 8'></polyline>
              <line x1='16' y1='13' x2='8' y2='13'></line>
              <line x1='16' y1='17' x2='8' y2='17'></line>
              <polyline points='10 9 9 9 8 9'></polyline>
            </svg>
          </div>
          <div>
            <strong
              class='block text-[.85rem] font-bold text-[var(--color-secondary)] mb-[.2rem]'
              style='font-family: var(--font-body);'>
              Breaking Ground, Building the Future
            </strong>
            <span
              class='text-[.78rem] text-[var(--color-muted)]'
              style='font-family: var(--font-body);'>
              Read the full groundbreaking story →
            </span>
          </div>
        </a>
      </div>

      <!-- CTA -->
      <div
        class='rounded-xl p-6 shadow-[0_2px_12px_rgba(0,0,0,.04)]'
        style='background: linear-gradient(135deg, var(--color-secondary), #1a3a5c);'>
        <h3
          class='text-[1.05rem] font-bold text-white mb-4
                 pb-[.6rem] border-b border-white/20'
          style='font-family: var(--font-display);'>
          Get in Touch
        </h3>
        <p
          class='text-[.87rem] text-white/[.8] leading-[1.6] mb-[1.2rem]'
          style='font-family: var(--font-body);'>
          For enquiries about this development or any of our services, our team
          is ready to help.
        </p>
        <a
          href='/about-us/contact'
          class='block w-full py-3 px-5 rounded-lg text-[.88rem] font-semibold text-center
                 no-underline bg-white text-[var(--color-secondary)] mb-[.6rem]
                 transition-all duration-200 hover:opacity-[.88] hover:-translate-y-px'
          style='font-family: var(--font-body);'>
          Contact Us
        </a>
        <a
          href='/services/appointments'
          class='block w-full py-3 px-5 rounded-lg text-[.88rem] font-semibold text-center
                 no-underline bg-transparent text-white border border-white/50
                 transition-all duration-200 hover:opacity-[.88] hover:-translate-y-px'
          style='font-family: var(--font-body);'>
          Book Appointment
        </a>
      </div>
    </aside>
  </div><!-- /page-body -->
</Layout>
