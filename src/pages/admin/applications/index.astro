---
import '../../../styles/global.css';
import AdminAuthGate from '../../../react-islands/AdminAuthGate';
---

<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>Master Admin Control Panel | SPMH</title>
  </head>
  <body class='bg-gray-50 text-gray-900 font-sans antialiased'>
    <AdminAuthGate client:load />

    <style is:global>
      @keyframes fadeIn {
        from {
          opacity: 0;
          transform: translateY(2px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      .animate-fadeIn {
        animation: fadeIn 0.2s ease-out forwards;
      }
    </style>
  </body>
</html>
