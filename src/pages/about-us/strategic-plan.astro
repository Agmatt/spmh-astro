---
import Layout from '../../Layout/Layout.astro';

// Core Identity Data
const vision =
  'A Center of Excellence in Integrated and Compassionate Healthcare.';
const mission =
  'To deliver high-quality, affordable, and compassionate healthcare that upholds human dignity and equity, while faithfully advancing the healing mission of Christ.';

const values = [
  {
    name: 'Christ-Centered Care',
    desc: 'Reflecting the healing ministry of Christ through spiritual, emotional, and physical care.',
  },
  {
    name: 'Professionalism',
    desc: 'Upholding the highest clinical, ethical, and operational standards in all interventions.',
  },
  {
    name: 'Integrity & Stewardship',
    desc: 'Ensuring transparency, resource accountability, and ethical management.',
  },
  {
    name: 'Teamwork & Servant Leadership',
    desc: 'Collaborating across disciplines with humility and a dedication to service.',
  },
  {
    name: 'Adaptability & Innovation',
    desc: 'Embracing digital health solutions and evolving to meet community health needs.',
  },
];

// Strategic Pillars Data - Recalled with a cohesive, professional palette (Teal, Indigo, Emerald, Cyan)
const pillars = [
  {
    title: 'Clinical Service Excellence',
    subtitle: 'Elevating Patient Care & Capabilities',
    bgGradient: 'from-teal-600 to-cyan-700',
    interventions: [
      'Expand Maternal, Newborn, Child, and Adolescent Health (MNCAH) services.',
      'Establish fully functional Intensive Care (ICU) and High Dependency Unit (HDU) capacities.',
      'Upgrade and streamline surgical suites and emergency stabilization workflows.',
      'Strengthen diagnostic accuracy across laboratory and imaging departments.',
    ],
  },
  {
    title: 'Health Workforce Development',
    subtitle: 'Empowering & Growing Our Team',
    bgGradient: 'from-indigo-600 to-blue-700',
    interventions: [
      'Aggressively recruit specialized medical cadres and key clinical personnel.',
      'Institutionalize Continuous Professional Development (CPD) and training pipelines.',
      'Implement institutional workplace wellness and burnout mitigation programs.',
      'Establish performance-driven retention frameworks aligned with MoH standards.',
    ],
  },
  {
    title: 'Infrastructure & Digital Health',
    subtitle: 'Modernizing the Care Environment',
    bgGradient: 'from-cyan-600 to-indigo-600',
    interventions: [
      'Construct physical spaces designated for specialized inpatient clinical units.',
      'Procure advanced biomedical infrastructure (including modern CT/imaging suites).',
      'Achieve comprehensive Electronic Medical Records (EMR) system integration.',
      'Deploy data-driven internal dashboards to eliminate operational data fragmentation.',
    ],
  },
  {
    title: 'Financial Sustainability',
    subtitle: 'Securing Our Long-Term Mission',
    bgGradient: 'from-emerald-600 to-teal-700',
    interventions: [
      'Diversify institutional revenue streams and maximize local partnerships.',
      'Optimize claims workflows to accelerate Social Health Authority (SHA) reimbursements.',
      'Implement robust cost-containment measures and accurate service-line costing.',
      'Build strategic capital reserves to insulate against external liquidity strains.',
    ],
  },
  {
    title: 'Community Health Integration',
    subtitle: 'Extending Care Beyond Our Walls',
    bgGradient: 'from-teal-600 to-indigo-600',
    interventions: [
      'Deepen structural networks with designated Community Health Promoters (CHPs).',
      'Scale preventative care, localized health education, and immunization campaigns.',
      'Launch integrated field outreach systems for chronic NCD monitoring and follow-ups.',
      'Strengthen external primary-to-secondary referral pathways within Homa Bay County.',
    ],
  },
  {
    title: 'Governance & Ethical Leadership',
    subtitle: 'Upholding Integrity & Trust',
    bgGradient: 'from-slate-700 to-indigo-950',
    interventions: [
      'Enforce rigorous compliance with regulatory frameworks and national standards.',
      'Embed principles of Catholic Social Teaching into daily hospital governance.',
      'Expand risk-management oversight, including institutional risk registries.',
      'Refine board-level and executive accountability structures across all departments.',
    ],
  },
];

// Implementation Timeline Data
const timeline = [
  {
    phase: 'Phase 1: Stabilization',
    years: '2026 – 2027',
    description:
      'Fortifying core internal systems, resolving immediate workforce shortages, and protecting financial health lines to ensure uninterrupted medical care.',
    status: 'Upcoming',
  },
  {
    phase: 'Phase 2: Expansion',
    years: '2028 – 2029',
    description:
      'Scaling specialized clinical departments, advancing digital health integrations, and breaking ground on vital physical infrastructure upgrades.',
    status: 'Planned',
  },
  {
    phase: 'Phase 3: Excellence',
    years: '2030',
    description:
      'Institutionalizing high-performance operational metrics and completing major readiness milestones to deliver the highest level of regional hospital care.',
    status: 'Target',
  },
];
---

<Layout title='Our Institutional Blueprint'>
  <!-- Premium Hero Section -->
  <header
    class='relative bg-gradient-to-br from-slate-900 via-slate-950 to-indigo-950 text-white overflow-hidden py-28 sm:py-36 border-b border-slate-800'>
    <div
      class='absolute inset-0 opacity-20 bg-[radial-gradient(#22d3ee_1px,transparent_1px)] [background-size:20px_20px]'>
    </div>
    <div
      class='absolute -top-40 -right-40 w-96 h-96 bg-teal-500/10 rounded-full blur-3xl'>
    </div>
    <div
      class='absolute -bottom-40 -left-40 w-96 h-96 bg-indigo-500/10 rounded-full blur-3xl'>
    </div>

    <div
      class='max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center'>
      <span
        class='inline-flex items-center gap-1.5 text-xs uppercase tracking-widest text-teal-400 bg-teal-500/10 px-4 py-1.5 rounded-full font-bold mb-6 border border-teal-500/20 shadow-inner'>
        Institutional Blueprint
      </span>
      <h1
        class='text-4xl sm:text-5xl lg:text-6xl font-black tracking-tight text-white max-w-4xl mx-auto leading-tight'>
        A Shared Vision <br class='hidden sm:block' />
        <span
          class='text-transparent bg-clip-text bg-gradient-to-r from-teal-400 via-cyan-400 to-indigo-400'>
          For Healing & Community Growth
        </span>
      </h1>
      <p
        class='mt-6 text-lg sm:text-xl text-slate-300 max-w-2xl mx-auto leading-relaxed font-medium'>
        Driving sustainable healthcare transformation, clinical care depth, and
        comprehensive medical support across Homa Bay County.
      </p>
      <div
        class='mt-10 flex flex-col sm:flex-row gap-4 justify-center items-center'>
        <a
          href='#pillars'
          class='w-full sm:w-auto text-center bg-teal-600 hover:bg-teal-500 text-white font-bold px-8 py-4 rounded-xl shadow-lg transition-all transform hover:-translate-y-0.5 active:translate-y-0'>
          Explore Our Framework
        </a>
        <a
          href='#'
          class='w-full sm:w-auto text-center border border-slate-700 bg-slate-900/40 hover:bg-slate-800 text-slate-200 font-semibold px-8 py-4 rounded-xl transition-colors backdrop-blur-sm'>
          Download Full Document (PDF)
        </a>
      </div>
    </div>
  </header>

  <!-- Vision, Mission & Values Section -->
  <section class='max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24'>
    <div class='grid grid-cols-1 lg:grid-cols-3 gap-8'>
      <div class='lg:col-span-1 flex flex-col gap-8'>
        <!-- Vision -->
        <div
          class='bg-gradient-to-b from-slate-50 to-white p-6 sm:p-8 rounded-3xl shadow-sm border border-slate-200/60 flex-1 hover:shadow-md transition-shadow relative overflow-hidden group'>
          <div class='absolute top-0 left-0 w-1.5 h-full bg-primary'></div>

          <!-- Vision Icon (Eye/Horizon) -->
          <div
            class='mb-5 h-12 w-12 rounded-2xl bg-teal-50 text-teal-600 border border-teal-100 flex items-center justify-center shadow-sm'>
            <svg
              xmlns='http://www.w3.org/2000/svg'
              fill='none'
              viewBox='0 0 24 24'
              stroke-width='2'
              stroke='currentColor'
              class='h-6 w-6'>
              <path
                stroke-linecap='round'
                stroke-linejoin='round'
                d='M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.43 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z'
              ></path>
              <path
                stroke-linecap='round'
                stroke-linejoin='round'
                d='M15 12a3 3 0 11-6 0 3 3 0 016 0z'></path>
            </svg>
          </div>

          <h2 class='text-2xl font-bold text-slate-900 mb-4'>Our Vision</h2>
          <p class='text-slate-600 leading-relaxed font-medium'>{vision}</p>
        </div>

        <!-- Mission -->
        <div
          class='bg-gradient-to-b from-slate-50 to-white p-6 sm:p-8 rounded-3xl shadow-sm border border-slate-200/60 flex-1 hover:shadow-md transition-shadow relative overflow-hidden group'>
          <div class='absolute top-0 left-0 w-1.5 h-full bg-primary'></div>

          <!-- Mission Icon (Target/Bullseye) -->
          <div
            class='mb-5 h-12 w-12 rounded-2xl bg-teal-50 text-teal-600 border border-teal-100 flex items-center justify-center shadow-sm'>
            <svg
              xmlns='http://www.w3.org/2000/svg'
              fill='none'
              viewBox='0 0 24 24'
              stroke-width='2'
              stroke='currentColor'
              class='h-6 w-6'>
              <path
                stroke-linecap='round'
                stroke-linejoin='round'
                d='M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m12.728 0l-.707-.707M6.343 6.343l-.707-.707M14 12a2 2 0 11-4 0 2 2 0 014 0z'
              ></path>
              <path
                stroke-linecap='round'
                stroke-linejoin='round'
                d='M19 12a7 7 0 11-14 0 7 7 0 0114 0z'></path>
            </svg>
          </div>

          <h2 class='text-2xl font-bold text-slate-900 mb-4'>Our Mission</h2>
          <p class='text-slate-600 leading-relaxed font-medium'>{mission}</p>
        </div>
      </div>

      <!-- Core Values Box -->
      <div
        class='lg:col-span-2 bg-white p-8 sm:p-10 rounded-3xl shadow-sm border border-slate-200/60 relative'>
        <h2 class='text-3xl font-bold text-slate-900 mb-3 tracking-tight'>
          Foundational Commitments
        </h2>
        <p class='text-slate-500 mb-8 text-lg font-medium leading-relaxed'>
          The core principles that shape our clinical culture and frame our
          interactions with every family we serve.
        </p>

        <div class='grid grid-cols-1 sm:grid-cols-2 gap-6'>
          {
            values.map((val) => (
              <div class='p-6 rounded-2xl bg-slate-50/50 border border-slate-100 hover:bg-slate-50 hover:border-slate-300 transition-all'>
                <h3 class='text-lg font-bold text-slate-900 mb-2 flex items-center gap-3'>
                  <span class='h-2.5 w-2.5 rounded-full bg-teal-600 shadow-sm shrink-0' />
                  {val.name}
                </h3>
                <p class='text-slate-600 leading-relaxed text-sm font-medium'>
                  {val.desc}
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- Narrative & Local Impact Section -->
  <section
    class='bg-gradient-to-b from-slate-900 to-slate-950 text-white py-24 relative overflow-hidden'>
    <div
      class='absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-indigo-500/5 rounded-full blur-3xl pointer-events-none'>
    </div>
    <div class='max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10'>
      <div class='grid grid-cols-1 lg:grid-cols-12 gap-16 items-center'>
        <div class='lg:col-span-7'>
          <span
            class='text-xs font-bold text-teal-400 tracking-widest uppercase bg-teal-500/10 border border-teal-500/20 px-3 py-1.5 rounded-md'
            >The Human Story</span
          >
          <h2
            class='text-3xl sm:text-4xl font-extrabold mt-4 mb-6 leading-tight tracking-tight'>
            Meeting Critical Healthcare Demands Head-On
          </h2>
          <p class='text-lg text-slate-300 leading-relaxed mb-6 font-medium'>
            Behind every programmatic choice is a patient, a newborn, or a
            family seeking security in times of crisis. Today, St. Paul's
            Mission Hospital directly anchors vital healthcare services for
            hundreds of thousands of people across Homa Bay County. Operating in
            an environment of high community demand requires a focused, deeply
            compassionate design for care delivery.
          </p>
          <p class='text-lg text-slate-300 leading-relaxed font-medium'>
            This approach details our path from an essential regional resource
            toward robust, high-tier healthcare delivery pipelines. It
            guarantees that our medical staff are supported, our spaces are
            clean and modern, and our clinical reach remains entirely accessible
            to those who need it most.
          </p>
        </div>

        <div
          class='lg:col-span-5 bg-slate-900/60 border border-slate-800 rounded-3xl p-8 shadow-2xl backdrop-blur-sm'>
          <h3
            class='text-xl font-bold mb-6 text-white tracking-wide flex items-center gap-2'>
            <span class='h-2 w-2 rounded-full bg-teal-400 shadow'></span>
            Key Outpatient Target Focuses
          </h3>
          <div class='space-y-4'>
            {
              [
                'Upper Respiratory Tract Infections (URTI)',
                'Malaria Mitigation & Treatment',
                'Pneumonia Care Delivery',
                'Hypertension & Cardiovascular Support',
                'Urinary Tract Infections (UTI)',
              ].map((disease, i) => (
                <div class='flex items-center gap-4 p-4 bg-slate-950/50 rounded-2xl border border-slate-800/80 hover:bg-slate-800/50 transition-colors'>
                  <span class='text-sm font-black text-teal-400 bg-teal-950/80 border border-teal-900 px-3 py-1.5 rounded-xl shadow-inner'>
                    0{i + 1}
                  </span>
                  <span class='text-base text-slate-200 font-semibold'>
                    {disease}
                  </span>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Core Pillars of Action Section -->
  <section
    id='pillars'
    class='bg-slate-50 border-b border-slate-200/60 px-4 sm:px-6 lg:px-8 py-24'>
    <div class='max-w-7xl mx-auto'>
      <div class='text-center max-w-3xl mx-auto mb-16'>
        <h2
          class='text-3xl sm:text-4xl font-extrabold text-slate-900 tracking-tight'>
          Framework Pillars
        </h2>
        <p class='mt-4 text-slate-600 text-lg font-medium leading-relaxed'>
          Our organizational milestones are driven by six core, interlinked
          structural areas crafted to generate measurable community outcomes.
        </p>
      </div>

      <div class='grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8'>
        {
          pillars.map((pillar) => (
            <div class='bg-white rounded-3xl shadow-sm border border-slate-200/80 flex flex-col justify-between overflow-hidden group hover:shadow-xl hover:-translate-y-1 transition-all duration-300'>
              <div class='p-8'>
                <h3 class='text-xl font-bold text-slate-900 mb-1 tracking-tight group-hover:text-teal-700 transition-colors'>
                  {pillar.title}
                </h3>
                <p class='text-xs text-slate-400 font-bold mb-8 uppercase tracking-widest'>
                  {pillar.subtitle}
                </p>

                <ul class='space-y-4'>
                  {pillar.interventions.map((item) => (
                    <li class='flex items-start gap-3 text-slate-600 text-sm font-medium leading-relaxed'>
                      <svg
                        xmlns='http://www.w3.org/2000/svg'
                        class='h-5 w-5 text-teal-600 mt-0.5 shrink-0 animate-pulse'
                        fill='none'
                        viewBox='0 0 24 24'
                        stroke='currentColor'>
                        <path
                          stroke-linecap='round'
                          stroke-linejoin='round'
                          stroke-width='2.5'
                          d='M5 13l4 4L19 7'
                        />
                      </svg>
                      <span>{item}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Phased Implementation Section -->
  <section class='bg-white py-24'>
    <div class='max-w-7xl mx-auto px-4 sm:px-6 lg:px-8'>
      <div class='text-center max-w-3xl mx-auto mb-16'>
        <h2
          class='text-3xl sm:text-4xl font-extrabold text-slate-900 tracking-tight'>
          Operational Timeline Phases
        </h2>
        <p class='mt-4 text-slate-600 text-lg font-medium leading-relaxed'>
          Our long-term delivery model isolates execution into clear windows to
          maximize clinical scaling and care continuity.
        </p>
      </div>

      <div class='grid grid-cols-1 lg:grid-cols-3 gap-8 relative'>
        {
          timeline.map((step) => (
            <div class='bg-slate-50/70 p-8 rounded-3xl border border-slate-200/60 relative shadow-inner hover:border-indigo-200 hover:bg-slate-50 transition-all group'>
              <div class='flex items-center justify-between mb-6'>
                <span class='text-xs font-bold uppercase tracking-wider text-indigo-700 bg-indigo-50 border border-indigo-100 px-3 py-1.5 rounded-xl shadow-sm'>
                  {step.years}
                </span>
                <span class='text-xs text-slate-400 font-bold uppercase tracking-widest'>
                  {step.status}
                </span>
              </div>
              <h3 class='text-xl font-bold text-slate-900 mb-3 tracking-tight group-hover:text-indigo-900 transition-colors'>
                {step.phase}
              </h3>
              <p class='text-slate-600 font-medium text-sm leading-relaxed'>
                {step.description}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- High-Impact Partner & Donor CTA Section -->
  <section
    class='relative bg-slate-950/70 py-28 overflow-hidden border-t border-slate-800'>
    <div
      class='absolute inset-0 opacity-15 bg-[radial-gradient(#22d3ee_1px,transparent_1px)] [background-size:24px_24px]'>
    </div>
    <div
      class='absolute -bottom-24 left-1/2 -translate-x-1/2 w-[500px] h-[500px] bg-teal-500/10 rounded-full blur-3xl pointer-events-none'>
    </div>

    <div
      class='max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center'>
      <h2
        class='text-3xl sm:text-5xl font-black text-white mb-6 tracking-tight leading-tight'>
        Collaborate With St. Paul's
      </h2>
      <p
        class='text-lg sm:text-xl text-slate-300 mb-12 leading-relaxed max-w-2xl mx-auto font-medium'>
        Every institutional resource, donor alliance, and partnership
        strengthens our local framework, bringing high-tier medical support
        directly to the communities that rely on us.
      </p>
      <div class='flex flex-col sm:flex-row gap-5 justify-center items-center'>
        <a
          href='/services/clinical'
          class='w-full sm:w-auto text-center bg-white text-slate-950 hover:bg-slate-100 font-bold px-10 py-4 rounded-xl shadow-xl transition-all transform hover:-translate-y-0.5 active:translate-y-0'>
          More About Us
        </a>
        <a
          href='/about-us/contact'
          class='w-full sm:w-auto text-center border-2 border-slate-700 bg-slate-900/30 hover:bg-slate-900 hover:border-slate-500 text-white font-bold px-10 py-4 rounded-xl backdrop-blur-sm transition-all transform hover:-translate-y-0.5 active:translate-y-0'>
          Contact Us
        </a>
      </div>
    </div>
  </section>
</Layout>
