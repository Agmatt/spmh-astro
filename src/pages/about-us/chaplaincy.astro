---
import Layout from '../../Layout/Layout.astro';

const chaplains = [
  {
    id: 1,
    name: 'Father Gumba',
    role: 'Hospital Chaplain',
    imageUrl: '/gallery/gumba.jpeg',
    bio: 'Leads the chaplaincy ministry with deep compassion and pastoral dedication.',
  },
  {
    id: 2,
    name: 'Father Philip',
    role: 'Assistant Chaplain',
    imageUrl: '/gallery/phillip.jpeg',
    bio: 'Supports spiritual care across all wards and serves alongside our lead chaplain.',
  },
];
---

<Layout title="Chaplaincy - St. Paul's Mission Hospital">
  <!-- Refined Centered Hero Section -->
  <section
    class='relative py-8 md:py-24 px-4 md:px-6 flex items-center justify-center min-h-[500px] bg-slate-500 overflow-hidden'>
    <!-- Warm Spiritual Background Image -->
    <div class='absolute inset-0'>
      <img
        src='/gallery/parish.jpg'
        alt='Hospital Chapel'
        class='w-full h-full object-cover brightness-85'
      />
      <div
        class='absolute inset-0 bg-gradient-to-b from-slate-900/60 to-slate-900/90'>
      </div>
    </div>

    <!-- Content -->
    <div class='relative z-10 max-w-3xl mx-auto text-center text-white'>
      <div
        class='inline-flex items-center gap-2 mb-6 text-amber-400 uppercase tracking-widest text-sm font-semibold'>
        <span class='h-px w-8 bg-amber-400'></span>
        Ministry of Presence
        <span class='h-px w-8 bg-amber-400'></span>
      </div>

      <h1 class='text-5xl md:text-6xl font-bold mb-8 leading-tight'>
        Spiritual Care at the Heart of Healing
      </h1>

      <p
        class='text-lg md:text-xl text-slate-200 leading-relaxed max-w-2xl mx-auto font-light'>
        At St. Paul's Mission Hospital, we believe healing involves the whole
        person—body, mind, and spirit. Our chaplaincy ministry offers
        compassionate spiritual support to patients, families, and staff during
        times of vulnerability and hope.
      </p>
    </div>
  </section>

  <!-- Chaplaincy Team Section -->
  <section class="py-16 px-4 md:px-6 md:py-20 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <div class="h-1 w-16 bg-amber-600 mx-auto mb-6"></div>
        <h2 class="text-4xl font-bold text-slate-900 mb-4">
          Our Chaplaincy Team
        </h2>
        <p class="text-lg text-slate-600 max-w-2xl mx-auto">
          Under the Diocese of Homabay, our team of dedicated priests brings pastoral care and spiritual guidance to every corner of our hospital.
        </p>
      </div>

      <!-- Flex layout: Stacked images on left, all text on right -->
      <div class="flex flex-col lg:flex-row gap-12 items-start">
        <!-- Left: Stacked Images -->
        <div class="w-full lg:w-1/2 flex flex-col gap-8">
          {chaplains.map((chaplain) => (
            <div class="flex flex-col">
              <!-- Chaplain Photo Slot - Optimized for viewing -->
              <div class="mb-4  overflow-hidden">
                {chaplain.imageUrl ? (
                  <img 
                    src={chaplain.imageUrl} 
                    alt={chaplain.name}
                    class="w-90 h-90 object-cover"
                    loading="lazy"
                  />
                ) : (
                  <div class="w-full h-80 flex items-center justify-center bg-gradient-to-br from-slate-300 to-slate-400">
                    <div class="text-center">
                      <span class="text-6xl">👨‍⚕️</span>
                      <p class="text-sm text-slate-600 mt-2">Photo placeholder</p>
                    </div>
                  </div>
                )}
              </div>
              
              <!-- Name and role below photo -->
              <h3 class="text-xl font-bold text-slate-900">
                {chaplain.name}
              </h3>
              <p class="text-sm font-semibold text-teal-700 uppercase tracking-wide">
                {chaplain.role}
              </p>
            </div>
          ))}
        </div>

        <!-- Right: All Team Info & Values -->
        <div class="w-full lg:w-1/2">
          <div class="space-y-8">
            <div>
              <h3 class="text-2xl font-bold text-slate-900 mb-4">
                Serving with Compassion
              </h3>
              <p class="text-slate-600 leading-relaxed mb-4">
                Our chaplaincy team brings together dedicated priests committed to holistic healing. Whether through formal services or quiet moments of pastoral presence, they embody the spiritual heart of SPMH's mission.
              </p>
              <p class="text-slate-600 leading-relaxed">
                Each member of our team is trained to listen, comfort, and pray alongside patients and families during their most vulnerable moments—ensuring that spiritual wellbeing is never overlooked in the healing journey.
              </p>
            </div>

            <!-- Key Values Cards -->
            <div class="space-y-4">
              <!-- Value 1 -->
              <div class="flex gap-4 p-4 bg-amber-50 rounded-lg border-l-4 border-amber-600">
                <div class="flex-shrink-0 mt-1">
                  <!-- Heart icon (compassion) -->
                  <svg class="w-6 h-6 text-amber-600" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                  </svg>
                </div>
                <div>
                  <p class="font-semibold text-slate-900">Compassionate Presence</p>
                  <p class="text-sm text-slate-600">Available to listen, comfort, and pray with those in need.</p>
                </div>
              </div>

              <!-- Value 2 -->
              <div class="flex gap-4 p-4 bg-teal-50 rounded-lg border-l-4 border-teal-600">
                <div class="flex-shrink-0 mt-1">
                  <!-- Hands icon (respect/dignity) -->
                  <svg class="w-6 h-6 text-teal-600" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M13 5.5a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0zm6 0a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0zm-12 0a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0zM4 19v-2h16v2H4z" opacity="0.3"/>
                    <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm-1.5-13h3v6h-3z"/>
                  </svg>
                </div>
                <div>
                  <p class="font-semibold text-slate-900">Dignity & Respect</p>
                  <p class="text-sm text-slate-600">Honoring every person as sacred and worthy of care.</p>
                </div>
              </div>

              <!-- Value 3 -->
              <div class="flex gap-4 p-4 bg-amber-50 rounded-lg border-l-4 border-amber-600">
                <div class="flex-shrink-0 mt-1">
                  <!-- Light bulb / Spark icon (faith/hope) -->
                  <svg class="w-6 h-6 text-amber-600" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M9 21c0 .5.4 1 1 1h4c.6 0 1-.5 1-1v-1H9v1zm3-20C5.1 1 2 4.1 2 8c0 2.9 1.7 5.4 4 6.7V19c0 .6.4 1 1 1h6c.6 0 1-.4 1-1v-4.3c2.3-1.3 4-3.8 4-6.7 0-3.9-3.1-7-7-7zm0 12.9c-2.2 0-4-1.8-4-4s1.8-4 4-4 4 1.8 4 4-1.8 4-4 4z"/>
                  </svg>
                </div>
                <div>
                  <p class="font-semibold text-slate-900">Faith-Centered Care</p>
                  <p class="text-sm text-slate-600">Bringing spiritual resources and hope to every healing moment.</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section class='py-16 px-4 md:px-6 md:py-20 bg-slate-50'>
    <div class='max-w-5xl mx-auto'>
      <div class='text-center mb-16'>
        <div class='h-1 w-16 bg-amber-600 mx-auto mb-6'></div>
        <h2 class='text-4xl font-bold text-slate-900 mb-4'>
          Spiritual Services
        </h2>
        <p class='text-lg text-slate-600 max-w-2xl mx-auto'>
          Our chaplaincy offers spiritual support tailored to meet the needs of
          patients and families at every stage of their healing journey.
        </p>
      </div>

      <div class='grid md:grid-cols-3 gap-8'>
        <!-- Service 1: Weekly Mass -->
        <div
          class='bg-white p-8 rounded-lg shadow-sm hover:shadow-md transition-shadow'>
          <h3 class='text-xl font-bold text-slate-900 mb-3'>
            Weekly Mass & Communion
          </h3>

          <p class='text-slate-600 mb-4 leading-relaxed'>
            Every <strong>Wednesday, 7:30–8:00 AM</strong>, we gather for a
            sacred celebration of Mass in our hospital chapel. This gathering is
            open to patients, families, visitors, caregivers, and staff of all
            backgrounds who wish to join in prayer and faith.
          </p>
        </div>

        <!-- Service 2: Ward Ministry -->
        <div
          class='bg-white p-8 rounded-lg shadow-sm hover:shadow-md transition-shadow'>
          <h3 class='text-xl font-bold text-slate-900 mb-3'>
            Bedside Prayer & Blessings
          </h3>

          <p class='text-slate-600 mb-4 leading-relaxed'>
            Following each Wednesday Mass, our chaplaincy team visits the wards
            to bring prayer and pastoral blessing to those who could not attend
            the main service. These moments of spiritual care bring comfort and
            hope to patients wherever they are in their healing.
          </p>
        </div>

        <!-- Service 3: Catholic Celebrations -->
        <div
          class='bg-white p-8 rounded-lg shadow-sm hover:shadow-md transition-shadow'>
          <h3 class='text-xl font-bold text-slate-900 mb-3'>
            Seasonal & Holy Day Masses
          </h3>

          <p class='text-slate-600 mb-4 leading-relaxed'>
            Throughout the year, major Catholic celebrations and feast days are
            honored with special masses and spiritual observances. These moments
            connect our hospital community to the wider faith tradition and mark
            significant spiritual milestones.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 px-4 md:py-28 bg-gray-900/20 text-white">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-4xl md:text-5xl font-bold mb-6 leading-tight">
        Spirituality Matters in Healing
      </h2>
      
      <p class="text-lg md:text-xl text-teal-700 mb-10 leading-relaxed">
        Whether you're seeking solace, celebrating faith, or simply need a compassionate presence, our chaplaincy is here to walk with you. Your spiritual wellbeing is part of our commitment to your whole-person care.
      </p>
      
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/partner" target="_blank" class="inline-flex items-center justify-center px-8 py-4 bg-white text-teal-700 font-semibold rounded-lg hover:bg-teal-50 transition-colors">
          Learn About Other Ways to Support SPMH
        </a>
      </div>
    </div>
  </section>
</Layout>

