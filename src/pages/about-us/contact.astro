---
import Layout from '../../Layout/Layout.astro';

const details = [
  {
    label: 'Address',
    value: 'P.O Box 426, Gov. Cyprian Awiti Street, Homa Bay, Kenya',
    icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z',
  },
  {
    label: 'Email',
    value: 'info@spmh.co.ke',
    icon: 'M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z',
  },
  {
    label: 'Hours',
    value: 'Open 24 hours, 7 days a week',
    icon: 'M12 8v4l3 1.5m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
  },
];
---

<Layout title='Contact Us'>
  <!-- ── HERO SECTION ── -->
  <header
    class='relative bg-gradient-to-br from-[#1565c0] via-[#125276] to-[#0d47a1] text-white overflow-hidden'>
    <!-- Decorative element -->
    <div
      class='absolute top-0 right-0 w-96 h-96 bg-white/5 rounded-full -mr-48 -mt-48'>
    </div>

    <div
      class='relative container mx-auto max-w-6xl px-6 lg:px-8 py-16 lg:py-20'>
      <div class='max-w-2xl'>
        <h1
          class='text-5xl lg:text-6xl text-white tracking-tighter leading-tight mb-4'
          style="font-family: 'Georgia', serif;">
          Reach Us
        </h1>
        <p class='text-lg text-white/80 leading-relaxed max-w-xl'>
          Safe hands, caring hearts — available 24/7. Connect with St. Paul's
          Mission Hospital through your preferred channel.
        </p>
      </div>
    </div>
  </header>

  <main class='bg-white'>
    <!-- ── DETAILS & FORM GRID ── -->
    <section class='container mx-auto max-w-6xl px-6 lg:px-8 py-16 lg:py-20'>
      <div class='grid lg:grid-cols-3 gap-12 lg:gap-16'>
        <!-- Left: Location & Hours -->
        <div class='lg:col-span-1 space-y-8'>
          <!-- Location & Hours Cards -->
          <div class='space-y-6'>
            {
              details.map((detail) => (
                <div class='flex gap-4'>
                  <div class='flex-shrink-0'>
                    <div class='flex items-center justify-center h-12 w-12 rounded-lg bg-[#e8f0fc] text-[#1565c0]'>
                      <svg
                        class='w-6 h-6'
                        fill='none'
                        stroke='currentColor'
                        stroke-width='2'
                        viewBox='0 0 24 24'>
                        <path
                          stroke-linecap='round'
                          stroke-linejoin='round'
                          d={detail.icon}
                        />
                      </svg>
                    </div>
                  </div>
                  <div>
                    <p class='text-sm font-bold text-[#5a6f8c] uppercase tracking-wide'>
                      {detail.label}
                    </p>
                    <p class='text-base font-medium text-[#125276] mt-1'>
                      {detail.value}
                    </p>
                  </div>
                </div>
              ))
            }
          </div>

          <!-- Embedded Map -->
          <div class='mt-12 pt-8 border-t border-[#c5d8f7]'>
            <h3
              class='text-lg font-black text-[#125276] mb-4 flex items-center gap-2'>
              <span class='w-1 h-6 bg-[#860f0f]'></span>
              Find Us
            </h3>
            <div
              class='relative w-full aspect-square rounded-xl overflow-hidden shadow-md'>
              <iframe
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3989.742385312345!2d34.4607123!3d-0.5255383!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x19d52f95c5555555%3A0x5555555555555555!2sSt.%20Paul's%20Mission%20Hospital!5e0!3m2!1sen!2ske!4v1700000000000!5m2!1sen!2ske"
                class='absolute inset-0 w-full h-full border-0'
                allowfullscreen=''
                loading='lazy'
                referrerpolicy='no-referrer-when-downgrade'
                title="St. Paul's Mission Hospital Interactive Map">
              </iframe>
            </div>
          </div>
        </div>

        <!-- Right: Contact Form -->
        <div class='lg:col-span-2'>
          <div class='mb-8'>
            <div class='flex items-center gap-3 mb-3'>
              <div class='w-1 h-8 bg-[#860f0f]'></div>
              <h2
                class='text-2xl lg:text-3xl font-black text-[#125276] tracking-tight'>
                Send Us a Message
              </h2>
            </div>
            <p class='text-[#5a6f8c] text-base'>
              For more detailed inquiries or feedback, please fill out the form
              below. We'll respond within 24 hours.
            </p>
          </div>

          <form
            action='https://formspree.io/f/movnbakk'
            method='POST'
            class='space-y-6'>
            <!-- Full Name -->
            <div class='relative'>
              <input
                type='text'
                name='fullName'
                id='fullName'
                placeholder='Your full name'
                required
                class='w-full px-4 py-3 border border-[#c5d8f7] rounded-lg bg-[#f4f8ff] text-[#125276] placeholder-[#5a6f8c] focus:outline-none focus:ring-2 focus:ring-[#1565c0] focus:bg-white transition-all'
              />
            </div>

            <!-- Email -->
            <div class='relative'>
              <input
                type='email'
                name='emailAddress'
                id='emailAddress'
                placeholder='your.email@example.com'
                required
                class='w-full px-4 py-3 border border-[#c5d8f7] rounded-lg bg-[#f4f8ff] text-[#125276] placeholder-[#5a6f8c] focus:outline-none focus:ring-2 focus:ring-[#1565c0] focus:bg-white transition-all'
              />
            </div>

            <!-- Phone (optional) -->
            <div class='relative'>
              <input
                type='tel'
                name='phone'
                id='phone'
                placeholder='+254 (optional)'
                class='w-full px-4 py-3 border border-[#c5d8f7] rounded-lg bg-[#f4f8ff] text-[#125276] placeholder-[#5a6f8c] focus:outline-none focus:ring-2 focus:ring-[#1565c0] focus:bg-white transition-all'
              />
            </div>

            <!-- Subject -->
            <div class='relative'>
              <select
                name='subject'
                id='subject'
                class='w-full px-4 py-3 border border-[#c5d8f7] rounded-lg bg-[#f4f8ff] text-[#125276] focus:outline-none focus:ring-2 focus:ring-[#1565c0] focus:bg-white transition-all appearance-none'>
                <option value='' disabled selected>Select inquiry type</option>
                <option value='Appointment'>Appointment Request</option>
                <option value='Medical Services'>Medical Services Info</option>
                <option value='Patient Feedback'>Patient Feedback</option>
                <option value='Partnership'>Partnership Inquiry</option>
                <option value='Other'>Other</option>
              </select>
            </div>

            <!-- Message -->
            <div class='relative'>
              <textarea
                name='message'
                id='message'
                rows='5'
                placeholder='Your message...'
                required
                class='w-full px-4 py-3 border border-[#c5d8f7] rounded-lg bg-[#f4f8ff] text-[#125276] placeholder-[#5a6f8c] focus:outline-none focus:ring-2 focus:ring-[#1565c0] focus:bg-white transition-all resize-none'
              ></textarea>
            </div>

            <!-- Submit -->
            <div class='flex gap-3 pt-4'>
              <button
                type='submit'
                class='flex-1 px-8 py-4 bg-gradient-to-r from-[#1565c0] to-[#125276] text-white font-bold rounded-lg hover:shadow-lg hover:-translate-y-0.5 transition-all duration-300'>
                Send Message
              </button>
            </div>
          </form>
        </div>
      </div>
    </section>
  </main>
</Layout>
