---
import '../styles/global.css'
---

<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>Donate — SPMH Outreach</title>
  </head>
  <body class='font-sans antialiased text-gray-900 overflow-x-hidden'>
    <!-- ══════════════════════════════════════════
       HERO
  ══════════════════════════════════════════ -->
    <section
      class='relative min-h-[380px] flex items-center justify-center text-center px-6 py-24'
      style="background: linear-gradient(rgba(10,25,55,0.62), rgba(10,25,55,0.68)), url('https://images.unsplash.com/photo-1532629345422-7515f3d16bb6?w=1400&q=80') center/cover no-repeat;">
      <div class='max-w-2xl mx-auto'>
        <div
          class='inline-flex items-center gap-2 bg-orange-500/20 border border-orange-400/40 text-orange-300 text-sm font-semibold px-4 py-1.5 rounded-full mb-5'>
          <!-- Heroicon: banknotes -->
          <svg
            xmlns='http://www.w3.org/2000/svg'
            viewBox='0 0 24 24'
            fill='currentColor'
            class='w-4 h-4'>
            <path d='M12 7.5a2.25 2.25 0 1 0 0 4.5 2.25 2.25 0 0 0 0-4.5Z'
            ></path>
            <path
              fill-rule='evenodd'
              d='M1.5 4.875C1.5 3.839 2.34 3 3.375 3h17.25c1.035 0 1.875.84 1.875 1.875v9.75c0 1.036-.84 1.875-1.875 1.875H3.375A1.875 1.875 0 0 1 1.5 14.625v-9.75ZM8.25 9.75a3.75 3.75 0 1 1 7.5 0 3.75 3.75 0 0 1-7.5 0ZM18.75 9a.75.75 0 0 0-.75.75v.008c0 .414.336.75.75.75h.008a.75.75 0 0 0 .75-.75V9.75a.75.75 0 0 0-.75-.75h-.008ZM4.5 9.75A.75.75 0 0 1 5.25 9h.008a.75.75 0 0 1 .75.75v.008a.75.75 0 0 1-.75.75H5.25a.75.75 0 0 1-.75-.75V9.75Z'
              clip-rule='evenodd'></path>
            <path
              d='M2.25 18a.75.75 0 0 0 0 1.5c5.4 0 10.63.722 15.6 2.075 1.19.324 2.4-.558 2.4-1.82V18.75a.75.75 0 0 0-.75-.75H2.25Z'
            ></path>
          </svg>
          Support Our Mission
        </div>
        <h1
          class='text-4xl md:text-5xl font-extrabold text-white leading-tight mb-4'>
          Your Generosity Changes Lives
        </h1>
        <p class='text-lg text-white/80'>
          Every contribution — large or small — helps SPMH bring healthcare,
          food, and hope to communities in Homa Bay County.
        </p>
      </div>

      <!-- wave bottom -->
      <!-- <div
        class='absolute bottom-0 left-0 right-0 overflow-hidden leading-none'>
        <svg
          viewBox='0 0 1440 50'
          xmlns='http://www.w3.org/2000/svg'
          preserveAspectRatio='none'
          class='w-full h-10 block'>
          <path d='M0,25 C480,50 960,0 1440,25 L1440,50 L0,50 Z' fill='#fdf6ee'
          ></path>
        </svg>
      </div> -->
    </section>

    <!-- ══════════════════════════════════════════
       IMPACT TEASERS
  ══════════════════════════════════════════ -->
    <section class='bg-[#fdf6ee] px-4 md:px-6 py-14'>
      <div class='max-w-4xl mx-auto'>
        <h2 class='text-center text-xl font-bold text-blue-900 mb-2'>
          What Your Donation Does
        </h2>
        <div class='flex justify-center mb-10'>
          <div class='w-14 h-1 bg-orange-500 rounded'></div>
        </div>
        <div class='grid sm:grid-cols-3 gap-5'>
          <div
            class='bg-white rounded-2xl p-6 text-center shadow-sm border-t-4 border-orange-400'>
            <p class='text-3xl font-extrabold text-orange-500 mb-1'>KES 500</p>
            <p class='text-sm text-gray-500 leading-relaxed'>
              Feeds a family of four for a week through our food assistance
              programme.
            </p>
          </div>
          <div
            class='bg-white rounded-2xl p-6 text-center shadow-sm border-t-4 border-blue-800'>
            <p class='text-3xl font-extrabold text-blue-800 mb-1'>KES 2,000</p>
            <p class='text-sm text-gray-500 leading-relaxed'>
              Covers basic medical supplies for one community health clinic
              outreach.
            </p>
          </div>
          <div
            class='bg-white rounded-2xl p-6 text-center shadow-sm border-t-4 border-orange-400'>
            <p class='text-3xl font-extrabold text-orange-500 mb-1'>
              KES 10,000
            </p>
            <p class='text-sm text-gray-500 leading-relaxed'>
              Sponsors a full outreach event reaching up to 200 community
              members.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
       PAYMENT METHODS
  ══════════════════════════════════════════ -->
    <section class='bg-white px-4 md:px-6 py-16'>
      <div class='max-w-4xl mx-auto'>
        <h2 class='text-2xl font-bold text-blue-900 mb-2'>How to Donate</h2>
        <div class='w-12 h-1 bg-orange-500 rounded mb-10'></div>

        <div class='grid md:grid-cols-2 gap-8'>
          <!-- M-PESA TILL -->
          <div
            class='rounded-2xl border-2 border-green-500 p-4 md:p-8 relative overflow-hidden'>
            <!-- M-Pesa green accent strip -->
            <div
              class='absolute top-0 left-0 right-0 h-1.5 bg-green-500 rounded-t-2xl'>
            </div>

            <div class='flex items-center gap-3 mb-5'>
              <div
                class='inline-flex items-center justify-center w-11 h-11 rounded-full bg-green-100'>
                <!-- Heroicon: device-phone-mobile -->
                <svg
                  xmlns='http://www.w3.org/2000/svg'
                  viewBox='0 0 24 24'
                  fill='currentColor'
                  class='w-6 h-6 text-green-600'>
                  <path
                    d='M10.5 18.75a.75.75 0 0 0 0 1.5h3a.75.75 0 0 0 0-1.5h-3Z'
                  ></path>
                  <path
                    fill-rule='evenodd'
                    d='M8.625.75A3.375 3.375 0 0 0 5.25 4.125v15.75a3.375 3.375 0 0 0 3.375 3.375h6.75a3.375 3.375 0 0 0 3.375-3.375V4.125A3.375 3.375 0 0 0 15.375.75h-6.75ZM7.5 4.125C7.5 3.504 8.004 3 8.625 3H9.75v.375c0 .621.504 1.125 1.125 1.125h2.25c.621 0 1.125-.504 1.125-1.125V3h1.125c.621 0 1.125.504 1.125 1.125v15.75c0 .621-.504 1.125-1.125 1.125h-6.75A1.125 1.125 0 0 1 7.5 19.875V4.125Z'
                    clip-rule='evenodd'></path>
                </svg>
              </div>
              <div>
                <h3 class='font-bold text-gray-900 text-lg leading-tight'>
                  M-Pesa Till
                </h3>
                <p class='text-xs text-gray-400'>Buy Goods & Services</p>
              </div>
            </div>

            <!-- Till number display -->
            <div
              class='bg-green-50 border border-green-200 rounded-xl px-6 py-4 text-center mb-6'>
              <p class='text-xs text-gray-500 uppercase tracking-widest mb-1'>
                Till Number
              </p>
              <p class='text-4xl font-extrabold text-green-700 tracking-widest'>
                XXXXXXX
              </p>
              <p class='text-xs text-gray-400 mt-1'>
                St. Paul's Mission Hospital
              </p>
            </div>

            <!-- Steps -->
            <ol class='space-y-3'>
              {
                [
                  'Go to M-Pesa on your phone',
                  'Select Lipa na M-Pesa → Buy Goods & Services',
                  'Enter Till Number: XXXXXXX',
                  'Enter amount and your M-Pesa PIN',
                  'You will receive a confirmation SMS',
                ].map((step, i) => (
                  <li class='flex items-start gap-3'>
                    <span class='flex-shrink-0 w-6 h-6 rounded-full bg-green-500 text-white text-xs font-bold flex items-center justify-center mt-0.5'>
                      {i + 1}
                    </span>
                    <span class='text-sm text-gray-600'>{step}</span>
                  </li>
                ))
              }
            </ol>

            <div
              class='mt-6 flex items-start gap-2 bg-green-50 border border-green-200 rounded-lg p-3'>
              <!-- Heroicon: information-circle -->
              <svg
                xmlns='http://www.w3.org/2000/svg'
                viewBox='0 0 24 24'
                fill='currentColor'
                class='w-4 h-4 text-green-600 flex-shrink-0 mt-0.5'>
                <path
                  fill-rule='evenodd'
                  d='M2.25 12c0-5.385 4.365-9.75 9.75-9.75s9.75 4.365 9.75 9.75-4.365 9.75-9.75 9.75S2.25 17.385 2.25 12Zm8.706-1.442c1.146-.573 2.437.463 2.126 1.706l-.709 2.836.042-.02a.75.75 0 0 1 .67 1.34l-.04.022c-1.147.573-2.438-.463-2.127-1.706l.71-2.836-.042.02a.75.75 0 1 1-.671-1.34l.041-.022ZM12 9a.75.75 0 1 0 0-1.5A.75.75 0 0 0 12 9Z'
                  clip-rule='evenodd'></path>
              </svg>
              <p class='text-xs text-green-700'>
                Screenshot your confirmation SMS and email it to <span
                  class='font-semibold'>outreach@spmh.co.ke</span
                > so we can acknowledge your gift.
              </p>
            </div>
          </div>

          <!-- BANK TRANSFER -->
          <div
            class='rounded-2xl border-2 border-blue-800 p-4 md:p-8 relative overflow-hidden'>
            <div
              class='absolute top-0 left-0 right-0 h-1.5 bg-blue-800 rounded-t-2xl'>
            </div>

            <div class='flex items-center gap-3 mb-5'>
              <div
                class='inline-flex items-center justify-center w-11 h-11 rounded-full bg-blue-100'>
                <!-- Heroicon: building-library -->
                <svg
                  xmlns='http://www.w3.org/2000/svg'
                  viewBox='0 0 24 24'
                  fill='currentColor'
                  class='w-6 h-6 text-blue-800'>
                  <path
                    d='M11.584 2.376a.75.75 0 0 1 .832 0l9 6a.75.75 0 1 1-.832 1.248L12 3.901 3.416 9.624a.75.75 0 0 1-.832-1.248l9-6Z'
                  ></path>
                  <path
                    fill-rule='evenodd'
                    d='M20.25 10.332v9.918H21a.75.75 0 0 1 0 1.5H3a.75.75 0 0 1 0-1.5h.75v-9.918a.75.75 0 0 1 .634-.74A49.109 49.109 0 0 1 12 9c2.59 0 5.134.202 7.616.592a.75.75 0 0 1 .634.74Zm-7.5 2.418a.75.75 0 0 0-1.5 0v6.75a.75.75 0 0 0 1.5 0v-6.75Zm3-.75a.75.75 0 0 1 .75.75v6.75a.75.75 0 0 1-1.5 0v-6.75a.75.75 0 0 1 .75-.75ZM9 12.75a.75.75 0 0 0-1.5 0v6.75a.75.75 0 0 0 1.5 0v-6.75Z'
                    clip-rule='evenodd'></path>
                </svg>
              </div>
              <div>
                <h3 class='font-bold text-gray-900 text-lg leading-tight'>
                  Bank Transfer
                </h3>
                <p class='text-xs text-gray-400'>
                  Direct deposit to SPMH account
                </p>
              </div>
            </div>

            <!-- Bank details table -->
            <div
              class='bg-blue-50 border border-blue-200 rounded-xl overflow-hidden mb-6'>
              {
                [
                  ['Account Name', "St. Paul's Mission Hospital"],
                  ['Bank', 'XXXX Bank'],
                  ['Branch', 'Homa Bay Branch'],
                  ['Account Number', '01116766349100'],
                  ['Swift / RTGS Code', 'XXXXXXXXX'],
                ].map(([label, value]) => (
                  <div class='flex border-b border-blue-100 last:border-0'>
                    <span class='w-30 flex-shrink-0 text-xs font-semibold text-gray-500 uppercase tracking-wide px-4 py-3 border-r border-blue-100 bg-blue-100/40'>
                      {label}
                    </span>
                    <span class='text-sm font-medium text-blue-900 px-4 py-3'>
                      {value}
                    </span>
                  </div>
                ))
              }
            </div>

            <!-- Reference instruction -->
            <div
              class='flex items-start gap-2 bg-orange-50 border border-orange-200 rounded-lg p-3 mb-5'>
              <!-- Heroicon: exclamation-triangle -->
              <svg
                xmlns='http://www.w3.org/2000/svg'
                viewBox='0 0 24 24'
                fill='currentColor'
                class='w-4 h-4 text-orange-500 flex-shrink-0 mt-0.5'>
                <path
                  fill-rule='evenodd'
                  d='M9.401 3.003c1.155-2 4.043-2 5.197 0l7.355 12.748c1.154 2-.29 4.5-2.599 4.5H4.645c-2.309 0-3.752-2.5-2.598-4.5L9.4 3.003ZM12 8.25a.75.75 0 0 1 .75.75v3.75a.75.75 0 0 1-1.5 0V9a.75.75 0 0 1 .75-.75Zm0 8.25a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Z'
                  clip-rule='evenodd'></path>
              </svg>
              <p class='text-xs text-orange-700'>
                Use <span class='font-bold'>"OUTREACH DONATION"</span> as your payment
                reference so we can correctly allocate your gift.
              </p>
            </div>

            <p class='text-sm text-gray-400'>
              After transfer, please notify us at <span
                class='font-semibold text-gray-600'>outreach@spmh.co.ke</span
              > with your transaction reference for acknowledgement.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
       TRUST SIGNALS
  ══════════════════════════════════════════ -->
    <section class='bg-[#fdf6ee] px-6 py-14'>
      <div class='max-w-4xl mx-auto'>
        <h2 class='text-center text-xl font-bold text-blue-900 mb-2'>
          Why Give to SPMH?
        </h2>
        <div class='flex justify-center mb-10'>
          <div class='w-14 h-1 bg-orange-500 rounded'></div>
        </div>
        <div class='grid sm:grid-cols-3 gap-6 text-center'>
          <div class='flex flex-col items-center gap-3'>
            <div
              class='inline-flex items-center justify-center w-12 h-12 rounded-full bg-orange-100'>
              <!-- Heroicon: shield-check -->
              <svg
                xmlns='http://www.w3.org/2000/svg'
                viewBox='0 0 24 24'
                fill='currentColor'
                class='w-6 h-6 text-orange-500'>
                <path
                  fill-rule='evenodd'
                  d='M12.516 2.17a.75.75 0 0 0-1.032 0 11.209 11.209 0 0 1-7.877 3.08.75.75 0 0 0-.722.515A12.74 12.74 0 0 0 2.25 9.75c0 5.942 4.064 10.933 9.563 12.348a.749.749 0 0 0 .374 0c5.499-1.415 9.563-6.406 9.563-12.348 0-1.39-.223-2.73-.635-3.985a.75.75 0 0 0-.722-.516l-.143.001c-2.996 0-5.717-1.17-7.705-3.078Zm3.094 8.016a.75.75 0 1 0-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 0 0-1.06 1.06l2.25 2.25a.75.75 0 0 0 1.14-.094l3.75-5.25Z'
                  clip-rule='evenodd'></path>
              </svg>
            </div>
            <h3 class='font-bold text-gray-800 text-sm'>Accountable</h3>
            <p class='text-xs text-gray-500 leading-relaxed'>
              Under the Catholic Diocese of Homa Bay, SPMH operates with full
              institutional accountability and governance.
            </p>
          </div>

          <div class='flex flex-col items-center gap-3'>
            <div
              class='inline-flex items-center justify-center w-12 h-12 rounded-full bg-orange-100'>
              <!-- Heroicon: eye -->
              <svg
                xmlns='http://www.w3.org/2000/svg'
                viewBox='0 0 24 24'
                fill='currentColor'
                class='w-6 h-6 text-orange-500'>
                <path d='M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z'></path>
                <path
                  fill-rule='evenodd'
                  d='M1.323 11.447C2.811 6.976 7.028 3.75 12.001 3.75c4.97 0 9.185 3.223 10.675 7.69.12.362.12.752 0 1.113-1.487 4.471-5.705 7.697-10.677 7.697-4.97 0-9.186-3.223-10.675-7.69a1.762 1.762 0 0 1 0-1.113ZM17.25 12a5.25 5.25 0 1 1-10.5 0 5.25 5.25 0 0 1 10.5 0Z'
                  clip-rule='evenodd'></path>
              </svg>
            </div>
            <h3 class='font-bold text-gray-800 text-sm'>Transparent</h3>
            <p class='text-xs text-gray-500 leading-relaxed'>
              Donations are directed specifically to outreach programmes and are
              reported on annually.
            </p>
          </div>

          <div class='flex flex-col items-center gap-3'>
            <div
              class='inline-flex items-center justify-center w-12 h-12 rounded-full bg-orange-100'>
              <!-- Heroicon: map-pin -->
              <svg
                xmlns='http://www.w3.org/2000/svg'
                viewBox='0 0 24 24'
                fill='currentColor'
                class='w-6 h-6 text-orange-500'>
                <path
                  fill-rule='evenodd'
                  d='m11.54 22.351.07.04.028.016a.76.76 0 0 0 .723 0l.028-.015.071-.041a16.975 16.975 0 0 0 1.144-.742 19.58 19.58 0 0 0 2.683-2.282c1.944-2.079 3.943-5.42 3.943-9.827a8.25 8.25 0 0 0-16.5 0c0 4.407 1.999 7.748 3.942 9.827a19.58 19.58 0 0 0 2.683 2.282 16.975 16.975 0 0 0 1.145.742ZM12 13.5a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z'
                  clip-rule='evenodd'></path>
              </svg>
            </div>
            <h3 class='font-bold text-gray-800 text-sm'>Locally Rooted</h3>
            <p class='text-xs text-gray-500 leading-relaxed'>
              100% of outreach donations stay within Homa Bay County, directly
              serving local communities.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
       CTA FOOTER BAND
  ══════════════════════════════════════════ -->
    <section class='bg-blue-900 px-6 py-12 text-center'>
      <h2 class='text-2xl font-bold text-white mb-3'>
        Questions About Donating?
      </h2>
      <p class='text-blue-200 text-sm mb-6 max-w-lg mx-auto'>
        Our team is happy to help — whether you want to give a one-off gift, set
        up regular giving, or discuss a larger partnership.
      </p>
      <a
        href='mailto:outreach@spmh.co.ke'
        class='inline-flex items-center gap-2 bg-orange-500 hover:bg-orange-600 text-white font-bold px-7 py-3 rounded-lg transition-colors duration-200'>
        <!-- Heroicon: envelope -->
        <svg
          xmlns='http://www.w3.org/2000/svg'
          viewBox='0 0 24 24'
          fill='currentColor'
          class='w-5 h-5'>
          <path
            d='M1.5 8.67v8.58a3 3 0 0 0 3 3h15a3 3 0 0 0 3-3V8.67l-8.928 5.493a3 3 0 0 1-3.144 0L1.5 8.67Z'
          ></path>
          <path
            d='M22.5 6.908V6.75a3 3 0 0 0-3-3h-15a3 3 0 0 0-3 3v.158l9.714 5.978a1.5 1.5 0 0 0 1.572 0L22.5 6.908Z'
          ></path>
        </svg>
        Contact Outreach Team
      </a>
    </section>
  </body>
</html>
