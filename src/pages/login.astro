---
// src/pages/editorial-login.astro
// Standalone login page for editorial staff
// Routes to /editorial-dashboard on successful auth

import '../styles/global.css';
---

<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>Editorial Login | St. Paul's Mission Hospital</title>
  </head>
  <body>
    <section
      class='min-h-screen bg-gradient-to-br from-slate-900 to-slate-800 flex items-center justify-center px-6 py-12'>
      <div class='w-full max-w-md'>
        <!-- HEADER -->
        <div class='text-center mb-8'>
          <h1 class='font-serif text-3xl text-white mb-2'>
            Editorial Dashboard
          </h1>
          <p class='text-slate-300'>Manage news, press releases, and events</p>
        </div>

        <!-- LOGIN FORM -->
        <div
          class='bg-white rounded-lg shadow-lg p-8'
          x-data='editorialLogin()'
          @submit.prevent='handleLogin'>
          <form class='space-y-5'>
            <!-- EMAIL INPUT -->
            <div>
              <label class='block text-sm font-medium text-slate-700 mb-1'
                >Email</label
              >
              <input
                x-model='email'
                type='email'
                placeholder='staff@spmh.co.ke'
                required
                class='w-full px-4 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#125276]'
              />
            </div>

            <!-- PASSWORD INPUT -->
            <div>
              <label class='block text-sm font-medium text-slate-700 mb-1'
                >Password</label
              >
              <input
                x-model='password'
                type='password'
                placeholder='••••••••'
                required
                class='w-full px-4 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#125276]'
              />
            </div>

            <!-- ERROR MESSAGE -->
            <div
              x-show='error'
              x-cloak
              class='p-3 bg-red-50 border border-red-200 rounded-lg text-sm text-red-700'>
              <span x-text='error'></span>
            </div>

            <!-- LOADING STATE -->
            <div
              x-show='loading'
              x-cloak
              class='p-3 bg-blue-50 border border-blue-200 rounded-lg text-sm text-blue-700'>
              Signing in...
            </div>

            <!-- SUBMIT BUTTON -->
            <button
              type='submit'
              :disabled='loading'
              class='w-full py-2 bg-[#125276] text-white font-semibold rounded-lg hover:bg-[#0d3a5c] transition-colors disabled:opacity-50 disabled:cursor-not-allowed'>
              Sign In
            </button>
          </form>

          <!-- FOOTER NOTE -->
          <p class='text-xs text-slate-500 text-center mt-6'>
            Contact your administrator if you don't have login credentials.
          </p>
        </div>
      </div>
    </section>

    <script>
      function editorialLogin() {
        return {
          email: '',
          password: '',
          loading: false,
          error: '',

          async handleLogin() {
            this.error = '';
            this.loading = true;

            try {
              // Import supabase dynamically (assumes you have it installed)
              const { createClient } = await import('@supabase/supabase-js');

              const supabase = createClient(
                import.meta.env.PUBLIC_SUPABASE_URL,
                import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
              );

              // Sign in with email/password
              const { data, error: signInError } =
                await supabase.auth.signInWithPassword({
                  email: this.email,
                  password: this.password,
                });

              if (signInError) {
                this.error = signInError.message;
                this.loading = false;
                return;
              }

              if (!data.session) {
                this.error = 'No session returned. Please try again.';
                this.loading = false;
                return;
              }

              // Verify user has editorial role
              const { data: adminUser, error: roleError } = await supabase
                .from('admin_users')
                .select('role')
                .eq('user_id', data.session.user.id)
                .single();

              if (roleError || !adminUser || adminUser.role !== 'editorial') {
                await supabase.auth.signOut();
                this.error =
                  'You do not have editorial access. Contact your administrator.';
                this.loading = false;
                return;
              }

              // Success — redirect to dashboard
              window.location.href = '/editorial-dashboard';
            } catch (err) {
              this.error = err.message || 'An unexpected error occurred.';
              this.loading = false;
            }
          },
        };
      }
    </script>
  </body>
</html>
