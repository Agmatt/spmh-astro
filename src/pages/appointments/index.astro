---
import '../../styles/global.css';
import AppointmentBooking from '../../react-islands/AppointmentBooking';
---

<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>Book an Appointment | SPMH</title>
  </head>
  <body> 
  <!-- ── HERO ──────────────────────────────────────────────────────────────── -->
  <section class='relative overflow-hidden bg-[#0d3b6e] min-h-[520px]'>
    <!-- BG image slot — replace src -->
    <img
      src='/img/5.jpg'
      alt=''
      class='absolute inset-0 w-full h-full object-cover blur-md scale-105 opacity-70'
    />
    <!-- Overlay -->
    <div
      class='absolute inset-0 bg-gradient-to-br from-[#0d3b6e]/90 to-[#125276]/75'>
    </div>

    <div
      class='relative z-10 max-w-5xl mx-auto px-4 md:px-6 py-20 md:py-28 flex flex-col md:flex-row md:items-center gap-10'>
      <!-- Text side -->
      <div class='flex-1'>
        <!-- Back link -->
        <a
          href='/'
          class='inline-flex items-center gap-1.5 text-white/70 hover:text-white text-sm mb-6 transition-colors'>
          <svg
            xmlns='http://www.w3.org/2000/svg'
            class='w-4 h-4'
            fill='none'
            viewBox='0 0 24 24'
            stroke='currentColor'
            stroke-width='2'>
            <path
              stroke-linecap='round'
              stroke-linejoin='round'
              d='M10 19l-7-7m0 0l7-7m-7 7h18'></path>
          </svg>
          Back to SPMH
        </a>

        <h1
          class='text-4xl md:text-6xl font-extrabold text-white leading-[1.1] tracking-tight mb-4'>
          Book your<br />
          <span class='text-sky-300'>appointment</span>
        </h1>
        <p class='text-white/75 text-lg max-w-md leading-relaxed mb-8'>
          Quick, easy, and convenient. Schedule your visit to St. Paul's Mission
          Hospital in just a few steps.
        </p>

        <!-- Trust chips -->
        <div class='flex flex-wrap gap-2'>
          <span
            class='inline-flex items-center gap-1.5 bg-white/10 border border-white/20 text-white text-xs font-medium px-3 py-1.5 rounded-full backdrop-blur-sm'>
            <svg
              xmlns='http://www.w3.org/2000/svg'
              class='w-3.5 h-3.5'
              fill='none'
              viewBox='0 0 24 24'
              stroke='currentColor'
              stroke-width='2'>
              <path
                stroke-linecap='round'
                stroke-linejoin='round'
                d='M5 13l4 4L19 7'></path>
            </svg>
            Confirmed in minutes
          </span>
          <span
            class='inline-flex items-center gap-1.5 bg-white/10 border border-white/20 text-white text-xs font-medium px-3 py-1.5 rounded-full backdrop-blur-sm'>
            <svg
              xmlns='http://www.w3.org/2000/svg'
              class='w-3.5 h-3.5'
              fill='none'
              viewBox='0 0 24 24'
              stroke='currentColor'
              stroke-width='2'>
              <path
                stroke-linecap='round'
                stroke-linejoin='round'
                d='M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z'></path>
            </svg>
            24/7 Emergency care
          </span>
        </div>
      </div>

      <!-- Card image side — replace src -->
      <div
        class='w-full md:w-80 flex-shrink-0 rounded-2xl overflow-hidden shadow-2xl'>
        <img
          src='/img/28.jpg'
          alt='SPMH care'
          class='w-full h-56 md:h-64 object-cover block'
        />
        <!-- Stats bar -->
        <div class='bg-white flex items-center justify-around px-5 py-4'>
          <div class='text-center'>
            <span
              class='block text-xl font-extrabold text-[#125276] leading-none'
              >6+</span
            >
            <span
              class='block text-[10px] uppercase tracking-widest text-gray-6px-4 md:00 mt-0.5'
              >Specialties</span
            >
          </div>
          <div class='w-px h-8 bg-gray-200'></div>
          <div class='text-center'>
            <span
              class='block text-xl font-extrabold text-[#125276] leading-none'
              >24/7</span
            >
            <span
              class='block text-[10px] uppercase tracking-widest text-gray-6px-4 md:00 mt-0.5'
              >Emergency</span
            >
          </div>
          <div class='w-px h-8 bg-gray-200'></div>
          <div class='text-center'>
            <span
              class='block text-xl font-extrabold text-[#125276] leading-none'
              >Fast</span
            >
            <span
              class='block text-[10px] uppercase tracking-widest text-gray-6px-4 md:00 mt-0.5'
              >Confirmation</span
            >
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── BOOKING FORM ───────────────────────────────────────────────────────── -->
  <section class='bg-[#f0f4f8] py-16 px-4'>
    <div class='max-w-2xl mx-auto text-center mb-10'>
      <p
        class='text-xs font-bold uppercase tracking-widest text-[#125276] mb-2'>
        Step 1 of 1
      </p>
      <h2 class='text-3xl font-extrabold text-[#0d3b6e] mb-2'>
        Fill in your details
      </h2>
      <p class='text-gray-500 text-sm'>
        We'll confirm your slot as soon as we receive your request.
      </p>
    </div>
    <AppointmentBooking client:load />
  </section>

  <!-- ── FAQ ───────────────────────────────────────────────────────────────── -->
  <section class='bg-white py-20 px-4'>
    <div class='max-w-2xl mx-auto'>
      <div class='text-center mb-12'>
        <p
          class='text-xs font-bold uppercase tracking-widest text-[#125276] mb-2'>
          Common questions
        </p>
        <h2 class='text-3xl font-extrabold text-[#0d3b6e] mb-3'>
          Frequently asked questions
        </h2>
        <p class='text-gray-500 text-sm'>
          Can't find your answer?
          <a
            href='/about-us/contact'
            class='text-teal-500 font-semibold hover:underline'
            >Contact us directly →</a
          >
        </p>
      </div>

      <div class='space-y-3'>
        <!-- FAQ 1 -->
        <details
          class='border border-gray-200 rounded-xl overflow-hidden group open:border-[#125276] open:shadow-[0_0_0_3px_rgba(18,82,118,0.08)] transition-all'>
          <summary
            class='flex items-center gap-3 px-5 py-4 cursor-pointer list-none font-semibold text-[#0d3b6e] text-[0.95rem] select-none [&::-webkit-details-marker]:hidden'>
            <span
              class='flex items-center justify-center w-9 h-9 rounded-lg bg-blue-50 text-[#125276] flex-shrink-0'>
              <svg
                xmlns='http://www.w3.org/2000/svg'
                class='w-5 h-5'
                fill='none'
                viewBox='0 0 24 24'
                stroke='currentColor'
                stroke-width='2'>
                <path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  d='M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z'
                ></path>
              </svg>
            </span>
            <span class='flex-1'>Can I cancel or reschedule?</span>
            <svg
              xmlns='http://www.w3.org/2000/svg'
              class='w-5 h-5 text-gray-400 transition-transform group-open:rotate-180 flex-shrink-0'
              fill='none'
              viewBox='0 0 24 24'
              stroke='currentColor'
              stroke-width='2'>
              <path
                stroke-linecap='round'
                stroke-linejoin='round'
                d='M19 9l-7 7-7-7'></path>
            </svg>
          </summary>
          <p
            class='px-5 pb-5 pl-[4.25rem] text-gray-500 text-sm leading-relaxed'>
            Yes, you can cancel or reschedule up to 24 hours before your
            appointment by calling our front desk.
          </p>
        </details>

        <!-- FAQ 2 -->
        <details
          class='border border-gray-200 rounded-xl overflow-hidden group open:border-[#125276] open:shadow-[0_0_0_3px_rgba(18,82,118,0.08)] transition-all'>
          <summary
            class='flex items-center gap-3 px-5 py-4 cursor-pointer list-none font-semibold text-[#0d3b6e] text-[0.95rem] select-none [&::-webkit-details-marker]:hidden'>
            <span
              class='flex items-center justify-center w-9 h-9 rounded-lg bg-blue-50 text-[#125276] flex-shrink-0'>
              <svg
                xmlns='http://www.w3.org/2000/svg'
                class='w-5 h-5'
                fill='none'
                viewBox='0 0 24 24'
                stroke='currentColor'
                stroke-width='2'>
                <path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  d='M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2'
                ></path>
              </svg>
            </span>
            <span class='flex-1'>What should I bring?</span>
            <svg
              xmlns='http://www.w3.org/2000/svg'
              class='w-5 h-5 text-gray-400 transition-transform group-open:rotate-180 flex-shrink-0'
              fill='none'
              viewBox='0 0 24 24'
              stroke='currentColor'
              stroke-width='2'>
              <path
                stroke-linecap='round'
                stroke-linejoin='round'
                d='M19 9l-7 7-7-7'></path>
            </svg>
          </summary>
          <p
            class='px-5 pb-5 pl-[4.25rem] text-gray-500 text-sm leading-relaxed'>
            Please bring a valid national ID and any previous
            medical records or prescriptions relevant to your visit.
          </p>
        </details>

        <!-- FAQ 3 -->
        <details
          class='border border-gray-200 rounded-xl overflow-hidden group open:border-[#125276] open:shadow-[0_0_0_3px_rgba(18,82,118,0.08)] transition-all'>
          <summary
            class='flex items-center gap-3 px-5 py-4 cursor-pointer list-none font-semibold text-[#0d3b6e] text-[0.95rem] select-none [&::-webkit-details-marker]:hidden'>
            <span
              class='flex items-center justify-center w-9 h-9 rounded-lg bg-blue-50 text-[#125276] flex-shrink-0'>
              <svg
                xmlns='http://www.w3.org/2000/svg'
                class='w-5 h-5'
                fill='none'
                viewBox='0 0 24 24'
                stroke='currentColor'
                stroke-width='2'>
                <path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  d='M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z'
                ></path>
              </svg>
            </span>
            <span class='flex-1'>Is emergency care available?</span>
            <svg
              xmlns='http://www.w3.org/2000/svg'
              class='w-5 h-5 text-gray-400 transition-transform group-open:rotate-180 flex-shrink-0'
              fill='none'
              viewBox='0 0 24 24'
              stroke='currentColor'
              stroke-width='2'>
              <path
                stroke-linecap='round'
                stroke-linejoin='round'
                d='M19 9l-7 7-7-7'></path>
            </svg>
          </summary>
          <p
            class='px-5 pb-5 pl-[4.25rem] text-gray-500 text-sm leading-relaxed'>
            Yes, our emergency department operates 24/7. For life-threatening
            emergencies, please come directly or call ahead so we can prepare
            for your arrival.
          </p>
        </details>

        <!-- FAQ 4 -->
        <details
          class='border border-gray-200 rounded-xl overflow-hidden group open:border-[#125276] open:shadow-[0_0_0_3px_rgba(18,82,118,0.08)] transition-all'>
          <summary
            class='flex items-center gap-3 px-5 py-4 cursor-pointer list-none font-semibold text-[#0d3b6e] text-[0.95rem] select-none [&::-webkit-details-marker]:hidden'>
            <span
              class='flex items-center justify-center w-9 h-9 rounded-lg bg-blue-50 text-[#125276] flex-shrink-0'>
              <svg
                xmlns='http://www.w3.org/2000/svg'
                class='w-5 h-5'
                fill='none'
                viewBox='0 0 24 24'
                stroke='currentColor'
                stroke-width='2'>
                <path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  d='M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z'
                ></path>
              </svg>
            </span>
            <span class='flex-1'>What payment methods are accepted?</span>
            <svg
              xmlns='http://www.w3.org/2000/svg'
              class='w-5 h-5 text-gray-400 transition-transform group-open:rotate-180 flex-shrink-0'
              fill='none'
              viewBox='0 0 24 24'
              stroke='currentColor'
              stroke-width='2'>
              <path
                stroke-linecap='round'
                stroke-linejoin='round'
                d='M19 9l-7 7-7-7'></path>
            </svg>
          </summary>
          <p
            class='px-5 pb-5 pl-[4.25rem] text-gray-500 text-sm leading-relaxed'>
            We accept M-Pesa,SHA and other corporate insurance . Please confirm insurance coverage
            with our billing desk before your appointment.
          </p>
        </details>
      </div>
    </div>
  </section>

  <!-- ── CTA STRIP ──────────────────────────────────────────────────────────── -->
  <section class='bg-gradient-to-r from-[#0d3b6e] to-[#125276] py-12 px-4'>
    <div
      class='max-w-4xl mx-auto flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6'>
      <div>
        <p class='text-xl font-bold text-white mb-1'>Need help? We're here.</p>
        <p class='text-white/70 text-sm'>
          Call our front desk or walk in — St. Paul's Mission Hospital, Homa
          Bay.
        </p>
      </div>
      <div class='flex gap-3 flex-wrap'>
        <a
          href='tel:+254111817447'
          class='px-5 py-2.5 bg-white text-[#0d3b6e] font-bold text-sm rounded-lg hover:opacity-90 transition-opacity'>
          Call us
        </a>
        <a
          href='/'
          class='px-5 py-2.5 border border-white/30 text-white font-semibold text-sm rounded-lg hover:bg-white/10 transition-colors'>
          ← Back to website
        </a>
      </div>
    </div>
  </section>
  </body>
</html>


