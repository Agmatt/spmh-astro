---
const services = [
  {
    id: 'emergency',
    icon: 'M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z',
    title: 'Emergency & Trauma Response',
    badge: '24/7 Priority',
    desc: 'Immediate clinical intervention around the clock. Completely self-referral structured — our emergency medicine unit functions at peak operational readiness before you arrive.',
    points: [
      'Immediate expert triage on arrival',
      'Dedicated trauma resuscitation bay',
      'Direct rapid admission pathways',
    ],
    cta: 'Get Emergency Care',
    ctaHref: '/services/clinical#emergency',
    isEmergency: true,
  },
  {
    id: 'maternity',
    icon: 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z',
    title: 'Maternity & Full ANC Journey',
    badge: 'Full Continuum',
    desc: 'Complete comprehensive maternal care loop. Guiding mothers safely from custom antenatal clinic blocks through dignified delivery and postpartum specialized newborn care.',
    points: [
      'Antenatal clinics & birth scheduling',
      'Skilled, compassionate midwifery',
      'Neonatal specialized care wing',
    ],
    cta: 'Book Antenatal Visit',
    ctaHref: '/services/antenatal-clinic',
    isEmergency: false,
  },
  {
    id: 'surgical',
    icon: 'M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z',
    title: 'Surgical Services & Theater',
    badge: 'Advanced Care',
    desc: 'Elective and emergency specialist procedures driven by rigorous surgical safety checklists. Full pre-operative optimization and structured recovery frameworks.',
    points: [
      'General and specialized procedures',
      '24/7 standby emergency theater',
      'Advanced post-anesthesia recovery',
    ],
    cta: 'Learn About Surgery',
    ctaHref: '/services/clinical#surgical',
    isEmergency: false,
  },
];
---

<section
  class='py-24 lg:py-32 bg-muted/10 antialiased'
  style='font-family: var(--font-body);'>
  <div class='max-w-7xl mx-auto px-6 lg:px-12'>
    <div class='max-w-3xl mx-auto text-center mb-20'>
      <h2
        class='text-3xl sm:text-4xl lg:text-5xl font-extrabold tracking-tight text-[var(--color-secondary)] uppercase leading-tight'
        style='font-family: var(--font-display);'>
        Our Core <br> Medical Pillars
      </h2>
    </div>

    <div class='grid grid-cols-1 lg:grid-cols-3 gap-10 items-stretch'>
      {
        services.map((service) => (
          <div
            key={service.id}
            class='bg-slate-50 border border-slate-200/60 p-8 lg:p-10 flex flex-col justify-between min-h-[520px] rounded-2xl relative transition-all duration-500 ease-out hover:bg-white hover:shadow-xl hover:border-slate-300 group'>
            <div>
              <div class='flex items-center justify-between pb-6 border-b border-slate-200/50 mb-8'>
                <div class='text-slate-400 group-hover:text-[var(--color-primary)] transition-colors duration-300'>
                  <svg
                    class='w-6 h-6'
                    fill='none'
                    stroke='currentColor'
                    stroke-width='1.5'
                    viewBox='0 0 24 24'
                    style={{
                      color: service.isEmergency
                        ? '#be123c'
                        : 'var(--color-secondary)',
                    }}>
                    <path
                      stroke-linecap='round'
                      stroke-linejoin='round'
                      d={service.icon}
                    />
                  </svg>
                </div>
                <span
                  class={`text-[9px] font-mono uppercase tracking-[0.2em] font-bold px-3 py-1 rounded ${
                    service.isEmergency
                      ? 'bg-rose-50 text-accent border border-rose-100'
                      : 'bg-slate-200/50 text-slate-700'
                  }`}>
                  {service.badge}
                </span>
              </div>

              <h3 class='text-xl sm:text-2xl font-black tracking-tight text-slate-900 mb-4 font-display group-hover:text-[var(--color-primary)] transition-colors duration-300'>
                {service.title}
              </h3>

              <p class='text-slate-500 text-m leading-relaxed mb-8 font-normal'>
                {service.desc}
              </p>

              <ul class='space-y-3 pt-6 border-t border-slate-200/50'>
                {service.points.map((point) => (
                  <li class='flex items-center gap-3'>
                    <span class='w-1.5 h-[1px] bg-slate-400 group-hover:w-3 group-hover:bg-[var(--color-primary)] transition-all duration-300 shrink-0' />
                    <span class='text-sm text-slate-600 font-medium tracking-wide group-hover:text-slate-900 transition-colors duration-300'>
                      {point}
                    </span>
                  </li>
                ))}
              </ul>
            </div>

            <div class='mt-10 pt-6 border-t border-slate-200/50'>
              <a
                href={service.ctaHref}
                class={`w-full text-center text-xs tracking-widest uppercase font-bold block py-3.5 px-4 rounded-xl transition-all duration-300 border ${
                  service.isEmergency
                    ? 'bg-accent text-white border-transparent hover:bg-rose-800 shadow-sm shadow-rose-100'
                    : 'bg-secondary text-white border-transparent hover:bg-primary shadow-sm'
                }`}>
                {service.cta}
              </a>
            </div>

            <div class='absolute bottom-0 left-10 right-10 h-[2px] bg-transparent transition-all duration-500 scale-x-70 group-hover:left-8 group-hover:right-8 group-hover:scale-x-100 group-hover:bg-[var(--color-primary)]' />
          </div>
        ))
      }
    </div>
  </div>
</section>
