---
/**
 * LatestDevelopments.astro — Premium Institutional Showcase
 * 
 * Clean, structured card layouts displaying strategic institutional milestones.
 * Completely static, fast-loading, and responsive across all viewports.
 */

const developments = [
  {
    id: "groundbreaking",
    title: "Maternity & Surgical Wing",
    headline: "A landmark investment in maternal and surgical care.",
    desc: "Breaking ground on our new wing expansion to drastically scale inpatient capacity and bring cutting-edge clinical infrastructure directly to our community.",
    points: [
      "Dedicated maternity beds",
      "Modern surgical theatre",
      "Postnatal care unit",
      "Expanded inpatient capacity",
      "Enhanced privacy & dignity",
    ],
    cta: "View Project Details",
    ctaHref: "/developments/maternity-surgical-wing",
    btnClass: "bg-red-700 text-white hover:bg-red-800 shadow-red-100", // Highlighted upcoming focus
    isAccent: true,
  },
  {
    id: "newborn",
    title: "Newborn Unit",
    headline: "Providing specialized neonatology from day one.",
    desc: "Our dedicated Newborn Unit is fully operational, delivering safe, expert clinical intervention for our smallest and most vulnerable patients across the county.",
    points: [
      "Dedicated newborn environment",
      "Skilled shift nursing staff",
      "Thermoregulation units",
      "Maternity ward integration",
      "Kangaroo mother care",
    ],
    cta: "Learn About the Unit",
    ctaHref: "/developments/newborn-unit",
    btnClass: "bg-[var(--color-primary)] text-white hover:bg-slate-800",
    isAccent: false,
  },
  {
    id: "hdu",
    title: "High Dependency Unit",
    headline: "Bridging complex ward and intensive therapy care.",
    desc: "Establishing our High Dependency Unit (HDU) to deliver continuous tracking and higher nurse-to-patient ratios for complex, high-risk clinical recovery.",
    points: [
      "Continuous vitals monitoring",
      "Higher nurse ratios",
      "Post-op recovery support",
      "Ward to ICU bridge care",
      "Serving regional environs",
    ],
    cta: "About the HDU Project",
    ctaHref: "/developments/hdu",
    btnClass: "bg-[var(--color-secondary)] text-white hover:bg-slate-900",
    isAccent: false,
  },
];
---

<section class="py-24 lg:py-32 bg-[var(--color-surface)] antialiased overflow-hidden" style="font-family: var(--font-body);">
  <div class="max-w-7xl mx-auto px-6 lg:px-12">

    <!-- ── Centered Typography Block ── -->
    <div class="text-center max-w-2xl mx-auto mb-16">
      <span class="text-[10px] font-mono text-[var(--color-primary)] uppercase tracking-[0.35em] font-bold block mb-2.5">
        Latest Developments
      </span>
      <h2 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-[var(--color-secondary)] uppercase leading-none" style="font-family: var(--font-display);">
        Strategic <span class="text-slate-950">Progressions</span>
      </h2>
      <div class="w-12 h-[2px] bg-slate-900 mx-auto mt-5"></div>
    </div>

    <!-- ── Balanced Static Column Grid ── -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 items-stretch">
      {developments.map((dev) => (
        <div 
          key={dev.id} 
          class="bg-white border border-slate-200/80 p-6 lg:p-8 flex flex-col justify-between min-h-[490px] rounded-2xl shadow-xs relative transition-all duration-500 ease-out hover:-translate-y-1.5 hover:shadow-xl hover:border-slate-300 group"
        >
          <div>
            <!-- Header Labels -->
            <h3 class="text-xl font-bold tracking-tight text-slate-900 mb-2 transition-colors group-hover:text-[var(--color-primary)]" style="font-family: var(--font-display);">
              {dev.title}
            </h3>
            <p class="text-[var(--color-primary)] text-m font-semibold leading-tight mb-3">
              {dev.headline}
            </p>
            <p class="text-slate-500 leading-relaxed mb-6">
              {dev.desc}
            </p>

            <!-- Specs Grid Block -->
            <ul class="space-y-2.5 pt-5 border-t border-slate-100">
              {dev.points.map(point => (
                <li class="flex items-start gap-2.5">
                  <span class="flex size-1 rounded-full bg-slate-300 group-hover:bg-[var(--color-primary-light)] mt-1.5 shrink-0 transition-colors duration-300"></span>
                  <span class="text-sm text-slate-600 font-normal transition-colors">{point}</span>
                </li>
              ))}
            </ul>
          </div>

          <!-- Bottom Button Interface Link -->
          <div class="mt-8 pt-5 border-t border-slate-100">
            <a
              href={dev.ctaHref}
              class={`w-full text-center text-xs tracking-wider font-bold block py-3 px-4 rounded-xl transition-all duration-300 shadow-xs hover:shadow-md active:scale-[0.98] ${dev.btnClass}`}
            >
              {dev.cta}
            </a>
          </div>

          <!-- Decorative Top Accent Layer Line -->
          <div 
            class="absolute top-0 left-6 right-6 h-[4px] rounded-b-md transition-all duration-500 group-hover:left-0 group-hover:right-0 group-hover:rounded-t-2xl group-hover:rounded-b-none" 
            style={{ backgroundColor: dev.isAccent ? '#b91c1c' : 'var(--color-primary)' }}
          ></div>
        </div>
      ))}
    </div>

  </div>
</section>