---
/**
 * LatestDevelopments.astro — Premium Institutional Showcase
 * * Compact card layouts displaying strategic institutional milestones.
 * Clean tracking architecture utilizing custom design system tokens.
 */

const developments = [
  {
    id: "groundbreaking",
    title: "New Maternity & Surgical Wing",
    headline: "A landmark investment in maternal and surgical care.",
    desc: "Breaking ground on a new wing—a cornerstone of our Strategic Plan 2026–2030. This expansion builds inpatient capacity and advances our progression toward Level 5 facility standards.",
    points: [
      "Dedicated maternity beds",
      "Modern surgical theatre",
      "Postnatal care unit",
      "Expanded inpatient capacity",
      "Enhanced privacy & dignity",
      "Closer to Level 5 by 2030",
    ],
    cta: "View Project Details",
    ctaHref: "/developments/maternity-surgical-wing",
    btnClass: "btn-tertiary", // Highlighted upcoming focus
    isAccent: true,
  },
  {
    id: "newborn",
    title: "Newborn Unit",
    headline: "Providing specialized neonatology from day one.",
    desc: "Our dedicated Newborn Unit is operational, delivering safe, expert clinical intervention for our smallest and most vulnerable patients across Homa Bay County.",
    points: [
      "Dedicated newborn environment",
      "Skilled shift nursing staff",
      "Thermoregulation units",
      "Maternity ward integration",
      "Kangaroo mother care",
      "Accessible care access framework",
    ],
    cta: "Learn About the Unit",
    ctaHref: "/developments/newborn-unit",
    btnClass: "btn-primary",
    isAccent: false,
  },
  {
    id: "hdu",
    title: "High Dependency Unit",
    headline: "Bridging complex ward and intensive therapy care.",
    desc: "Establishing our High Dependency Unit (HDU) to deliver continuous tracking and higher nurse-to-patient ratios for complex, high-risk clinical recovery.",
    points: [
      "Continuous vitals monitoring",
      "Higher nurse ratios",
      "Post-op recovery support",
      "Ward to ICU bridge care",
      "Level 5 readiness alignment",
      "Serving regional environs",
    ],
    cta: "About the HDU Project",
    ctaHref: "/developments/hdu",
    btnClass: "btn-secondary",
    isAccent: false,
  },
]
---

<section class="py-16 lg:py-20 bg-[var(--color-surface)] antialiased overflow-hidden" style="font-family: var(--font-body);">
  <div class="max-w-7xl mx-auto px-6 lg:px-12">

    <div class="flex flex-col md:flex-row items-center justify-center text-center border-b border-[var(--color-border)] pb-6 mb-10">
      <div class="max-w-xl">
        <span class="text-xs font-bold uppercase mb-4 tracking-[0.25em] text-[var(--color-muted)] block">Latest Developments</span>
        <h2 class="text-3xl lg:text-4xl font-light tracking-tight text-[var(--color-secondary)]" style="font-family: var(--font-display);">
          Strategic <span class="font-bold text-[var(--color-primary)]">Progressions</span>
        </h2>
      </div>
      
    </div>

    <div class="relative" x-data="devCarousel()">
      <div class="overflow-hidden">
        <div
          class="flex gap-6 transition-transform duration-700 cubic-bezier(0.16, 1, 0.3, 1)"
          :style="`transform: translateX(-${currentIndex * calcTransform}%)`"
        >
          {developments.map((dev, idx) => (
            /* Card Component Container: Optimized Heights */
            <div 
              key={dev.id} 
              class="w-full md:w-[calc(50%-12px)] lg:w-[calc(33.333%-16px)] flex-shrink-0 bg-white border border-[var(--color-border)] p-4 md:p-6 lg:p-7 flex flex-col justify-between min-h-[400px] rounded-lg shadow-sm relative transition-all duration-300 hover:border-[var(--color-primary)]"
            >
              <div>
                <h3 class="text-xl font-bold tracking-tight text-[var(--color-secondary)] mb-1.5" style="font-family: var(--font-display);">
                  {dev.title}
                </h3>
                <p class="text-[var(--color-primary)] text-xs font-semibold leading-tight mb-3">
                  {dev.headline}
                </p>
                <p class="text-[var(--color-muted)] text-xs leading-relaxed mb-4">
                  {dev.desc}
                </p>

                <div class="grid grid-cols-12 gap-3 pt-3 border-t border-[var(--color-surface-2)] items-start">
                  <ul class="col-span-7 space-y-1">
                    {dev.points.slice(0, 4).map(point => ( // Sliced slightly to tightly manage height limits
                      <li class="flex items-start gap-1.5">
                        <span class="text-[var(--color-primary-light)] text-[9px] mt-0.5">▪</span>
                        <span class="text-[11px] text-[var(--color-secondary)] tracking-wide truncate max-w-full">{point}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>

              <div class="mt-5 pt-4 border-t border-[var(--color-surface)]">
                <a
                  href={dev.ctaHref}
                  class={`btn ${dev.btnClass} w-full text-center text-xs tracking-wide font-semibold shadow-sm`}
                >
                  {dev.cta}
                </a>
              </div>

              <div 
                class="absolute top-0 left-0 right-0 h-[3px] rounded-t-lg" 
                style={{ backgroundColor: dev.isAccent ? 'var(--color-accent)' : 'var(--color-primary)' }}
              ></div>
            </div>
          ))}
        </div>
      </div>

      <div class="flex items-center justify-center mt-8 gap-3">
        {developments.map((_, idx) => (
          <button
            key={idx}
            @click={`currentIndex = ${idx}`}
            class="group flex items-center justify-center p-1.5 focus:outline-none"
            aria-label={`Maps to portfolio asset segment 0${idx + 1}`}
          >
            <div 
              class="w-2.5 h-2.5 rounded-full transition-all duration-500 ease-out"
              :class={`currentIndex === ${idx} ? 'bg-[var(--color-accent)] scale-125 shadow-sm' : 'bg-[var(--color-border)] group-hover:bg-[var(--color-muted)]'`}
            ></div>
          </button>
        ))}
      </div>

    </div>
  </div>

  <script is:inline>
    function devCarousel() {
      return {
        currentIndex: 0,
        calcTransform: 100,
        init() {
          const checkLayoutGrid = () => {
            if (window.innerWidth >= 1024) {
              this.calcTransform = 33.333; // 3 Columns Desktop
            } else if (window.innerWidth >= 768) {
              this.calcTransform = 50;     // 2 Columns Tablet
            } else {
              this.calcTransform = 100;    // Full view Mobile standard
            }
          };
          
          checkLayoutGrid();
          window.addEventListener('resize', checkLayoutGrid);

          // Paced lifecycle frame integration
          setInterval(() => {
            const indexThreshold = window.innerWidth >= 1024 ? 0 : window.innerWidth >= 768 ? 1 : 2;
            this.currentIndex = this.currentIndex >= indexThreshold ? 0 : this.currentIndex + 1;
          }, 6500);
        }
      }
    }
  </script>
</section>