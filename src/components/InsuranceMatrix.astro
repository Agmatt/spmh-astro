---
const corporateLogos = [
  { name: "Social Health Authority (SHA)", src: "/logos/sha.png", alt: "SHA Kenya Logo" },
  { name: "Madison", src: "/logos/madison.jpeg", alt: "Madison Logo" },
  { name: "Jubilee Insurance", src: "/logos/jubilee.png", alt: "Jubilee Insurance Underwriters" },
  { name: "CIC Group", src: "/logos/cic.png", alt: "CIC General Medical Cover" },
  { name: "Britam Health", src: "/logos/britam.jpeg", alt: "Britam Corporate Panel" },
  { name: "M-tiba", src: "/logos/mtiba.png", alt: "M-tiba Health Network Cover" },
  { name: "GA", src: "/logos/GA.jpg", alt: "GA" },
  { name: "AAR", src: "/logos/aar.png", alt: "AAR" },
  { name: "KA Insurance", src: "/logos/KA.png", alt: "KA Insurance" },
  { name: "APA Insurance", src: "/logos/apa.png", alt: "APA Insurance" },
];

// duplicate the array so the scroll loop is seamless
const loopLogos = [...corporateLogos, ...corporateLogos];
---

<section class="py-16 lg:py-20 bg-muted/30 border-y border-slate-200/60 antialiased" style="font-family: var(--font-body);">
  <div class="max-w-7xl mx-auto px-6 lg:px-12 text-center mb-10">
    <p class="text-xs font-semibold tracking-[0.2em] text-primary/70 uppercase mb-2">
      Trusted Partners
    </p>
    <h3 class="text-xl sm:text-2xl font-semibold tracking-tight text-secondary font-display">
      Accepted Insurance &amp; Medical Schemes
    </h3>
  </div>

  <!-- Edge-fade mask so the scroll appears to dissolve at the container edges -->
  <div class="relative w-full overflow-hidden [mask-image:linear-gradient(to_right,transparent,black_10%,black_90%,transparent)]">
    <div class="flex w-max animate-marquee gap-12 lg:gap-20 items-center py-2 hover:[animation-play-state:paused]">
      {loopLogos.map((logo) => (
        <div class="shrink-0 h-12 flex items-center justify-center">
          <img
            src={logo.src}
            alt={logo.alt}
            title={logo.name}
            class="max-h-10 sm:max-h-12 w-auto object-contain grayscale opacity-70 hover:grayscale-0 hover:opacity-100 transition-all duration-300"
            loading="lazy"
          />
        </div>
      ))}
    </div>
  </div>
</section>

<style is:global>
  @keyframes marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
  .animate-marquee {
    animation: marquee 28s linear infinite;
  }
  @media (prefers-reduced-motion: reduce) {
    .animate-marquee { animation: none; }
  }
</style>