const tagClasses: Record<string, string> = {
  accent:    "bg-accent/10 text-accent border border-accent/20",
  primary:   "bg-primary/10 text-primary border border-primary/20",
  secondary: "bg-secondary/10 text-secondary border border-secondary/20",
}
---

<section
  id="services"
  class="py-24 bg-gray-100"
  x-data="{ active: 'All' }"
>
  <div class="max-w-7xl mx-auto px-2 md:px-4 lg:px-16">

    <!-- Section label + filter row -->
    <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-6 mb-12">

      <div>
        <p class="text-primary text-xs tracking-[0.22em] uppercase font-semibold mb-3">
          What We Offer
        </p>
        <h2 class="font-display text-4xl lg:text-5xl text-secondary font-normal leading-tight">
          Our Services
        </h2>
      </div>

      <!-- Alpine filter pills -->
      <div class="flex flex-wrap gap-2">
        {categories.map(cat => (
          <button
            @click={`active = '${cat}'`}
            :class={`active === '${cat}'
              ? 'bg-primary text-white border-primary'
              : 'bg-white text-muted border-border hover:border-primary hover:text-primary'`}
            class="px-4 py-2 text-xs font-semibold tracking-wide uppercase border transition-all duration-200"
          >
            {cat}
          </button>
        ))}
      </div>

    </div>

    <!-- Divider -->
    <div class="h-px bg-gradient-to-r from-primary/30 via-border to-transparent mb-12"></div>

    <!-- Grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {services.map((s) => (
        <a
          href={s.href}
          x-show={`active === 'All' || active === '${s.category}'`}
          x-transition:enter="transition duration-300"
          x-transition:enter-start="opacity-0 translate-y-2"
          x-transition:enter-end="opacity-100 translate-y-0"
          class="group relative flex flex-col gap-5 p-7 border border-border/60
                 hover:border-primary/30 hover:shadow-lg hover:shadow-primary/5
                 transition-all duration-300 bg-white hover:bg-surface"
        >
          <!-- Top row: icon + tag -->
          <div class="flex items-start justify-between">
            <div class="size-12 flex items-center justify-center bg-surface-2 text-primary
                        group-hover:bg-primary group-hover:text-white transition-all duration-300">
              <svg class="size-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d={s.icon}/>
              </svg>
            </div>
            {s.tag && (
              <span class={`text-[0.62rem] font-bold tracking-[0.15em] uppercase px-2.5 py-1 ${tagClasses[s.tagColor!]}`}>
                {s.tag}
              </span>
            )}
          </div>

          <!-- Text -->
          <div class="flex-1">
            <h3 class="font-display text-lg font-semibold text-secondary group-hover:text-primary
                       transition-colors duration-200 mb-2 leading-snug">
              {s.name}
            </h3>
            <p class="text-muted text-sm leading-relaxed">{s.desc}</p>
          </div>

          <!-- Category + arrow -->
          <div class="flex items-center justify-between pt-4 border-t border-border/50">
            <span class="text-[0.62rem] tracking-[0.15em] uppercase text-border font-semibold">
              {s.category}
            </span>
            <svg class="size-4 text-border group-hover:text-primary group-hover:translate-x-1
                        transition-all duration-200"
                 fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </div>

        </a>
      ))}
    </div>

  </div>
</section>
